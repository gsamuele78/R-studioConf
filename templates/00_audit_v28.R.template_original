  oconf <- readLines(override, warn = FALSE)
  checks <- c(); issues <- c()
  if (any(grepl("MemoryMax=", oconf))) {
    mem <- sub(".*MemoryMax=([0-9]+[A-Z]).*", "\\1", oconf[grep("MemoryMax=", oconf)[1]])
    checks <- c(checks, sprintf("RAM=%s", mem))
  } else issues <- c(issues, "No MemoryMax")
  if (any(grepl("OLLAMA_HOST=127\\.0\\.0\\.1", oconf))) checks <- c(checks, "localhost") else issues <- c(issues, "OLLAMA_HOST not 127.0.0.1")
  if (any(grepl("OLLAMA_KEEP_ALIVE=", oconf))) checks <- c(checks, "idle-unload")
  if (any(grepl("OLLAMA_MAX_LOADED_MODELS=", oconf))) checks <- c(checks, "single-model")
  if (length(issues) > 0) stop(paste(issues, collapse = "; "))
  paste(checks, collapse = ", ")
}, fix_hint = "Redeploy with 50_setup_nodes.sh")

