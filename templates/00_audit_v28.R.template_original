                  error = function(e) NULL)
  if (is.null(bmc)) stop("biome_make_cluster not found")
  # Inspect formals: must include 'outfile' arg (new in v11.0)
  fml <- names(formals(bmc))
  if (!"outfile" %in% fml) stop(sprintf("biome_make_cluster missing 'outfile' arg (formals: %s)",
