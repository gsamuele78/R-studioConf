    heap_gb <- as.integer(sub("-Xmx([0-9]+)g", "\\1", heap_match))
    quota <- tryCatch(.biome_env$shared_env$last_quota, error = function(e) 0)
    expected_heap <- max(2L, min(16L, as.integer(floor(quota * 0.25))))
