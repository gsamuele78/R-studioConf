    cl <- bmc(workers = 1, worker_threads = 1L)
    on.exit(try(parallel::stopCluster(cl), silent = TRUE), add = TRUE)
    # Give worker a moment to log its greeting
    parallel::clusterEvalQ(cl, Sys.getpid())
    parallel::stopCluster(cl)
  }, error = function(e) stop(sprintf("Smoke test failed: %s", e$message)))

  # Check if any log file was created in cluster_logs/
  logs_found <- if (dir.exists(cl_dir)) list.files(cl_dir, pattern = "^psock_.*\\.log$") else character(0)
  sprintf("OK (outfile arg present, cluster_logs=%d file(s))", length(logs_found))
