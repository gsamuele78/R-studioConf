run_audit("2.4", "Ollama Model Readiness", {
  models_raw <- tryCatch(
    system2("curl", args = c("-s", "-m", "5", "http://127.0.0.1:11434/api/tags"), stdout = TRUE, stderr = FALSE),
    error = function(e) ""
