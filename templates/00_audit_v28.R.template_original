# v28 [CRITICAL]: top-level return() bug fix — ensure worker Rscript survives profile load
run_audit("14.20", "Top-level return() bug fix (v11.0 CRITICAL)", {
  # v10.0 had a bug: `return(invisible(NULL))` at top-level of Rprofile.site
  # causes "Error: no function to return from" under Rscript, which halts
  # execution BEFORE the -e body runs. Worker PSOCK nodes die at handshake.
  # v11.0 fixes this by wrapping everything in local() blocks with if/else.
  #
  # We detect if the bug is present by actually spawning an Rscript subprocess
  # with BIOME_WORKER_MODE=1 and checking it can execute a -e body.
  profile_path <- tryCatch({
    r_home <- R.home()
    candidates <- c(
      file.path(r_home, "etc", "Rprofile.site"),
      "/etc/R/Rprofile.site"
    )
    found <- candidates[file.exists(candidates)]
    if (length(found) == 0) stop("Rprofile.site not found in standard locations")
    found[1]
  }, error = function(e) NULL)
  if (is.null(profile_path)) stop("Cannot locate Rprofile.site")

  # Check for the v10 bug pattern: top-level `return(...)` not wrapped in local()
  # A simple static check — count top-level return() calls outside local()/function()
  prof_lines <- tryCatch(readLines(profile_path, warn = FALSE), error = function(e) character(0))
  # Strip comments
  stripped <- sub("#.*$", "", prof_lines)
  # The v10 bug signature: lines with ONLY whitespace + `return(invisible(NULL))` or similar
  # AND not inside a function/local block. Hard to check statically, so we just
  # check for the v11 fix marker in the header.
  has_v11_marker <- any(grepl("v11.0|LOCAL-DISK ARCHITECTURE|return\\(\\) inside local\\(\\)", prof_lines))
  if (!has_v11_marker) {
    warning("Rprofile.site header does not show v11.0 marker — fix may be absent")
  }

  # Real test: spawn Rscript with --no-init-file (parallelly flags) and BIOME_WORKER_MODE=1
  tmp_marker <- tempfile(fileext = ".txt")
  on.exit(unlink(tmp_marker), add = TRUE)

  # Ensure R_PROFILE points at the same file so Rscript uses it
  env_cmd <- c(
    sprintf("R_PROFILE=%s", profile_path),
    "BIOME_WORKER_MODE=1",
    "BIOME_WORKER_THREADS=1"
  )
  cmd_str <- sprintf('env %s Rscript --no-init-file --no-save --no-restore --no-echo -e %s',
                      paste(env_cmd, collapse = " "),
                      shQuote(sprintf('cat("WORKER_ALIVE=", Sys.getpid(), file="%s")', tmp_marker)))
  result <- tryCatch(
    system(cmd_str, intern = FALSE, ignore.stderr = TRUE),
    error = function(e) 1L
  )

  if (result != 0 || !file.exists(tmp_marker)) {
    stop("Rscript aborted (BUG PRESENT) — top-level return() halts worker at Rprofile load")
  }
  marker_content <- tryCatch(readLines(tmp_marker, warn = FALSE), error = function(e) "")
  if (!grepl("WORKER_ALIVE=", paste(marker_content, collapse = ""))) {
    stop("Rscript exited but -e body did NOT run (BUG PRESENT)")
  }
  sprintf("OK (worker Rscript survives Rprofile load)")
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Deploy Rprofile v11.0 — fixes top-level return() that aborted Rscript workers")

