  if (TMP_REDIRECT_PCT > 95) warning(sprintf("Redirect threshold %d%% is very high — OOM risk", TMP_REDIRECT_PCT))
  sprintf("Warn@%d%% Redirect@%d%% BigData@%dGB", TMP_WARN_PCT, TMP_REDIRECT_PCT, BIG_DATA_THRESHOLD_GB)
}, fix_hint = "Check setup_nodes.vars.conf threshold values")

run_audit("6.3", "Per-User Tmp Isolation", {
  user <- Sys.info()[["user"]]
  user_root <- file.path("/tmp", paste0("biome_", user))
  if (!dir.exists(user_root)) {
    warning(sprintf("biome_%s not created yet (deferred until first package load)", user))
  } else {
    subdirs <- list.dirs(user_root, recursive = FALSE, full.names = FALSE)
    other_users <- list.dirs("/tmp", recursive = FALSE, full.names = FALSE)
    other_biome <- grep("^biome_", other_users, value = TRUE)
    other_biome <- setdiff(other_biome, paste0("biome_", user))
    # Check we can't access other users' dirs
    leaked <- c()
    for (ob in other_biome) {
      ob_path <- file.path("/tmp", ob)
      if (file.access(ob_path, 4) == 0) leaked <- c(leaked, ob)  # readable
    }
    if (length(leaked) > 0) warning(sprintf("Can read other users' tmp: %s", paste(leaked, collapse=", ")))
    return(sprintf("OK (subdirs: %s)", paste(subdirs, collapse=", ")))
  }
  "Pending (not yet initialized)"
}, fix_hint = "Run library(terra) or library(ggplot2) to trigger deferred init")

