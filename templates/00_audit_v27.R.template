run_audit("11.1", "glmmTMB Hessian Inversion (Poisson GLMM)", {
  # glmmTMB builds a Hessian matrix via TMB C++ automatic differentiation,
  # then inverts it with solve(). This is the #1 OOM pattern for Bayesian ecologists.
  if (!.audit_pkgs[["glmmTMB"]]) return("Skipped (glmmTMB not installed)")
  tryCatch({
    set.seed(42)
    # Simulate GBIF-style species count data (Poisson family)
    N <- 1000; n_sites <- 50
    dat <- data.frame(
      count    = rpois(N, lambda = 5),
      habitat  = rnorm(N, 10, 3),
      elevation = rnorm(N, 500, 200),
      site     = factor(rep(1:n_sites, each = N / n_sites))
    )
    # Add zero-inflation (common in ecology — 30% structural zeros)
    dat$count[rbinom(N, 1, 0.3) == 1] <- 0L

    initial_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
    t0 <- Sys.time()
    mod <- glmmTMB::glmmTMB(count ~ habitat + elevation + (1|site),
                             data = dat, family = poisson())
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
    post_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))

    if (!inherits(mod, "glmmTMB")) stop("glmmTMB object not returned")
    if (post_t != initial_t) stop(sprintf("Thread leak: %d -> %d", initial_t, post_t))

    n_fx <- length(glmmTMB::fixef(mod)$cond)
    aic <- round(AIC(mod), 1)
    rm(dat, mod); gc(verbose = FALSE)
    sprintf("OK (%.1fs, %d fixed effects, AIC=%.0f, threads=%d)", dt, n_fx, aic, post_t)
  }, error = function(e) stop(sprintf("glmmTMB failed: %s", e$message)))
}, timeout = 60, use_fork = TRUE,
   fix_hint = "Check TMB/glmmTMB + solve() thread management in Rprofile v9.6")

