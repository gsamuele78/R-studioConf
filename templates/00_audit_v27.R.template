  }
}, error = function(e) NULL)

# Dual-write: console + logfile
audit_cat <- function(...) {
  msg <- paste0(...)
  cat(msg)
  tryCatch(cat(msg, file = LOG_FILE, append = TRUE), error = function(e) NULL)
}

