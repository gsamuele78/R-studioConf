      temp = rnorm(200, 18, 5),
      precip = rnorm(200, 800, 200),
      ndvi = runif(200, 0.2, 0.9)
    )

    # Use a fast method (glm) with small grid — tests expand.grid path
    ctrl <- caret::trainControl(method = "cv", number = 3)
    t0 <- Sys.time()
    mod <- caret::train(species_richness ~ ., data = dat, method = "glm",
                        trControl = ctrl, family = "poisson")
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))

    if (!inherits(mod, "train")) stop("caret train object not returned")

    # Also test expand.grid explicitly with ecology-style parameter sweep
    grid <- expand.grid(
      shrinkage = c(0.01, 0.05, 0.1),
      interaction.depth = c(1, 2, 3, 5),
      n.minobsinnode = c(5, 10, 20),
      n.trees = c(100, 500, 1000)
    )
    if (nrow(grid) != 108) stop(sprintf("expand.grid wrong: %d rows (expected 108)", nrow(grid)))

    rm(dat, mod, grid); gc(verbose = FALSE)
    sprintf("OK (GLM CV in %.1fs, expand.grid 108 rows verified)", dt)
  }, error = function(e) stop(sprintf("caret failed: %s", e$message)))
}, timeout = 60, use_fork = TRUE,
   fix_hint = "Check caret + expand.grid() guard in Rprofile v9.6")
# ==============================================================================
# [12.0] NIMBLE COMPILATION TESTS (Bayesian MCMC — Martina spGDMM pattern)
# ==============================================================================
# Inspired by plan/Test/test_Martina/test_Martina2.R (spGDMM with nimbleHMC).
# These tests validate the NIMBLE C++ compilation pipeline:
#   - compileNimble() creates artifacts on NFS ($HOME), NOT on /Rtmp
#   - Compiler scratch files (.o intermediates) use /Rtmp
#   - No SIGSEGV during the C++ compilation chain
#   - Thread safety with OpenBLAS during compilation
# We use a TINY model — NOT the full 247-site spGDMM — to keep runtime < 120s.
# ==============================================================================
audit_cat("\n[12.0] NIMBLE COMPILATION TESTS (Bayesian MCMC)\n")

run_audit("12.1", "NIMBLE Model Compilation (NFS routing)", {
  if (!.audit_pkgs[["nimble"]]) return("Skipped (nimble not installed)")
  tryCatch({
    # Minimal conjugate model — fastest possible compile
    code <- nimble::nimbleCode({
      mu ~ dnorm(0, sd = 10)
      sigma ~ dunif(0, 100)
      for (i in 1:5) {
        y[i] ~ dnorm(mu, sd = sigma)
      }
    })
    
    set.seed(42)
    model <- nimble::nimbleModel(
      code,
      data = list(y = rnorm(5, 10, 2)),
      inits = list(mu = 0, sigma = 1),
      check = FALSE
    )
    
    initial_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
    t0 <- Sys.time()
    Cmodel <- nimble::compileNimble(model)
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
    post_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
    
    # Verify NFS routing: NIMBLE dir should be under $HOME (NFS), not /Rtmp
    nimble_dir <- nimble::getNimbleDir()
    home <- Sys.getenv("HOME")
    if (!grepl(home, nimble_dir, fixed = TRUE)) {
      warning(sprintf("NIMBLE dir not on NFS: %s (expected under %s)", nimble_dir, home))
    }
    
    # Verify no thread leak
    if (post_t != initial_t) warning(sprintf("Thread change during compile: %d -> %d", initial_t, post_t))
    
    # Basic smoke: compiled model should have calculate()
    calc_ok <- tryCatch({ Cmodel$calculate(); TRUE }, error = function(e) FALSE)
    if (!calc_ok) warning("Compiled model calculate() failed")
    
    rm(model, Cmodel); gc(verbose = FALSE)
    sprintf("OK (compile=%.1fs, dir=%s, threads=%d)", dt, basename(nimble_dir), post_t)
  }, error = function(e) stop(sprintf("NIMBLE compile failed: %s", e$message)))
}, timeout = 120, use_fork = TRUE,
   fix_hint = "Check nimble installation, NFS mount, and C++ compiler (g++)")

run_audit("12.2", "NIMBLE MCMC Build + Short Run", {
  if (!.audit_pkgs[["nimble"]]) return("Skipped (nimble not installed)")
  tryCatch({
    # Build MCMC and run 10 iterations — validates the full pipeline
    code <- nimble::nimbleCode({
      mu ~ dnorm(0, sd = 10)
      sigma ~ dunif(0, 100)
      for (i in 1:5) {
        y[i] ~ dnorm(mu, sd = sigma)
      }
    })
    
    set.seed(42)
    model <- nimble::nimbleModel(
      code,
      data = list(y = rnorm(5, 10, 2)),
      inits = list(mu = 0, sigma = 1),
      check = FALSE
    )
    
    mcmcConf <- nimble::configureMCMC(model, print = FALSE)
    mcmc <- nimble::buildMCMC(mcmcConf)
    Cmodel <- nimble::compileNimble(model)
    Cmcmc <- nimble::compileNimble(mcmc, project = model)
    
    t0 <- Sys.time()
    Cmcmc$run(10)  # 10 iterations — smoke test only
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
    
    # Get samples — verify dimensions
    samples <- as.matrix(Cmcmc$mvSamples)
    if (nrow(samples) != 10) stop(sprintf("Expected 10 samples, got %d", nrow(samples)))
    if (!"mu" %in% colnames(samples)) stop("'mu' not in MCMC samples")
    
    rm(model, mcmcConf, mcmc, Cmodel, Cmcmc, samples); gc(verbose = FALSE)
    sprintf("OK (10 iters in %.2fs, %d params sampled)", dt, ncol(samples))
  }, error = function(e) stop(sprintf("NIMBLE MCMC failed: %s", e$message)))
}, timeout = 180, use_fork = TRUE,
   fix_hint = "Check nimble C++ compiler chain and /Rtmp scratch space")

run_audit("12.3", "NIMBLE buildDerivs (HMC-ready, Martina pattern)", {
  # Martina's test_Martina2.R uses buildDerivs=TRUE for nimbleHMC
  # This validates the AD (automatic differentiation) compilation path
  if (!.audit_pkgs[["nimble"]]) return("Skipped (nimble not installed)")
  if (!.audit_pkgs[["nimbleHMC"]]) return("Skipped (nimbleHMC not installed)")
  tryCatch({
    code <- nimble::nimbleCode({
      mu ~ dnorm(0, sd = 10)
      for (i in 1:5) {
        y[i] ~ dnorm(mu, sd = 1)
      }
    })
    
    set.seed(42)
    model <- nimble::nimbleModel(
      code,
      data = list(y = rnorm(5, 10, 2)),
      inits = list(mu = 0),
      buildDerivs = TRUE,   # ← Martina's pattern: required for HMC
      check = FALSE
    )
    
    t0 <- Sys.time()
    Cmodel <- nimble::compileNimble(model)
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
    
    # Verify derivatives are available (AD compilation succeeded)
    derivs_ok <- tryCatch({
      model$enableDerivs(c("mu"))
      TRUE
    }, error = function(e) FALSE)
    
    rm(model, Cmodel); gc(verbose = FALSE)
    sprintf("OK (AD compile=%.1fs, derivs=%s)", dt, if (derivs_ok) "enabled" else "unavailable")
  }, error = function(e) stop(sprintf("NIMBLE AD compile failed: %s", e$message)))
}, timeout = 180, use_fork = TRUE,
   fix_hint = "Check nimbleHMC installation and C++ compiler with AD support")

# ==============================================================================
# [14.0] INFRASTRUCTURE PLUMBING (pessimistic edge tests)
# ==============================================================================
# These tests validate the INVISIBLE infrastructure that makes everything work:
#   - Env vars, callbacks, thread isolation, systemd services
#   - If any of these break, the user-facing features silently degrade
# Design: lightweight checks only (no heavy compute)
# ==============================================================================
audit_cat("\n[14.0] INFRASTRUCTURE PLUMBING (env vars, callbacks, workers)\n")

run_audit("14.1", "PSOCK Cluster Thread Isolation", {
  # biome_make_cluster() creates PSOCK workers with OPENBLAS_NUM_THREADS=1
  # If broken: each worker runs 16 BLAS threads → 64-thread stampede → OOM
  bmc <- tryCatch(get("biome_make_cluster", envir = as.environment("tools:biome_calc")), error = function(e) NULL)
  if (is.null(bmc)) stop("biome_make_cluster not exported to tools:biome_calc")
  
  tryCatch({
    cl <- bmc(workers = 2, worker_threads = 1L)
    on.exit(try(parallel::stopCluster(cl), silent = TRUE), add = TRUE)
    
    # Each worker reports its OPENBLAS_NUM_THREADS
    worker_blas <- parallel::clusterEvalQ(cl, as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "-1")))
    worker_omp  <- parallel::clusterEvalQ(cl, as.integer(Sys.getenv("OMP_NUM_THREADS", "-1")))
    
    blas_vals <- unlist(worker_blas)
    omp_vals  <- unlist(worker_omp)
    
    if (any(blas_vals > 2)) stop(sprintf("Workers have OPENBLAS_NUM_THREADS=%s (expected 1)", paste(blas_vals, collapse=",")))
    if (any(omp_vals > 2))  stop(sprintf("Workers have OMP_NUM_THREADS=%s (expected 1)", paste(omp_vals, collapse=",")))
    
    parallel::stopCluster(cl)
    sprintf("OK (2 workers, BLAS=%s, OMP=%s)", paste(blas_vals, collapse=","), paste(omp_vals, collapse=","))
  }, error = function(e) stop(sprintf("Cluster test failed: %s", e$message)))
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Check .biome_make_cluster_impl in Rprofile v10.0")

run_audit("14.2", "future::plan() Worker Thread Safety", {
  # Future hook should set plan(cluster) with thread-capped workers
  if (!requireNamespace("future", quietly = TRUE)) return("Skipped (future not installed)")
  tryCatch({
    future_workers <- tryCatch(.biome_env$shared_env$future_workers, error = function(e) 0L)
    
    if (future_workers > 0L) {
      # Workers are already registered — test one
      val <- future::value(future::future({
        list(
          blas = as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "-1")),
          omp  = as.integer(Sys.getenv("OMP_NUM_THREADS", "-1")),
          pid  = Sys.getpid()
        )
      }))
      if (val$blas > 2) stop(sprintf("Future worker OPENBLAS=%d (expected 1)", val$blas))
      sprintf("OK (%d workers registered, worker BLAS=%d)", future_workers, val$blas)
    } else {
      # Future not yet initialized — just verify the hook exists
      hook_exists <- !is.null(tryCatch(.biome_env$deferred_pkg_hooks, error = function(e) NULL))
      if (hook_exists) "Pending (future not loaded yet — hook ready)" else stop("No deferred_pkg_hooks function")
    }
  }, error = function(e) stop(sprintf("Future test failed: %s", e$message)))
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Check future::plan() hook in deferred_pkg_hooks()")

run_audit("14.3", "Renviron.site Variable Contract", {
  # These env vars MUST be set by /etc/R/Renviron.site for the system to work
  required_vars <- list(
    TMPDIR           = "/Rtmp",
    TMP              = "/Rtmp",
    TEMP             = "/Rtmp",
    R_TEMPDIR        = "/Rtmp",
    OPENBLAS_NUM_THREADS = "1",
    RETICULATE_PYTHON = NULL,  # just must exist
    FONTCONFIG_PATH  = "/etc/fonts",
    BSPM_SUDO        = "true",
    TF_CPP_MIN_LOG_LEVEL = "2",
    BIOME_TMP_DISK_GB = NULL   # just must exist
  )
  
  missing <- c(); wrong <- c()
  for (var_name in names(required_vars)) {
    val <- Sys.getenv(var_name, "")
    expected <- required_vars[[var_name]]
    if (nchar(val) == 0) {
      missing <- c(missing, var_name)
    } else if (!is.null(expected) && val != expected) {
      wrong <- c(wrong, sprintf("%s=%s (expected %s)", var_name, val, expected))
    }
  }
  
  if (length(missing) > 0) stop(sprintf("Missing env vars: %s", paste(missing, collapse=", ")))
  if (length(wrong) > 0) warning(paste(wrong, collapse="; "))
  sprintf("OK (%d vars verified)", length(required_vars))
}, fix_hint = "Redeploy Renviron.site via 50_setup_nodes.sh")

run_audit("14.4", "Arrow Thread Capping", {
  if (!requireNamespace("arrow", quietly = TRUE)) return("Skipped (arrow not installed)")
  tryCatch({
    cpu_threads <- arrow::cpu_count()
    io_threads  <- arrow::io_thread_count()
    max_allowed <- conf$max_threads
    
    if (cpu_threads > max_allowed) stop(sprintf("Arrow CPU threads=%d exceeds max=%d", cpu_threads, max_allowed))
    if (io_threads > max_allowed) stop(sprintf("Arrow IO threads=%d exceeds max=%d", io_threads, max_allowed))
    
    sprintf("OK (CPU=%d, IO=%d, max=%d)", cpu_threads, io_threads, max_allowed)
  }, error = function(e) stop(sprintf("Arrow thread check failed: %s", e$message)))
}, fix_hint = "Check arrow hook in deferred_pkg_hooks() or reload Rprofile")

