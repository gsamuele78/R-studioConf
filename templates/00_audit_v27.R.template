run_audit("14.8", "data.table fread SmartIO Hook", {
  # SmartIO overrides read.csv and fread — test that originals are preserved
  if (!requireNamespace("data.table", quietly = TRUE)) return("Skipped (data.table not installed)")
  
  # Test fread functional correctness with a tiny temp file
  tf <- tempfile(fileext = ".csv")
  on.exit(unlink(tf), add = TRUE)
  writeLines(c("x,y", "1,2", "3,4"), tf)
  
  tryCatch({
    # fread should work (even if wrapped by SmartIO)
    dt <- data.table::fread(tf)
    if (!is.data.frame(dt) || nrow(dt) != 2) stop("fread returned wrong dimensions")
    if (!all(c("x", "y") %in% names(dt))) stop("fread lost column names")
    
    # read.csv should also work
    df <- read.csv(tf)
    if (nrow(df) != 2) stop("read.csv returned wrong dimensions")
    
    # Check original preserved (critical: prevents infinite recursion)
    orig_csv <- tryCatch(get("original_read_csv", envir = .biome_env), error = function(e) NULL)
    if (is.null(orig_csv)) warning("original_read_csv not preserved — recursion risk if SmartIO active")
    
    sprintf("OK (fread=%dx%d, read.csv=%dx%d, original=%s)",
            nrow(dt), ncol(dt), nrow(df), ncol(df),
            if (!is.null(orig_csv)) "preserved" else "MISSING")
  }, error = function(e) stop(sprintf("SmartIO test failed: %s", e$message)))
}, timeout = 10,
   fix_hint = "Check SmartIO section in Rprofile — original_read_csv must be saved before override")

run_audit("14.9", "rJava Heap Scaling", {
  if (!requireNamespace("rJava", quietly = TRUE)) return("Skipped (rJava not installed)")
  
  # Check java.parameters option
  java_params <- getOption("java.parameters", "")
  if (nchar(java_params) == 0 || !grepl("-Xmx", java_params)) {
    # rJava hook fires on load — check if hook registered
    hook_done <- tryCatch(.biome_env$shared_env$.rjava_hook_done, error = function(e) FALSE)
    if (!isTRUE(hook_done)) {
      warning("rJava heap not configured — Java defaults to 256MB (climate4R OOM risk)")
    }
  }
  
  # Parse heap size
  heap_match <- regmatches(java_params, regexpr("-Xmx([0-9]+)g", java_params))
  if (length(heap_match) > 0) {
    heap_gb <- as.integer(sub("-Xmx([0-9]+)g", "\\1", heap_match))
    quota <- tryCatch(.biome_env$shared_env$last_quota, error = function(e) 0)
    expected_heap <- max(2L, as.integer(floor(quota * 0.25)))
    if (heap_gb < 2) warning(sprintf("Java heap only %dGB — too low for climate4R", heap_gb))
    sprintf("OK (heap=%dGB, quota=%dGB, expected~%dGB)", heap_gb, quota, expected_heap)
  } else {
    sprintf("Pending (java.parameters='%s')", java_params)
  }
}, fix_hint = "Load library(rJava) to trigger heap hook, or check rJava hook in Rprofile")

