# Self-heal: ensure the system log is writable
SYS_LOG <- "%%LOG_FILE%%"
tryCatch({
  if (file.exists(SYS_LOG) && file.access(SYS_LOG, 2) != 0) {
    if (Sys.info()[["user"]] == "root") {
