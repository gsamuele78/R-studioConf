# ── Pre-load key packages and activate memory guards ──
# The Rprofile's memory guards (solve, dist, outer, expand.grid) are installed
# by deferred_pkg_init(), which normally fires via an R task callback.
# But task callbacks don't fire during source() — they only fire between
# top-level REPL expressions. So we MUST call deferred_pkg_init() directly.
.audit_pkgs <- list()
for (.pkg in c("geosphere", "ggplot2", "terra", "vegan", "fields",
               "ncdf4", "lme4", "tmap", "Matrix",
               "glmmTMB", "doParallel", "igraph", "caret",
               "nimble", "nimbleHMC")) {
  .audit_pkgs[[.pkg]] <- tryCatch({
    suppressMessages(library(.pkg, character.only = TRUE))
    TRUE
  }, error = function(e) FALSE)
}

# Force-trigger deferred_pkg_init() + deferred_pkg_hooks() to install all guards
# v9.7: deferred_pkg_init installs memory guards, deferred_pkg_hooks installs
# package-specific guards (geosphere distm, doParallel hook, terra routing, etc.)
tryCatch({
  if (exists(".biome_env", envir = .GlobalEnv)) {
    be <- get(".biome_env", envir = .GlobalEnv)
    if (is.function(be$deferred_pkg_init)) {
      be$deferred_pkg_init()
    }
    if (is.function(be$deferred_pkg_hooks)) {
      be$deferred_pkg_hooks()
    }
  }
}, error = function(e) NULL)

