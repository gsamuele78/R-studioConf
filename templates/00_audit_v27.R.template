run_audit("4.6", "Dynamic Smart Routing Active Test", {
  smart_routing_enabled <- tryCatch(ENABLE_SMART_ROUTING, error = function(e) TRUE)
  if (!smart_routing_enabled) return("Skipped (Feature disabled in Rprofile.site)")

  force_nfs <- Sys.getenv("BIOME_FORCE_NFS_TMP") == "true"
  df_line <- system("df /tmp | tail -1", intern = TRUE)
  pct <- as.numeric(sub("%", "", strsplit(trimws(df_line), "\\s+")[[1]][5]))
  redirect_pct <- tryCatch(TMP_REDIRECT_PCT, error = function(e) 75L)
  expected_base <- if (!force_nfs && pct < redirect_pct) "/tmp" else file.path(Sys.getenv("HOME"), ".r_tmp_fallback")
  
  status_msgs <- c()
  
  # v27: Check per-user biome_ directory structure
  user <- Sys.info()[["user"]]
  user_root <- file.path("/tmp", paste0("biome_", user))
  if (dir.exists(user_root)) {
    subdirs <- list.dirs(user_root, recursive = FALSE, full.names = FALSE)
    status_msgs <- c(status_msgs, sprintf("biome_%s: %s", user, paste(subdirs, collapse=",")))
  }
  
  if (isNamespaceLoaded("terra")) {
    td <- terra::terraOptions()$tempdir
    if (!grepl(paste0("biome_", user), td, fixed = TRUE)) warning(sprintf("terra tmp not under biome_%s: %s", user, td))
    status_msgs <- c(status_msgs, sprintf("terra: %s", basename(dirname(td))))
  }
  
  if (isNamespaceLoaded("raster")) {
    rd <- raster::tmpDir()
    if (!grepl(paste0("biome_", user), rd, fixed = TRUE)) warning(sprintf("raster tmp not under biome_%s: %s", user, rd))
    status_msgs <- c(status_msgs, sprintf("raster: %s", basename(dirname(rd))))
  }
  
  if (length(status_msgs) == 0) "Skipped (GIS packages not loaded)" else paste(status_msgs, collapse=", ")
}, fix_hint = "Ensure Rprofile v9.6 is deployed (check VERSION in Rprofile_site.R)")

run_audit("4.7", "NUMA Topology", {
  numa_raw <- tryCatch(system2("lscpu", stdout = TRUE, stderr = FALSE), error = function(e) "")
