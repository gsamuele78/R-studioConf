run_audit("14.6", "bspm Sudo Access", {
  # R users need passwordless sudo for apt-get via bspm
  sudoers_file <- "/etc/sudoers.d/99-bspm-domain-users"
  if (!file.exists(sudoers_file)) stop("bspm sudoers rule missing: 99-bspm-domain-users")
  
  # Verify bspm is installed and functional
  bspm_ok <- requireNamespace("bspm", quietly = TRUE)
  if (!bspm_ok) stop("bspm package not installed (users can't install R packages)")
  
  # Check file permissions (must be 0440)
  perms <- tryCatch(
    system(sprintf("stat -c '%%a' '%s'", sudoers_file), intern = TRUE),
    error = function(e) "unknown"
  )
  if (perms != "440") warning(sprintf("Sudoers perms=%s (expected 440)", perms))
  
  sprintf("OK (bspm installed, sudoers=%s, perms=%s)", basename(sudoers_file), perms)
}, fix_hint = "Redeploy bspm sudoers via 50_setup_nodes.sh Step 7")

run_audit("14.7", "Python Venv + Reticulate", {
  # RETICULATE_PYTHON must point to existing Python binary in venv
  py_path <- Sys.getenv("RETICULATE_PYTHON", "")
  if (nchar(py_path) == 0) stop("RETICULATE_PYTHON not set — reticulate will install miniconda")
  if (!file.exists(py_path)) stop(sprintf("RETICULATE_PYTHON=%s does not exist", py_path))
  
  # Check it's actually executable
  if (file.access(py_path, 1) != 0) stop(sprintf("Python not executable: %s", py_path))
  
  # Quick version check
  py_ver <- tryCatch(
    system2(py_path, args = "--version", stdout = TRUE, stderr = TRUE),
    error = function(e) "unknown"
