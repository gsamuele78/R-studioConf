run_audit("14.11", "Kernel Swappiness", {
  # vm.swappiness must be ≤10 for analytics workloads
  # High swappiness → Linux swaps active R sessions → 100x slowdown
  swappiness <- tryCatch(
    as.integer(readLines("/proc/sys/vm/swappiness", warn = FALSE)),
    error = function(e) NA_integer_
  )
  if (is.na(swappiness)) stop("Cannot read /proc/sys/vm/swappiness")
  if (swappiness > 10) warning(sprintf("vm.swappiness=%d (should be ≤10 for analytics)", swappiness))
  
  # Also check overcommit
  overcommit <- tryCatch(
    as.integer(readLines("/proc/sys/vm/overcommit_memory", warn = FALSE)),
    error = function(e) NA_integer_
  )
  
  sprintf("OK (swappiness=%d, overcommit=%s)", swappiness,
          if (is.na(overcommit)) "unknown" else as.character(overcommit))
}, fix_hint = "Run: sysctl vm.swappiness=5 (or redeploy via 50_setup_nodes.sh)")

