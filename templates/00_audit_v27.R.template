audit_cat("\n[4.0] SYSTEM HEALTH\n")

run_audit("4.1", "/tmp Usage (RAMDisk)", {
  df_line <- system("df -BG /tmp | tail -1", intern = TRUE)
  parts <- strsplit(trimws(df_line), "\\s+")[[1]]
  total_gb <- as.numeric(sub("G", "", parts[2]))
  free_gb <- as.numeric(sub("G", "", parts[4]))
  pct <- as.numeric(sub("%", "", parts[5]))
  
  # v27: Use v9.6 thresholds from .biome_env (they're local to Rprofile's local({}))
  warn_pct <- tryCatch(.biome_env$TMP_WARN_PCT, error = function(e) 60L)
  redirect_pct <- tryCatch(.biome_env$TMP_REDIRECT_PCT, error = function(e) 75L)
  
  if (pct >= 95) stop(sprintf("CRITICAL: /tmp at %d%%. System unstable.", pct))
  if (pct >= redirect_pct) warning(sprintf("NFS redirect active: %d%% (threshold: %d%%)", pct, redirect_pct))
  else if (pct >= warn_pct) warning(sprintf("Advisory: %d%% used (warn@%d%%, redirect@%d%%)", pct, warn_pct, redirect_pct))
  
  sprintf("OK (%d GB free of %d GB, %d%% | Warn@%d%% Redirect@%d%%)", free_gb, total_gb, pct, warn_pct, redirect_pct)
}, fix_hint = "Clean stale Rtmp* dirs in /tmp or rely on v9.6 auto-redirect")

