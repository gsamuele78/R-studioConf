# ==============================================================================
# v10.0 routed NIMBLE compile to $HOME (NFS) "for reboot safety".
# v11+ FIX: routes to /Rtmp local disk to avoid NFS dir-cache races during
# concurrent compileNimble() in parLapply workers (cause of unserialize() crashes).
# ==============================================================================
audit_cat("\n[12.0] NIMBLE COMPILATION TESTS (v11+ routing)\n")

run_audit("12.1", "NIMBLE Model Compilation (LOCAL /Rtmp routing)", {
  # v28: no bare return() — use if/else
  if (!.audit_pkgs[["nimble"]]) {
    "Skipped (nimble not installed)"
  } else {
    tryCatch({
      code <- nimble::nimbleCode({
        mu ~ dnorm(0, sd = 10)
        sigma ~ dunif(0, 100)
        for (i in 1:5) {
          y[i] ~ dnorm(mu, sd = sigma)
        }
      })
      set.seed(42)
      model <- nimble::nimbleModel(code,
        data = list(y = rnorm(5, 10, 2)),
        inits = list(mu = 0, sigma = 1),
        check = FALSE)
      initial_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
      t0 <- Sys.time()
      Cmodel <- nimble::compileNimble(model)
      dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
      post_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
      nimble_dir <- getOption("nimble.dirName", "")
      if (nchar(nimble_dir) == 0) {
        nimble_dir <- tryCatch(nimble::getNimbleDir(), error = function(e) "")
      }
      home <- Sys.getenv("HOME")
      if (nchar(nimble_dir) > 0) {
        if (grepl(paste0("^", home), nimble_dir)) {
          stop(sprintf("REGRESSION: NIMBLE dir on NFS (%s) — v11+ requires /Rtmp!", nimble_dir))
        }
        if (!grepl("^/Rtmp/", nimble_dir)) {
          warning(sprintf("NIMBLE dir not on /Rtmp: %s", nimble_dir))
        }
      }
      if (post_t != initial_t) warning(sprintf("Thread change: %d -> %d", initial_t, post_t))
      calc_ok <- tryCatch({ Cmodel$calculate(); TRUE }, error = function(e) FALSE)
      if (!calc_ok) warning("Compiled model calculate() failed")
      rm(model, Cmodel); gc(verbose = FALSE)
      sprintf("OK (compile=%.1fs, dir=%s, threads=%d)",
              dt, if (nchar(nimble_dir) > 0) basename(nimble_dir) else "unknown", post_t)
    }, error = function(e) stop(sprintf("NIMBLE compile failed: %s", e$message)))
  }
}, timeout = 120, use_fork = TRUE,
   fix_hint = "Deploy Rprofile v12.x (NIMBLE hook routes to /Rtmp, not NFS)")

