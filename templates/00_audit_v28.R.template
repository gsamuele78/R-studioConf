run_audit("13.5", "OpenMP runtime compile test", {
  tmp_c <- tempfile(fileext = ".c")
  tmp_bin <- tempfile()
  on.exit({ unlink(tmp_c); unlink(tmp_bin) }, add = TRUE)
  c_source <- '
#include <stdio.h>
#include <omp.h>
int main() {
  int total_threads = 0;
  #pragma omp parallel reduction(+:total_threads)
  { total_threads += 1; }
  printf("%d\\n", total_threads);
  return 0;
}
'
  writeLines(c_source, tmp_c)
  compile_result <- tryCatch(
    system2("gcc", args = c("-fopenmp", tmp_c, "-o", tmp_bin, "-lgomp"),
            stdout = TRUE, stderr = TRUE),
    error = function(e) "ERROR")
  if (!file.exists(tmp_bin)) {
    stop(sprintf("OpenMP compile failed: %s", paste(compile_result, collapse = " ")))
  }
  env_exec <- c("OMP_NUM_THREADS=4")
  run_out <- tryCatch(
    system2("env", args = c(env_exec, tmp_bin), stdout = TRUE, stderr = FALSE),
    error = function(e) "0")
  threads_seen <- suppressWarnings(as.integer(run_out[1]))
  if (is.na(threads_seen)) stop("OpenMP runtime test did not return an integer")
  if (threads_seen != 4L) {
    warning(sprintf("OMP_NUM_THREADS=4 but runtime used %d threads", threads_seen))
