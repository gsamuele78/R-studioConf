run_audit("14.3", "Renviron.site Variable Contract", {
  # Static contract: /etc/R/Renviron.site MUST set these vars.
  # OPENBLAS_NUM_THREADS=1 is the static fallback; Rprofile dynamically
  # raises thread caps per-session — runtime value may differ from 1.
  required_vars <- list(
    TMPDIR           = "/Rtmp",
    TMP              = "/Rtmp",
    TEMP             = "/Rtmp",
    R_TEMPDIR        = "/Rtmp",
    RETICULATE_PYTHON = NULL,
    FONTCONFIG_PATH  = "/etc/fonts",
    BSPM_SUDO        = "true",
    TF_CPP_MIN_LOG_LEVEL = "2",
    BIOME_TMP_DISK_GB = NULL
  )
  # Separate check: Renviron.site file must contain OPENBLAS_NUM_THREADS=1
  renviron_ok <- tryCatch({
    rlines <- readLines("/etc/R/Renviron.site", warn = FALSE)
    any(grepl("^OPENBLAS_NUM_THREADS=1$", rlines))
  }, error = function(e) FALSE)
  missing <- c(); wrong <- c()
  for (var_name in names(required_vars)) {
    val <- Sys.getenv(var_name, "")
    expected <- required_vars[[var_name]]
    if (nchar(val) == 0) missing <- c(missing, var_name)
    else if (!is.null(expected) && val != expected) {
      wrong <- c(wrong, sprintf("%s=%s (expected %s)", var_name, val, expected))
    }
  }
  if (!renviron_ok) {
    warning("OPENBLAS_NUM_THREADS=1 not found in /etc/R/Renviron.site")
  }
  if (length(missing) > 0) stop(sprintf("Missing env vars: %s", paste(missing, collapse=", ")))
  if (length(wrong) > 0) warning(paste(wrong, collapse="; "))
  # Runtime OPENBLAS_NUM_THREADS may be >1 (dynamic cap by Rprofile) — not an error
  rt_blas <- Sys.getenv("OPENBLAS_NUM_THREADS", "1")
  max_t <- tryCatch(.biome_env$shared_env$last_threads, error = function(e) 16)
  blas_note <- if (rt_blas != "1") {
    sprintf(" (runtime=%s, cap=%d — dynamic, OK)", rt_blas, max_t)
  } else ""
  sprintf("OK (%d vars verified, Renviron OPENBLAS_NUM_THREADS=1%s)",
          length(required_vars), blas_note)
}, fix_hint = "Redeploy Renviron.site via 50_setup_nodes.sh (Rprofile v12.x)")

