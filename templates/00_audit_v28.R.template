run_audit("12.4", "NIMBLE per-worker compile subdir (v12.x fragment 35)", {
  if (!.audit_pkgs[["nimble"]]) "Skipped (nimble not installed)"
  else {
    usr <- tryCatch(.biome_env$USER_TMP_ROOT, error = function(e) NULL)
    if (is.null(usr)) stop("USER_TMP_ROOT missing — Rprofile < v11+")
    # v12.x fragment 35_compile_routing.R: compile dirs are run-specific
    #   /Rtmp/biome_<user>/nimble/<BIOME_RUN_ID>/{master|worker_<pid>}/
    # BIOME_NIMBLE_DIR was removed in v11.2 (NIMBLE never read it).
