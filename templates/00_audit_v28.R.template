run_audit("15.1", "Renviron.site R_LIBS_USER set", {
  # v12.4+: R_LIBS_USER is emitted by 50_setup_nodes.sh only when
  # ENABLE_R_LIBS_LOCAL=true.  If local R libs are disabled, absence
  # of R_LIBS_USER is valid legacy NFS-only behavior.
  local_libs_root <- "/var/lib/biome-Rlibs"
  local_libs_enabled <- dir.exists(local_libs_root)
  rs_env <- tryCatch({
    lines <- readLines("/etc/R/Renviron.site", warn = FALSE)
    libs_line <- grep("^R_LIBS_USER=", lines, value = TRUE)
    if (length(libs_line) == 0) {
      if (local_libs_enabled) {
        stop(sprintf("R_LIBS_USER not found in Renviron.site but %s exists — redeploy Renviron.site",
                     local_libs_root))
      } else {
        # Local libs not deployed — legacy NFS-only mode is valid
        sprintf("OK (R_LIBS_USER not set — local R libs disabled, NFS-only legacy mode)")
      }
    } else if (grepl("/var/lib/biome-Rlibs", libs_line[1])) {
      sprintf("OK (%s)", sub("^R_LIBS_USER=", "", libs_line[1]))
    } else {
      warning(sprintf("R_LIBS_USER=%s — expected /var/lib/biome-Rlibs/...",
                      sub("^R_LIBS_USER=", "", libs_line[1])))
    }
  }, error = function(e) stop(sprintf("Cannot validate Renviron.site: %s", e$message)))
  rs_env
}, fix_hint = "Redeploy Renviron.site via 50_setup_nodes.sh (v12.4+)")

