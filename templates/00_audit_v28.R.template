# v28 [NEW v12.x]: mclapply Fork Guard Functional Test
run_audit("9.6", "mclapply Fork Guard (v12.4+ fragment 52)", {
  if (!requireNamespace("terra", quietly = TRUE)) "Skipped (terra not installed)"  # no bare return()
  else {
    res <- tryCatch({
      suppressMessages(library(terra))
      suppressMessages(library(data.table))
      # When fork-unsafe packages loaded, mclapply should reroute to PSOCK
      # via fragment 52_mclapply_guard. v12.7+ adds PKG-SYNC, v12.9.3+ adds GLOBAL-SYNC.
      omp_before <- as.integer(Sys.getenv("OMP_NUM_THREADS", "-1"))
      result <- parallel::mclapply(1:2, function(i) {
        list(pid = Sys.getpid(),
             omp = as.integer(Sys.getenv("OMP_NUM_THREADS", "-1")))
      }, mc.cores = 2)
      pids <- vapply(result, function(x) x$pid, integer(1))
      unique_pids <- unique(pids)
      if (length(unique_pids) == 1 && unique_pids[1] == Sys.getpid()) {
        "OK (fork used — terra not loaded as fork-unsafe in this session)"
      } else if (length(unique_pids) > 1) {
        sprintf("OK (PSOCK reroute active, %d unique worker PIDs)", length(unique_pids))
      } else {
        sprintf("OK (reroute=%s, PIDs=%s)",
                if (Sys.getenv("BIOME_DISABLE_FORK_GUARD", "") != "") "disabled" else "active",
                paste(pids, collapse=","))
      }
    }, error = function(e) {
      if (grepl("could not find function", e$message)) {
        warning(sprintf("Fork Guard PKG-SYNC may need v12.7+: %s", e$message))
      }
      sprintf("WARN (%s)", e$message)
    })
    res
  }
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Check fragment 52_mclapply_guard — requires Rprofile v12.4+")

