run_audit("17.1", "cgroup v2 is active", {
  fs_type <- tryCatch(
    system2("stat", args = c("-fc", "%T", "/sys/fs/cgroup/"), stdout = TRUE, stderr = FALSE),
    error = function(e) "unknown")
  if (fs_type != "cgroup2fs") {
    stop(sprintf("Expected cgroup2fs, got: %s — kernel cmdline may force cgroup v1", fs_type))
  }
  "cgroup2fs (v2 unified hierarchy)"
}, fix_hint = "Ubuntu 24.04 should have v2 by default. Check /proc/cmdline for systemd.unified_cgroup_hierarchy=0")

run_audit("17.2", "user-.slice template deployed", {
  cfg <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
  if (!file.exists(cfg)) stop(sprintf("Missing: %s", cfg))
  content <- tryCatch(readLines(cfg, warn = FALSE), error = function(e) character(0))
  required <- c("MemoryHigh", "MemoryMax", "CPUWeight", "TasksMax")
  missing <- required[!sapply(required, function(k) any(grepl(paste0("^", k, "="), content)))]
  if (length(missing) > 0) {
    stop(sprintf("Config exists but missing keys: %s", paste(missing, collapse = ", ")))
  }
  sprintf("OK (%s)", basename(cfg))
}, fix_hint = "Run 50_setup_nodes.sh option C")

run_audit("17.3", "user slice MemoryHigh in effect", {
  # First validate the drop-in template exists (authoritative source).
  # Runtime slice may be missing if user session predates deployment.
  dropin <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
  if (!file.exists(dropin)) {
    stop(sprintf("Drop-in missing: %s — run 50_setup_nodes.sh Step 11A first", dropin))
  }
  uid <- tryCatch(as.integer(system2("id", args = "-u", stdout = TRUE)), error = function(e) -1L)
  if (uid < 1000) "Skipped (not a regular user — likely running as root)"
  else {
    slice_path <- sprintf("/sys/fs/cgroup/user.slice/user-%d.slice/memory.high", uid)
    if (!file.exists(slice_path)) {
      # Drop-in deployed but runtime slice not materialized for this session
      warning(sprintf("Runtime slice not materialized: %s — user session may predate cgroup deployment. Log out and back in, or run: systemctl daemon-reload && systemctl restart user-%d.slice",
                      slice_path, uid))
      sprintf("WARN (drop-in deployed, runtime slice pending — relogin required)")
    } else {
      raw <- tryCatch(readLines(slice_path, n = 1, warn = FALSE), error = function(e) "")
      if (raw == "max" || raw == "") stop("MemoryHigh not set on this user's slice")
      gb <- as.numeric(raw) / (1024^3)
      if (gb < 16) warning(sprintf("MemoryHigh=%.0fGB is unusually low", gb))
      if (gb > 400) warning(sprintf("MemoryHigh=%.0fGB is unusually high", gb))
      sprintf("OK (throttle at %.0f GB)", gb)
    }
  }
}, fix_hint = "Run 50_setup_nodes.sh Step 11A, then log out and back in")

run_audit("17.4", "user slice MemoryMax (catastrophic ceiling)", {
  dropin <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
  if (!file.exists(dropin)) {
    stop(sprintf("Drop-in missing: %s — run 50_setup_nodes.sh Step 11A first", dropin))
  }
  uid <- tryCatch(as.integer(system2("id", args = "-u", stdout = TRUE)), error = function(e) -1L)
  if (uid < 1000) "Skipped (not a regular user)"
  else {
    slice_path <- sprintf("/sys/fs/cgroup/user.slice/user-%d.slice/memory.max", uid)
    if (!file.exists(slice_path)) {
      warning(sprintf("Runtime slice not materialized: %s — relogin required", slice_path))
      "WARN (drop-in deployed, runtime slice pending — relogin required)"
    } else {
      raw <- tryCatch(readLines(slice_path, n = 1, warn = FALSE), error = function(e) "")
      if (raw == "max") {
        warning("MemoryMax not set — runaway process could OOM the entire host")
      } else {
        gb <- as.numeric(raw) / (1024^3)
        sprintf("OK (kill ceiling at %.0f GB, applies to this slice only)", gb)
      }
    }
  }
}, fix_hint = "Set USER_SLICE_MEMORY_MAX in setup_nodes.vars.conf, then relogin")

run_audit("17.5", "user slice CPU is weight-only (no hard quota)", {
  dropin <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
  if (!file.exists(dropin)) {
    stop(sprintf("Drop-in missing: %s — run 50_setup_nodes.sh Step 11A first", dropin))
  }
  # Validate drop-in has CPUWeight (no CPUQuota) — authoritative contract
  dcontent <- tryCatch(readLines(dropin, warn = FALSE), error = function(e) character(0))
  has_cpuweight <- any(grepl("^CPUWeight=", dcontent))
  has_cpuquota  <- any(grepl("^CPUQuota=", dcontent))
  if (!has_cpuweight) stop("CPUWeight not set in drop-in")
  if (has_cpuquota) warning("CPUQuota found in drop-in — removes dynamic fair-share when server is empty")
  uid <- tryCatch(as.integer(system2("id", args = "-u", stdout = TRUE)), error = function(e) -1L)
  if (uid < 1000) {
    sprintf("OK (drop-in valid, CPUWeight present, no CPUQuota — skip runtime check for uid<1000)")
  } else {
    cpu_weight <- sprintf("/sys/fs/cgroup/user.slice/user-%d.slice/cpu.weight", uid)
    if (!file.exists(cpu_weight)) {
      warning(sprintf("Runtime slice not materialized: %s — relogin required", cpu_weight))
      "WARN (drop-in deployed, runtime slice pending — relogin required)"
    } else {
      raw_weight <- tryCatch(readLines(cpu_weight, n = 1, warn = FALSE), error = function(e) "")
      weight <- suppressWarnings(as.integer(raw_weight))
      if (is.na(weight) || weight <= 0) stop("CPUWeight not set on runtime slice")
      cpu_max <- sprintf("/sys/fs/cgroup/user.slice/user-%d.slice/cpu.max", uid)
      raw_max <- tryCatch(readLines(cpu_max, n = 1, warn = FALSE), error = function(e) "")
      parts <- strsplit(raw_max, " ")[[1]]
      has_quota <- length(parts) >= 1 && parts[1] != "max"
      if (has_quota) {
        pct <- as.numeric(parts[1]) / as.numeric(parts[2]) * 100
        warning(sprintf("CPUQuota set at %.0f%% — this prevents dynamic fair-share when server is empty", pct))
      }
      sprintf("OK (weight=%d, no hard quota → dynamic fair-share active)", weight)
    }
  }
}, fix_hint = "Remove CPUQuota line from /etc/systemd/system/user-.slice.d/50-biome-limits.conf")

run_audit("17.6", "system.slice has memory protection floor", {
  cfg <- "/etc/systemd/system/system.slice.d/50-biome-reserve.conf"
  if (!file.exists(cfg)) {
    warning(sprintf("Missing: %s — system services unprotected against user pressure", cfg))
    "Not configured"
  } else {
    min_path <- "/sys/fs/cgroup/system.slice/memory.min"
    raw_min <- tryCatch(readLines(min_path, n = 1, warn = FALSE), error = function(e) "0")
    gb <- as.numeric(raw_min) / (1024^3)
    if (gb < 4) warning(sprintf("MemoryMin=%.1fGB is too low", gb))
    sprintf("OK (%.0f GB protected for nginx/sssd/telemetry)", gb)
  }
}, fix_hint = "Run 50_setup_nodes.sh option C")

run_audit("17.6b", "rstudio-server stack limit (geospatial guard)", {
  cfg <- "/etc/systemd/system/rstudio-server.service.d/50-biome-stack.conf"
  if (!file.exists(cfg)) {
    warning(sprintf("Missing: %s — GEOS C stack errors likely with complex polygons", cfg))
    "Not configured"
  } else {
    content <- tryCatch(readLines(cfg, warn = FALSE), error = function(e) character(0))
    stack_line <- grep("^LimitSTACK=", content, value = TRUE)
    if (length(stack_line) == 0) {
      warning("LimitSTACK not found in drop-in")
      "No LimitSTACK directive"
    } else {
      stack_val <- as.integer(sub("LimitSTACK=", "", stack_line[1]))
      if (is.na(stack_val)) "Invalid LimitSTACK value"
      else {
        expected <- 33554432
        if (stack_val != expected) {
          warning(sprintf("LimitSTACK=%d ≠ expected %d (32 MB)", stack_val, expected))
        }
        sprintf("OK (LimitSTACK=%d bytes = %d MB)", stack_val, stack_val / (1024^2))
      }
    }
  }
}, fix_hint = "Run scripts/50_setup_nodes.sh Step 11A, then systemctl daemon-reload && systemctl restart rstudio-server")

run_audit("17.6c", "user-.slice does NOT contain stale LimitSTACK", {
  cfg <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
  if (!file.exists(cfg)) "Skipped (user-.slice not deployed)"
  else {
    content <- tryCatch(readLines(cfg, warn = FALSE), error = function(e) character(0))
    if (any(grepl("^LimitSTACK=", content))) {
      warning("user-.slice contains LimitSTACK — ignored by systemd (slices manage cgroups, not RLIMITs). Re-run Step 11A for updated config.")
      "Stale LimitSTACK present"
    } else {
      "OK (no LimitSTACK in slice — RLIMIT belongs on rstudio-server.service)"
    }
  }
}, fix_hint = "Re-run scripts/50_setup_nodes.sh Step 11A.")

run_audit("17.7", "Ollama CPU yields to user compute", {
  if (!requireNamespace("base", quietly = TRUE)) "Skipped"
  else {
    ollama_active <- tryCatch(
      system2("systemctl", args = c("is-active", "--quiet", "ollama"), stdout = FALSE, stderr = FALSE) == 0,
      error = function(e) FALSE)
    if (!ollama_active) "Skipped (ollama not running)"
    else {
      cfg <- "/etc/systemd/system/ollama.service.d/50-biome-cpu.conf"
      if (!file.exists(cfg)) "Not configured (ollama uses default CPU weight)"
      else {
        content <- tryCatch(readLines(cfg, warn = FALSE), error = function(e) character(0))
        weight_line <- grep("^CPUWeight=", content, value = TRUE)
        if (length(weight_line) == 0) "CPUWeight not set in drop-in"
        else {
          weight <- as.integer(sub("CPUWeight=", "", weight_line[1]))
          if (is.na(weight)) "Invalid CPUWeight value"
          else {
            if (weight >= 100) {
              warning(sprintf("Ollama CPUWeight=%d competes equally with users — should be lower", weight))
            }
            sprintf("OK (CPUWeight=%d, yields to user sessions)", weight)
          }
        }
      }
    }
  }
}, fix_hint = "Set OLLAMA_CPU_WEIGHT=80 in setup_nodes.vars.conf")


