run_audit("1.7", "Rprofile Version >= 11.0 (baseline)", {
  v <- tryCatch(.biome_env$VERSION, error = function(e) "unknown")
  if (v == "unknown") stop("Cannot determine Rprofile version")
  vnum <- suppressWarnings(as.numeric(gsub("[^0-9.]", "", v)))
  if (is.na(vnum)) stop(sprintf("Cannot parse version: %s", v))
  if (vnum < 9.6)   stop(sprintf("CRITICAL: v%s is pre-v9.6 — missing memory sentinels", v))
  if (vnum < 11.0)  warning(sprintf("v%s is pre-v11.0 — missing local-disk NIMBLE routing + return() fix", v))
  if (vnum >= 12.0) sprintf("v%s (v12.x current)", v)
  else sprintf("v%s (v11 baseline)", v)
}, fix_hint = "Deploy Rprofile v12.x via 50_setup_nodes.sh")

# v28: BIOME_USER_TMP must be set by Rprofile Section -1.8
run_audit("1.8", "BIOME_USER_TMP env var (v11+)", {
  but <- Sys.getenv("BIOME_USER_TMP", "")
  if (nchar(but) == 0) stop("BIOME_USER_TMP not set (Rprofile < v11.0 or Section -1.8 failed)")
  if (!grepl("^/Rtmp/biome_", but)) {
    warning(sprintf("BIOME_USER_TMP=%s — unusual path (expected /Rtmp/biome_<user>)", but))
  }
  expected <- file.path("/Rtmp", paste0("biome_", Sys.info()[["user"]]))
  if (but != expected) {
    warning(sprintf("BIOME_USER_TMP=%s (expected %s)", but, expected))
  }
  if (!dir.exists(but)) stop(sprintf("BIOME_USER_TMP dir does not exist: %s", but))
  sprintf("OK (%s)", but)
}, fix_hint = "Deploy Rprofile v12.x — Section -1.8 creates the user tmp root")

