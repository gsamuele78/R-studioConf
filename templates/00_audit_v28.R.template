run_audit("14.16", "Worker env propagation (v12.x [N3])", {
  bmc <- tryCatch(get("biome_make_cluster", envir = as.environment("tools:biome_calc")),
                  error = function(e) NULL)
  if (is.null(bmc)) stop("biome_make_cluster not found")
  tryCatch({
    cl <- bmc(workers = 1, worker_threads = 1L)
    on.exit(try(parallel::stopCluster(cl), silent = TRUE), add = TRUE)
    # v12.x fragment 30_psock_factory env_vec: BIOME_NIMBLE_DIR and BIOME_TMB_DIR
    # were removed in v11.2 (phantom env vars).  Real vars propagated:
    #   BIOME_WORKER_MODE, BIOME_USER_TMP, BIOME_RUN_ID, BIOME_RUN_TIMESTAMP,
    #   BIOME_STAN_DIR, BIOME_RCPP_CACHE, OMP/OPENBLAS/MKL_NUM_THREADS,
    #   R_TEMPDIR, GDAL_NUM_THREADS, CPL_TMPDIR, GDAL_PAM_PROXY_DIR,
    #   CUDA_VISIBLE_DEVICES, MALLOC_ARENA_MAX
    worker_env <- parallel::clusterCall(cl, function() {
      list(
        BIOME_WORKER_MODE = Sys.getenv("BIOME_WORKER_MODE"),
        BIOME_USER_TMP    = Sys.getenv("BIOME_USER_TMP"),
        BIOME_RUN_ID      = Sys.getenv("BIOME_RUN_ID"),
        BIOME_STAN_DIR    = Sys.getenv("BIOME_STAN_DIR"),
        BIOME_RCPP_CACHE  = Sys.getenv("BIOME_RCPP_CACHE"),
        TMPDIR            = Sys.getenv("TMPDIR"),
        OMP_NUM_THREADS   = Sys.getenv("OMP_NUM_THREADS"),
        OPENBLAS_NUM_THREADS = Sys.getenv("OPENBLAS_NUM_THREADS"),
        MALLOC_ARENA_MAX  = Sys.getenv("MALLOC_ARENA_MAX")
      )
    })[[1]]
    parallel::stopCluster(cl)
    # Required vars for v12.x workers
    required_worker_vars <- c("BIOME_WORKER_MODE", "BIOME_USER_TMP")
    missing_vars <- required_worker_vars[!nchar(vapply(worker_env[required_worker_vars],
                                       function(x) x, character(1))) > 0]
    if (length(missing_vars) > 0) {
      warning(sprintf("Worker missing env vars: %s", paste(missing_vars, collapse=", ")))
    }
    # /Rtmp routing check for dirs that MUST be on local disk
    for (k in c("BIOME_USER_TMP", "BIOME_STAN_DIR", "BIOME_RCPP_CACHE")) {
      if (nchar(worker_env[[k]]) > 0 && !grepl("^/Rtmp/", worker_env[[k]])) {
        warning(sprintf("%s=%s — not under /Rtmp", k, worker_env[[k]]))
      }
    }
    mma <- worker_env$MALLOC_ARENA_MAX
    mma_note <- if (nchar(mma) > 0)
      sprintf(", MALLOC_ARENA_MAX=%s", mma) else ""
    sprintf("OK (%d vars, WORKER_MODE=%s, RUN_ID=%s%s)",
            length(worker_env), worker_env$BIOME_WORKER_MODE,
            if (nchar(worker_env$BIOME_RUN_ID) > 0) substr(worker_env$BIOME_RUN_ID, 1, 20) else "MISSING",
            mma_note)
  }, error = function(e) stop(sprintf("Worker env test failed: %s", e$message)))
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Deploy Rprofile v12.x [N3] — check env_vec in .biome_make_cluster_impl (fragment 30)")

