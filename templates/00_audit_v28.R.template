run_audit("10.7", "Sparse Matrix Cholesky (Matrix pkg)", {
  # v28: no bare return() — use if/else
  if (!.audit_pkgs[["Matrix"]]) {
    "Skipped (Matrix not installed)"
  } else {
    tryCatch({
      set.seed(2025)
      N <- 2000
      n_edges <- N * 5
      i_idx <- sample(N, n_edges, replace = TRUE)
      j_idx <- sample(N, n_edges, replace = TRUE)
      M <- Matrix::sparseMatrix(i = i_idx, j = j_idx, x = runif(n_edges, 0.1, 1),
                                 dims = c(N, N))
      M <- M + Matrix::t(M) + Matrix::Diagonal(N, 10)
      t0 <- Sys.time()
      ch <- Matrix::Cholesky(M, perm = TRUE, LDL = FALSE)
      dt_chol <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
      b <- Matrix::Matrix(rnorm(N), ncol = 1, sparse = TRUE)
      t0 <- Sys.time()
      x_sol <- Matrix::solve(ch, b)
      dt_solve <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
      resid <- max(abs(as.numeric(as.matrix(M %*% x_sol - b))))
      if (resid > 1e-6) stop(sprintf("Sparse solve residual: %.2e", resid))
      sparsity <- round(1 - Matrix::nnzero(M) / (N * N), 4) * 100
      rm(M, ch, b, x_sol); gc(verbose = FALSE)
      sprintf("OK (N=%d, %.1f%% sparse, chol=%.3fs, solve=%.3fs)",
              N, sparsity, dt_chol, dt_solve)
    }, error = function(e) stop(sprintf("Sparse solve failed: %s", e$message)))
  }
}, timeout = 30, use_fork = TRUE,
   fix_hint = "Install Matrix package")

