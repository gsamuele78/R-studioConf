      ns <- asNamespace("nimble")
      fn <- get("compileNimble", envir = ns, inherits = FALSE)
      isTRUE(attr(fn, "biome_wrapper"))
    }, error = function(e) FALSE)
    if (!wrapper_ok) warning("safe_compileNimble wrapper not installed — fragment 35 may not have run")
    # Check no stale NFS path
    old_nfs_path <- file.path(Sys.getenv("HOME"), ".nimble_compile")
    if (dir.exists(old_nfs_path)) {
      warning(sprintf("Stale NFS compile dir detected: %s (should be under /Rtmp)", old_nfs_path))
    }
    if (dir.exists(compile_dir)) {
      sprintf("OK (compile_dir=%s, wrapper=%s)", compile_dir, if (wrapper_ok) "active" else "missing")
    } else {
      sprintf("OK (compile_dir=%s pending — created on first compileNimble, wrapper=%s)",
