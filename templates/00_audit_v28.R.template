run_audit("4.1", "/Rtmp Disk (Local)", {
  df_line <- system("df -BG /Rtmp | tail -1", intern = TRUE)
  parts <- strsplit(trimws(df_line), "\\s+")[[1]]
  total_gb <- as.numeric(sub("G", "", parts[2]))
  free_gb <- as.numeric(sub("G", "", parts[4]))
  pct <- as.numeric(sub("%", "", parts[5]))
  warn_pct <- tryCatch(.biome_env$TMP_WARN_PCT, error = function(e) 80L)
  fs_type <- system("df -T /Rtmp | tail -1 | awk '{print $2}'", intern = TRUE)
  if (grepl("tmpfs", fs_type)) stop("CRITICAL: /Rtmp is still tmpfs — must be local disk")
  if (pct >= 95) stop(sprintf("CRITICAL: /Rtmp at %d%%. Disk full.", pct))
  if (pct >= warn_pct) warning(sprintf("Advisory: %d%% used (warn@%d%%)", pct, warn_pct))
  if (total_gb < 100) warning(sprintf("/Rtmp only %dGB — recommended 400GB", total_gb))
  sprintf("OK (%d GB free of %d GB, %d%% | %s | Warn@%d%%)", free_gb, total_gb, pct, fs_type, warn_pct)
}, fix_hint = "Mount dedicated 400GB disk at /Rtmp. Run 50_setup_nodes.sh.")

