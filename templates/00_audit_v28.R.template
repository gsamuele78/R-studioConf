run_audit("14.9", "rJava Heap Scaling (v12.x dynamic hook)", {
  # v12.x fragment 50_pkg_hooks.R: rJava heap is configured lazily when
  # rJava namespace is loaded.  The hook sets options(java.parameters).
  # If rJava is not loaded, this is not a failure — the hook will fire on
  # first library(rJava).
  if (!requireNamespace("rJava", quietly = TRUE)) {
    "Skipped (rJava not installed — heap hook will fire on first library(rJava))"
  } else {
    java_params <- getOption("java.parameters", "")
    hook_done <- tryCatch(.biome_env$shared_env$.rjava_hook_done, error = function(e) FALSE)
    if (nchar(java_params) == 0 || !grepl("-Xmx", java_params)) {
      if (!isTRUE(hook_done)) {
        # rJava namespace loaded but hook didn't fire — may be pre-v12.x profile
        warning("rJava heap not configured — Java defaults to 256MB (climate4R OOM risk). Load library(rJava) to trigger v12.x hook.")
      } else {
        warning("rJava hook fired but java.parameters empty — may need session restart")
      }
      "WARN (heap not configured)"
    } else {
      heap_match <- regmatches(java_params, regexpr("-Xmx([0-9]+)g", java_params))
      if (length(heap_match) > 0) {
        heap_gb <- as.integer(sub("-Xmx([0-9]+)g", "\\1", heap_match))
        quota <- tryCatch(.biome_env$shared_env$last_quota, error = function(e) 0)
        expected_heap <- max(2L, min(16L, as.integer(floor(quota * 0.25))))
        if (heap_gb > 16L) warning(sprintf("Java heap %dGB > v11.0 cap of 16GB (GC pauses risk)", heap_gb))
        if (heap_gb < 2) warning(sprintf("Java heap only %dGB — too low for climate4R", heap_gb))
        sprintf("OK (heap=%dGB, quota=%dGB, expected~%dGB, max_cap=16GB)",
                heap_gb, quota, expected_heap)
      } else {
        sprintf("OK (java.parameters='%s')", java_params)
      }
    }
  }
}, fix_hint = "Load library(rJava) to trigger heap hook (v12.x fragment 50_pkg_hooks [N11])")

run_audit("14.10", "Orphan Cleanup Service", {
  # v12.x: orphan cleanup is deployed via cron, not systemd timer.
  # 50_setup_nodes.sh writes /etc/cron.d/r_orphan_cleanup and deploys
  # scripts to ${BIOME_CONF}/script/ (default: /opt/biome/script/).
  cron_file <- "/etc/cron.d/r_orphan_cleanup"
  biome_conf <- Sys.getenv("BIOME_CONF", "/opt/biome")
  script_dir <- file.path(biome_conf, "script")
  scripts_expected <- c("cleanup_r_orphans.sh", "notify_r_orphans.sh",
                        "r_orphan_report.sh")
  issues <- c()
  if (!file.exists(cron_file)) {
    issues <- c(issues, sprintf("%s missing", cron_file))
  } else {
    cron_content <- tryCatch(readLines(cron_file, warn = FALSE), error = function(e) character(0))
    if (!any(grepl("cleanup_r_orphans\\.sh", cron_content))) {
      issues <- c(issues, "cleanup_r_orphans.sh not referenced in cron")
    }
  }
  for (s in scripts_expected) {
    sp <- file.path(script_dir, s)
    if (!file.exists(sp)) issues <- c(issues, sprintf("%s not deployed", s))
  }
  if (length(issues) > 0) {
    warning(paste(issues, collapse = "; "))
  } else {
    sprintf("OK (cron=%s, scripts=%s)", basename(cron_file), script_dir)
  }
}, fix_hint = "Run 50_setup_nodes.sh Step 11b (orphan cleanup deploys via cron)")

