run_audit("9.1", "solve() Safety Test (6000x6000)", {
  blas_serial <- isTRUE(tryCatch(.biome_env$blas_is_serial, error = function(e) FALSE))
  curr_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))

  if (blas_serial) {
    N <- 6000
    A <- matrix(runif(N * N), N, N)
    diag(A) <- diag(A) + N
    t0 <- Sys.time()
    B <- solve(A)
    dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
    rm(A, B); gc(verbose = FALSE)
    sprintf("OK (%.1fs, serial BLAS — no thread reduction needed, no SIGSEGV)", dt)
  } else {
    if (curr_t <= 2) sprintf("Skipped (threads already at %d)", curr_t)
    else {
      N <- 6000
      A <- matrix(runif(N * N), N, N)
      diag(A) <- diag(A) + N
      t0 <- Sys.time()
      B <- solve(A)
      dt <- as.numeric(difftime(Sys.time(), t0, units = "secs"))
      post_t <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
      rm(A, B); gc(verbose = FALSE)
      if (post_t != curr_t) stop(sprintf("Threads not restored: was %d, now %d", curr_t, post_t))
      sprintf("OK (%.1fs, threads %d->reduced->%d restored)", dt, curr_t, post_t)
    }
  }
}, timeout = 120, use_fork = TRUE,
   fix_hint = "Deploy Rprofile v12.x with serial-aware solve() guard")

