# ==============================================================================
# %%BIOME_HOST%% SYSTEM PROFILE v%%RPROFILE_VERSION%% — LOCAL-DISK ARCHITECTURE
# ==============================================================================
# VM:      QEMU on Proxmox 9.x (Ceph), x86-64-v4 CPU, %%VM_VCORES%% vCores, ~%%VM_RAM_GB%%GB RAM
# System:  Ubuntu 24.04, R 4.5.x, bspm enabled
# BLAS:    openblas-serial (safe with rsession pthreads — rstudio/rstudio#7031)
# OpenMP:  libgomp (capped by OMP_NUM_THREADS, coordinated per-user)
# Contact: %%BIOME_CONTACT%%
#
# v11.4 CHANGES (from v11.3) — "Lexical Scope Restoration":
#   - FIXED:   .biome_install_wrapper() no longer overwrites `environment(fn)`.
#              Overwriting it with `ns_env` broke lexical scope resolution for
#              every wrapper, preventing them from accessing `.biome_env` and
#              crashing on `expand.grid` (ggplot2 load) and others.
#   - FIXED:   safe_makeCluster() now explicitly qualifies its default argument
#              as `parallel:::getClusterOption("type")` instead of relying on
#              environment hacking to resolve the unexported symbol.
#   - API_VERSION bumped 9→10 to signal the lexical scope fix.
#
# v11.3 CHANGES (from v11.2) — "Close the wrapper class-of-bug + PSE hardening":
#   Discovery: production crash on biome-calc04 (2026-04-24) —
#     Error in getClusterOption("type") : could not find function "getClusterOption"
#   Root cause: safe_makeCluster default `type = getClusterOption("type")` failed
#     at call time. assign(fn, envir=asNamespace("parallel")) does NOT change the
#     closure's enclosing environment, so lookup of non-exported `getClusterOption`
#     fell back to globalenv+baseenv → not found → crash on every makeCluster(N, ...)
#     without explicit type=. Confirmed: the safeguard killed every PSOCK cluster
#     created with bare makeCluster(), the exact opposite of its intent.
#
#   CHANGES:
#   - [W1]  ADDED:   .biome_install_wrapper() — single helper for installing
#                    namespace-binding wrappers. Sets environment(fn) <- ns_env
#                    so default args resolving to non-exported symbols work.
#                    Preserves original binding lock state (was_locked save/restore)
#                    — fixes silent "cannot change value of locked binding" errors
#                    when other packages try to patch same bindings later.
#                    Logs every install/skip/fail via sys_log for post-mortem.
#   - [W2]  FIXED:   safe_makeCluster — now uses .biome_install_wrapper; default
#                    `getClusterOption("type")` resolves against parallel ns.
#                    Observed in prod: makeCluster(4, outfile=...) now works.
#   - [W3]  FIXED:   safe_dist — restored full formal args (method, diag, upper, p)
#                    so tab completion, introspection, lintr, and positional
#                    calls all work. Also delegates explicitly (no ... splat).
#   - [W4]  FIXED:   safe_distm — added `...` passthrough for forward compat
#                    with future geosphere releases.
#   - [W5]  FIXED:   All safe_* wrappers migrated to .biome_install_wrapper —
#                    was_locked state preserved; no more unconditional lockBinding.
#   - [W6]  FIXED:   Smart I/O — split .biome_smart_io into two dedicated wrappers
#                    (.biome_smart_read_csv for utils::read.csv,
#                     .biome_smart_fread  for data.table::fread). Each captures
#                    its original via closure (not namespace lookup) so infinite
#                    recursion is impossible even if .biome_env is cleared.
#                    fread wrapper now matches real signature (input,file,text,cmd).
#   - [W7]  FIXED:   .biome_make_cluster_impl — requireNamespace("parallelly")
#                    guard with explicit stop() message. No more silent fail in
#                    minimal environments.
#   - [W8]  FIXED:   Section -1.8 — removed pre-creation of nimble_compile/
#                    tmb_compile subdirs (phantom per v11.2 H1-H8). Not exported
#                    to worker env anymore. Renamed comment: escape hatch docs.
#   - [W9]  FIXED:   Stan hook — separate flags per package (.cmdstanr_hook_done,
#                    .brms_hook_done, .rstan_hook_done). Enables late-loading
#                    packages to still pick up their routing.
#   - [W10] FIXED:   addTaskCallback fallback now covers non-RStudio Rscript —
#                    if callback registration fails AND we're not in RStudio,
#                    run init/hooks immediately so guards are still installed.
#   - [W11] FIXED:   get_active_users — counts Rscript and bare R too, not just
#                    rsession. Future::multisession and callr-spawned processes
#                    now counted correctly in fair-share computation.
#   - [W12] DOCUMENTED: solve/dist/outer wrappers are bypassed by S4 dispatch
#                    (e.g., Matrix::solve on dgCMatrix). Added warning in header
#                    of each guard so future maintainers know the scope.
#   - [W13] API_VERSION bumped 8→9 to signal contract change (new helper + fixes).
#
# Key design principles (v11.0):
#   - CORETYPE auto-detected from CPU vendor on EVERY session start (migration-safe)
#   - NO static CORETYPE, OMP, or BLAS thread counts in env files
#   - Boot-time detection: biome-detect-coretype.service (systemd oneshot)
#   - Per-session detection: this profile (handles live migration without reboot)
#   - Thread cap: %%MAX_BLAS_THREADS%% max to prevent QEMU livelock + BLAS oversubscription
#   - PESSIMISTIC SYSTEM ENGINEERING: assume failure at every layer, fail fast
#
# ARCHITECTURE (v11.0 — LOCAL-DISK FOR ALL SCRATCH):
#   /Rtmp = dedicated 400GB local ext4 disk per VM (NOT tmpfs, NOT NFS, NOT OS /tmp)
#   NFS   = user homes (/nfs/home/<user>) — FINAL results, saved RData, R libraries
#   Each VM has its own /Rtmp → no cross-server tmp interference, no NFS cache hell
#
#   EVERYTHING transient goes to /Rtmp/biome_<user>/<pkg>/:
#     - NIMBLE compile artifacts  (was NFS in v10.0 — FIXED)
#     - TMB compile artifacts
#     - Rcpp/sourceCpp compile temp
#     - Stan/rstan/cmdstanr output/compile
#     - terra/raster/stars/gdal temp rasters
#     - ncdf4/climate4R temp datasets
#     - keras/tensorflow cache + XLA tmpdir
#     - ggplot/ragg font cache + plot cache
#     - PSOCK cluster worker logs
#     - future plan cluster scratch
#     - R native tempdir() — inherited from TMPDIR=/Rtmp
#
#   NFS home keeps ONLY:
#     - ~/R/x86_64-pc-linux-gnu-library/4.5/  (persistent user packages)
#     - biome_save_session() RData backups
#     - User scripts, datasets, results
#
# v11.2 CHANGES (from v11.1) — "The honest cleanup" — REMOVE PHANTOM APIs:
#   Discovery: v11.0/v11.1 targeted routing APIs that DO NOT EXIST.
#   Verified empirically (2026-04-22) by grepping the upstream source repos:
#     * options("nimble.dirName")       — NIMBLE never reads this option.
#                                          Only NIMBLE getOption call is for
#                                          "nimble.Makevars.file". Compile dir
#                                          is controlled via `dirName` ARGUMENT
#                                          to compileNimble() or, when NULL,
#                                          defaults to file.path(tempdir(),
#                                          "nimble_generatedCode").
#     * Sys.setenv("TMB_COMPILE_DIR")   — TMB never reads this env var.
#     * options("rstan.auto_write")     — rstan uses its OWN option storage via
#                                          rstan_options("auto_write"), NOT
#                                          base::options().
#     * Sys.setenv("STAN_TMPDIR")       — Stan never reads this env var.
#
#   Verified as REAL and kept in v11.2:
#     * options("cmdstanr_output_dir")  — cmdstanr/R/options.R:27
#     * options("brms.file_refit")      — brms/R/brm.R:469
#
#   PSOCK NIMBLE ISOLATION — NATURAL, not engineered:
#     Each PSOCK worker is a separate R process with its own tempdir()
#     (R creates /Rtmp/RtmpXXXXXX on startup, driven by TMPDIR=/Rtmp from
#     Renviron.site). NIMBLE's default compile dir is tempdir()/nimble_generatedCode.
#     So each worker already compiles to a unique path on local disk with
#     ZERO configuration required. Confirmed via clusterEvalQ showing 4
#     unique tempdirs on /Rtmp/ for 4 workers.
#
#   MARTINA-GATE — Original "NIMBLE race on NFS" crash was a misdiagnosis:
#     The error `unserialize(node$con) : error reading from connection` in
#     Martina's script was caused by `setwd("BECAUSE")` (an unsubstituted
#     TODO placeholder) failing → cascading errors → `data_mod` never created
#     in master → parLapply's serialize() throws on undefined symbol → socket
#     closed → next recv fails with unserialize error. NIMBLE was not involved.
#
#   CHANGES:
#   - [H1]  REMOVED: options(nimble.dirName = ...) in worker fast-path (phantom)
#   - [H2]  REMOVED: setHook(packageEvent("nimble", "onLoad"), ...) (phantom target)
#   - [H3]  REMOVED: setHook(packageEvent("nimbleHMC", "onLoad"), ...) (phantom)
#   - [H4]  REMOVED: Sys.setenv(TMB_COMPILE_DIR = ...) in worker fast-path (phantom)
#   - [H5]  REMOVED: setHook for TMB/glmmTMB (phantom target)
#   - [H6]  REMOVED: options(rstan.auto_write = ...) (phantom)
#   - [H7]  REMOVED: Sys.setenv(STAN_TMPDIR = ...) (phantom)
#   - [H8]  REMOVED: Per-worker subdir creation in BIOME_NIMBLE_DIR / BIOME_TMB_DIR
#                    (cargo cult — NIMBLE uses tempdir() per worker, not these dirs)
#   - [H9]  KEPT:    options(cmdstanr_output_dir = worker_sd) for Stan output
#                    routing — but only if BIOME_STAN_DIR is set (real API)
#   - [H10] KEPT:    options(brms.file_refit = "on_change") — real API
#   - [H11] KEPT:    BLAS thread capping via Sys.setenv (OMP_NUM_THREADS etc.) — real
#   - [H12] KEPT:    BIOME env var propagation via biome_make_cluster() — real
#   - [H13] KEPT:    cluster_logs outfile routing — real and useful
#   - [H14] ADDED:   Optional worker diagnostic log (BIOME_WORKER_DEBUG=1) writes
#                    /tmp/biome_worker_<pid>.log to trace fast-path execution.
#                    For use if a future mystery arises; no-op by default.
#   - [H15] API_VERSION bumped 7→8 to signal contract change (phantom APIs removed).
#
# v11.1 CHANGES (from v11.0) — SUPERSEDED BY v11.2: attempted setHook fix for
#   phantom API options(nimble.dirName). Since the option itself doesn't exist,
#   the setHook approach was academic. Kept here for historical record:
#   - [F1]  Root cause observed in production (biome-calc04, R 4.5.3, 2026-04-22):
#           Worker fast-path at Rprofile load creates worker_<pid>/ dirs correctly
#           and BLAS env vars propagate, BUT options(nimble.dirName = worker_nd)
#           does NOT persist — getOption("nimble.dirName") returns NULL in
#           clusterEvalQ. Package-namespaced options set during Rprofile.site
#           sourcing appear to be lost when the worker transitions to the
#           parallel:::.slaveRSOCK() serve loop. Plain options (e.g.
#           "biome.profile.loaded") survive; only package-dotted names are lost.
#           Not fully understood; possibly related to the way Rscript handles
#           the site profile vs the slave bootstrap expression.
#   - [F2]  FIX: register setHook(packageEvent("nimble", "onLoad"), ...) in the
#           worker fast-path. Hook fires at require(nimble) / library(nimble)
#           time — exactly when options(nimble.dirName) actually matters for
#           compileNimble() routing. Hook closure captures worker_nd; safe
#           across worker lifetime. Applied symmetrically to nimbleHMC.
#   - [F3]  Same setHook pattern applied to TMB/glmmTMB (env var TMB_COMPILE_DIR)
#           and rstan/cmdstanr/brms (mixed options + STAN_TMPDIR). Belt-and-
#           suspenders: also keep the original options()/Sys.setenv() calls in
#           case either persists — harmless if redundant, saves you if one path
#           gets broken by future R or package changes.
#   - [F4]  API_VERSION bumped 6→7 to signal the contract change.
#

#   - [N1]  NIMBLE compilation moved NFS→/Rtmp local disk (per-PID worker subdirs)
#           Reason: acregmin=60,acdirmin=60 on NFS causes directory-cache races
#           during concurrent compileNimble() in multi-chain MCMC via parLapply.
#           Symptom: unserialize(node$con) worker death mid-chain. See rstudio#7031.
#   - [N2]  PSOCK fast-path receives BIOME_NIMBLE_DIR + BIOME_TMB_DIR env vars
#           and creates worker_<pid> subdirs → zero parent-dir contention.
#   - [N3]  biome_make_cluster() propagates all /Rtmp routing env vars to workers
#           and accepts outfile= argument (default: /Rtmp/.../cluster_logs/).
#           Outfile captures worker stderr for post-mortem when a worker dies.
#   - [N4]  parallel::makeCluster() safeguard — warns + redirects to
#           biome_make_cluster(). Educates users away from unsafe patterns.
#   - [N5]  doSNOW::registerDoSNOW() safeguard (symmetric to doParallel).
#   - [N6]  Rcpp/sourceCpp compile temp routed via TMPDIR (no new option needed,
#           but documented — Rcpp uses tempdir() which inherits from Renviron).
#   - [N7]  rstan/cmdstanr/brms auto-config — if loaded, set output_dir and
#           cache dirs to /Rtmp. Thread cap for stan_sampling.
#   - [N8]  BRISC / spNNGP / ranger — OMP thread cap for packages using libgomp
#           directly (not BLAS). Set n.omp.threads option on load.
#   - [N9]  New tool: biome_future_plan() — helper that picks plan() based on
#           workload. callr for compile-heavy (NIMBLE/Stan), cluster for I/O.
#   - [N10] New tool: biome_worker_diagnostics() — reads cluster_logs/ and shows
#           last N crashes, quickly locates the worker that died mid-chain.
#   - [N11] Dynamic rJava heap — replaces hardcoded -Xmx4g (uses user's quota).
#   - [N12] parallel::mcmapply / pvec / mclapply warnings for NFS-bound users.
#   - [N13] R_USER_CACHE_DIR kept on NFS (persistent package install cache)
#           but TMPDIR + per-pkg scratch dirs on /Rtmp (fast, ephemeral).
#   - [N14] brms::make_stancode + rstan::sampling cores arg capped at MAX_THREADS.
#
# v10.0 CHANGES (from v9.8) — Local /Rtmp Disk Architecture:
#   - [T1]  Replaced 100GB RAM tmpfs with dedicated 400GB local disk at /Rtmp
#   - [T2]  Removed tmpfs→NFS split-brain routing
#   - [T3]  Removed NFS fallback
#   - [T4]  All per-package temp dirs use local /Rtmp/biome_<user>/<pkg>
#   - [T5]  RAMDISK_GB=0 (no RAM consumed by /Rtmp)
#   - [T7]  API_VERSION bumped 4→5
#
# v9.8 CHANGES (from v9.7) — OpenBLAS Serial Safety:
#   - [B1]  SECTION -1.5: BLAS serial/pthread safety check at profile load
#   - [B2]  .biome_env$blas_is_serial: pessimistic flag
#   - [B3]  solve() guard: serial-aware
#   - [B4]  Belt-and-suspenders: OPENBLAS_NUM_THREADS=1 in Renviron.site
# ==============================================================================

# ── L2: Template Integrity Self-Check ──
# If template placeholders were not substituted, abort early to prevent
# syntax errors and silent profile failure.
local({
  sentinel <- "%%RPROFILE_VERSION%%"
  if (grepl("^%%", sentinel)) {
    warning("BIOME-CALC: Rprofile_site.R was not rendered from template (unsubstituted placeholders). Aborting.",
            call. = FALSE, immediate. = TRUE)
    return(invisible(NULL))
  }
})

# ══════════════════════════════════════════════════════════════════════════════
# SECTION -2: OPENBLAS CORETYPE AUTO-DETECTION (Migration-Safe)
# ══════════════════════════════════════════════════════════════════════════════
# This MUST run before ANY package loads or BLAS call happens.
# It runs for EVERY R process: rsession, Rscript workers, terminal R.
# On QEMU without cpu:host, OpenBLAS auto-detection picks instruction sets
# (e.g., AVX-512) that the virtual CPU doesn't support → SIGILL → crash.
#
# Detection priority:
#   1. If already set (by rsession-profile or systemd service), keep it.
#   2. Read /proc/cpuinfo vendor_id, select conservative CORETYPE.
#   3. If /proc/cpuinfo unreadable, don't set (let OpenBLAS try auto-detect).
# ══════════════════════════════════════════════════════════════════════════════
if (!nzchar(Sys.getenv("OPENBLAS_CORETYPE", ""))) {
  local({
    coretype <- tryCatch({
      ci <- readLines("/proc/cpuinfo", n = 20, warn = FALSE)
      vendor_line <- grep("^vendor_id", ci, value = TRUE)[1]
      if (is.na(vendor_line)) return(NULL)
      vendor <- trimws(sub(".*:\\s*", "", vendor_line))
      flags_line <- grep("^flags", ci, value = TRUE)[1]
      flags <- if (!is.na(flags_line)) trimws(sub(".*:\\s*", "", flags_line)) else ""

      if (grepl("AMD", vendor, ignore.case = TRUE)) {
        if (grepl("\\bavx2\\b", flags)) "ZEN" else "BARCELONA"
      } else if (grepl("Intel", vendor, ignore.case = TRUE)) {
        if (grepl("\\bavx512f\\b", flags)) "SKYLAKEX" else "HASWELL"
      } else {
        NULL
      }
    }, error = function(e) NULL)

    if (!is.null(coretype)) {
      Sys.setenv(OPENBLAS_CORETYPE = coretype)
    }
  })
}

# ══════════════════════════════════════════════════════════════════════════════
# SECTION -1.8: EARLY USER TMP ROOT SETUP (v11.0, updated v11.3)
# ══════════════════════════════════════════════════════════════════════════════
# Compute BIOME_USER_TMP = /Rtmp/biome_<user> as early as possible.
# Used by fast-path workers AND main session. Must precede any package hook.
# Also exported to child processes via env var so workers inherit without
# needing to read the master's .biome_env.
#
# v11.3 [W8]: Removed nimble_compile/ and tmb_compile/ pre-creation —
# these were phantom targets (NIMBLE and TMB don't read nimble.dirName /
# TMB_COMPILE_DIR — per v11.2 H1-H8). We no longer create them eagerly nor
# export BIOME_NIMBLE_DIR / BIOME_TMB_DIR to workers. Users who WANT to route
# NIMBLE compile to a specific local path can still pass `dirName=` explicitly
# to compileNimble() — that is the only supported API.
# ══════════════════════════════════════════════════════════════════════════════
local({
  curr_user <- tryCatch(Sys.info()[["user"]], error = function(e) "unknown")
  rtmp_path <- "/Rtmp"
  user_tmp  <- file.path(rtmp_path, paste0("biome_", curr_user))

  # Only create if /Rtmp is mounted (fail-fast: if not mounted, fall back to tempdir)
  if (dir.exists(rtmp_path)) {
    tryCatch({
      if (!dir.exists(user_tmp)) dir.create(user_tmp, recursive = TRUE, showWarnings = FALSE, mode = "0700")
    }, error = function(e) NULL)
    Sys.setenv(BIOME_USER_TMP = user_tmp)
    # v11.3: only pre-create dirs that SOMETHING actually writes to.
    # stan_compile:  options(cmdstanr_output_dir) writes here (real)
    # rcpp_cache:    RCPP_CACHE_DIR env var is read by Rcpp (real)
    # cluster_logs:  biome_make_cluster() writes PSOCK stderr here (real)
    # keras_cache:   KERAS_CACHE_DIR env var is read by keras (real)
    # plot_cache:    used by ragg/cairo tempfiles that explicitly route here
    for (sub in c("stan_compile", "rcpp_cache",
                  "cluster_logs", "keras_cache", "plot_cache")) {
      d <- file.path(user_tmp, sub)
      if (!dir.exists(d)) tryCatch(dir.create(d, recursive = TRUE, showWarnings = FALSE, mode = "0700"),
                                   error = function(e) NULL)
    }
    Sys.setenv(
      # v11.3: removed BIOME_NIMBLE_DIR / BIOME_TMB_DIR — phantom APIs
      BIOME_STAN_DIR   = file.path(user_tmp, "stan_compile"),
      BIOME_RCPP_CACHE = file.path(user_tmp, "rcpp_cache")
    )
  }
})

# ══════════════════════════════════════════════════════════════════════════════
# SECTION -1.5: BLAS SERIAL/PTHREAD SAFETY CHECK (v9.8)
# ══════════════════════════════════════════════════════════════════════════════
# OpenBLAS-pthread's internal thread pool conflicts with RStudio rsession's
# own pthreads, causing SIGSEGV in blas_thread_server during solve()/crossprod().
# See: https://github.com/rstudio/rstudio/issues/7031
# ══════════════════════════════════════════════════════════════════════════════
local({
  blas_path <- tryCatch(sessionInfo()$BLAS, error = function(e) "")
  lapack_path <- tryCatch(sessionInfo()$LAPACK, error = function(e) "")

  if (grepl("openblas-pthread", blas_path, fixed = TRUE) ||
      grepl("openblas-pthread", lapack_path, fixed = TRUE)) {
    Sys.setenv(OPENBLAS_NUM_THREADS = "1")
    warning(paste0(
      "BIOME-CALC CRITICAL: OpenBLAS-pthread detected!\n",
      "  BLAS:   ", blas_path, "\n",
      "  LAPACK: ", lapack_path, "\n",
      "  This WILL cause SIGSEGV in RStudio rsession during solve()/crossprod().\n",
      "  Emergency mitigation: OPENBLAS_NUM_THREADS forced to 1.\n",
      "  Fix: sudo apt-get install libopenblas0-serial && ",
      "sudo apt-get remove libopenblas0-pthread\n",
      "  See: https://github.com/rstudio/rstudio/issues/7031"),
      call. = FALSE, immediate. = TRUE)
  }
})

# ══════════════════════════════════════════════════════════════════════════════
# SECTION -1: PSOCK WORKER FAST PATH (v11.0 — compile-dir aware)
# ══════════════════════════════════════════════════════════════════════════════
# PSOCK workers are Rscript processes that load this profile on every start.
# The full profile (bspm, Ollama, callbacks, Smart I/O, etc.) is designed for
# interactive rsession — NOT for ephemeral compute workers.
#
# When the parent creates PSOCK workers (via biome_make_cluster), it sets:
#   BIOME_WORKER_MODE=1          — triggers this fast path
#   BIOME_WORKER_THREADS=<n>     — per-worker BLAS/OMP thread limit
#   BIOME_NIMBLE_DIR=<path>      — parent's nimble scratch root (v11.0)
#   BIOME_TMB_DIR=<path>         — parent's TMB scratch root (v11.0)
#   BIOME_STAN_DIR=<path>        — parent's Stan scratch root (v11.0)
#
# The fast path applies thread limits, creates per-PID compile subdirs,
# sets nimble.dirName/TMB_COMPILE_DIR, and returns. No task callbacks, no
# memory guards, no AI — workers are lean.
# ══════════════════════════════════════════════════════════════════════════════
if (nzchar(Sys.getenv("BIOME_WORKER_MODE", ""))) {
  # ════════════════════════════════════════════════════════════════════════════
  # WORKER MODE FAST PATH
  # ════════════════════════════════════════════════════════════════════════════
  # return() inside local() exits local() cleanly — never hits top-level.
  # Rscript under `--no-init-file --no-save --no-restore --no-echo` would
  # otherwise abort on a top-level return() with "no function to return from"
  # and exit BEFORE running the -e body, killing the worker at handshake.
  # ════════════════════════════════════════════════════════════════════════════
  local({
    wt <- Sys.getenv("BIOME_WORKER_THREADS", "1")
    Sys.setenv(
      OMP_NUM_THREADS        = wt,
      OPENBLAS_NUM_THREADS   = wt,
      MKL_NUM_THREADS        = wt,
      VECLIB_MAXIMUM_THREADS = wt,
      NUMEXPR_NUM_THREADS    = wt,
      GOTO_NUM_THREADS       = wt,
      BLIS_NUM_THREADS       = wt
    )
    if (requireNamespace("RhpcBLASctl", quietly = TRUE)) {
      tryCatch({
        RhpcBLASctl::blas_set_num_threads(as.integer(wt))
        RhpcBLASctl::omp_set_num_threads(as.integer(wt))
      }, error = function(e) NULL)
    }

    # ── v11.2 [H1-H8]: NIMBLE / TMB compile routing ─────────────────────────
    # NOT NEEDED. Each PSOCK worker is a separate R process with its OWN
    # tempdir() — R creates /Rtmp/RtmpXXXXXX on startup, driven by TMPDIR=/Rtmp
    # from Renviron.site. NIMBLE's default compile dir is:
    #     file.path(tempdir(), 'nimble_generatedCode')
    # So each worker automatically compiles to a unique /Rtmp path with ZERO
    # configuration. Confirmed empirically: 4 workers → 4 unique tempdirs.
    # Previous v11.0/v11.1 versions wrote options(nimble.dirName) and
    # Sys.setenv(TMB_COMPILE_DIR) — both are phantom APIs that NIMBLE and
    # TMB do not read. They were silently ignored. Removed in v11.2.
    # ─────────────────────────────────────────────────────────────────────────

    # ── v11.2 [H9-H10]: Stan / brms / cmdstanr routing (REAL options) ───────
    # Verified upstream:
    #   * options("cmdstanr_output_dir") — cmdstanr/R/options.R:27
    #   * options("brms.file_refit")     — brms/R/brm.R:469
    # Each worker's tempdir() already gives a unique path, but cmdstanr's
    # default is NOT tempdir() — it defaults to the current working directory.
    # So we DO need to route cmdstanr_output_dir explicitly to /Rtmp to avoid
    # writing Stan intermediate CSVs into the user's NFS home when the worker
    # inherits a NFS cwd. brms.file_refit="on_change" is just a sane default
    # for re-fitting behavior.
    sd <- Sys.getenv("BIOME_STAN_DIR", "")
    if (nzchar(sd)) {
      # Use the worker's own tempdir() as the Stan output dir — already unique
      # per worker, always on /Rtmp. No need to create extra worker_<pid>/ dirs.
      stan_out <- file.path(tempdir(), "cmdstan_output")
      tryCatch(dir.create(stan_out, recursive = TRUE, showWarnings = FALSE,
                          mode = "0700"),
               error = function(e) NULL)
      if (dir.exists(stan_out)) {
        options(
          cmdstanr_output_dir = stan_out,
          brms.file_refit     = "on_change"
        )
      }
    }

    # ── v11.2 [H14]: optional diagnostic log for troubleshooting ────────────
    # Enable by setting BIOME_WORKER_DEBUG=1 in the parent session before
    # biome_make_cluster(). Writes one log line per worker to
    # /tmp/biome_worker_<pid>.log so we can confirm the fast-path ran.
    if (nzchar(Sys.getenv("BIOME_WORKER_DEBUG", ""))) {
      tryCatch({
        log_path <- file.path("/tmp", paste0("biome_worker_", Sys.getpid(), ".log"))
        cat(sprintf("[%s] BIOME worker fast-path v11.2 loaded | pid=%d | tempdir=%s | blas_threads=%s\n",
                    format(Sys.time(), "%Y-%m-%d %H:%M:%S"),
                    Sys.getpid(), tempdir(), wt),
            file = log_path, append = TRUE)
      }, error = function(e) NULL)
    }

    options(biome.profile.loaded = TRUE)
  })

} else {
  # ════════════════════════════════════════════════════════════════════════════
  # FULL PROFILE — Interactive rsession / Rscript non-worker / Background jobs
  # ════════════════════════════════════════════════════════════════════════════

  # ── SECTION 0: bspm (Critical Pre-Load) ──
  options(bspm.sudo = TRUE, bspm.version.check = FALSE)
  tryCatch({
    if (requireNamespace("bspm", quietly = TRUE)) {
      options(bspm.sudo = TRUE)
      suppressMessages(bspm::enable())
    }
  }, error = function(e) NULL)

  # ── SECTION 1: Early options (rJava heap set dynamically in hook — see N11) ──
  # DO NOT set -Xmx here (was hardcoded 4g in v10.0). The rJava hook below
  # computes heap based on per-user quota.

  # ── GUARD: Prevent double-init (return() inside local() — never top-level) ──
  # Returns TRUE if the full profile should be skipped (already loaded).
  .biome_skip_main <- local({
    if (isTRUE(getOption("biome.profile.loaded"))) return(TRUE)
    if (exists(".biome_env", envir = .GlobalEnv, inherits = FALSE)) {
      .existing_be <- tryCatch(get(".biome_env", envir = .GlobalEnv),
                                error = function(e) NULL)
      if (is.environment(.existing_be) && !is.null(.existing_be$VERSION)) {
        options(biome.profile.loaded = TRUE)
        return(TRUE)
      }
    }
    options(biome.profile.loaded = TRUE)
    return(FALSE)
  })

  if (!.biome_skip_main) {

# ══════════════════════════════════════════════════════════════════════════════
# MAIN BLOCK
# ══════════════════════════════════════════════════════════════════════════════
local({

  .start_time <- Sys.time()
  VERSION     <- "%%RPROFILE_VERSION%%"

  # ── ANSI Colors ──
  .ESC      <- intToUtf8(27)
  .C_RESET  <- paste0(.ESC, "[39m")
  .C_RED    <- paste0(.ESC, "[31m")
  .C_GREEN  <- paste0(.ESC, "[32m")
  .C_YELLOW <- paste0(.ESC, "[33m")
  .C_BLUE   <- paste0(.ESC, "[34m")
  .C_CYAN   <- paste0(.ESC, "[36m")
  .C_BOLD   <- paste0(.ESC, "[1m")
  .C_GRAY   <- paste0(.ESC, "[90m")
  .C_ITALIC <- paste0(.ESC, "[3m")

  # ── Feature Flags ──
  ENABLE_RESOURCE_MGMT <- TRUE
  ENABLE_SMART_IO      <- TRUE
  ENABLE_SMART_ROUTING <- TRUE
  ENABLE_AI_ASSISTANT  <- TRUE
  ENABLE_SYS_LOGGING   <- TRUE
  ENABLE_TMP_CLEANUP   <- TRUE
  ENABLE_BLAS_MGMT     <- TRUE
  ENABLE_TERRA_OPT     <- TRUE
  ENABLE_RGEE_OPT      <- TRUE
  ENABLE_ARROW_OPT     <- TRUE
  ENABLE_FUTURE_OPT    <- TRUE
  ENABLE_CGROUP_AWARE  <- TRUE
  ENABLE_TF_MGMT       <- TRUE
  ENABLE_NUMA_AWARE    <- FALSE
  ENABLE_GGPLOT_OPT    <- TRUE
  ENABLE_STAN_OPT      <- TRUE   # v11.0 [N7]
  ENABLE_PARALLEL_GUARD <- TRUE  # v11.0 [N4] safeguard makeCluster/doSNOW

  # /Rtmp usage advisory threshold
  TMP_WARN_PCT     <- %%TMP_WARN_THRESHOLD_PCT%%L

  # ── Infrastructure ──
  R_HOST       <- "%%BIOME_HOST%%"
  LOG_PATH     <- "%%LOG_FILE%%"
  VM_VCORES    <- %%VM_VCORES%%L
  VM_RAM_GB    <- %%VM_RAM_GB%%L
  RAMDISK_GB   <- 0L
  TMP_DISK_GB  <- tryCatch(as.integer(Sys.getenv("BIOME_TMP_DISK_GB", "400")), error=function(e) 400L)
  RTMP_PATH    <- "/Rtmp"
  MAX_THREADS  <- %%MAX_BLAS_THREADS%%L

  OLLAMA_API   <- "http://127.0.0.1:11434/api/generate"
  AI_MODEL     <- tryCatch({
    mf <- "%%BIOME_CONF%%/ai_model"
    if (file.exists(mf)) trimws(readLines(mf, n = 1, warn = FALSE)) else "codellama:7b"
  }, error = function(e) "codellama:7b")
  AI_CURL_TIMEOUT <- 120

  # ── User Context ──
  curr_user    <- Sys.info()[["user"]]
  r_ver_short  <- paste0(R.version$major, ".", substr(R.version$minor, 1, 1))
  personal_lib <- file.path(Sys.getenv("HOME"), "R", "x86_64-pc-linux-gnu-library", r_ver_short)

  # v11.0: USER_TMP_ROOT is set in Section -1.8 via env var. Read it back
  # (or recompute if missing) so the main session and child processes agree.
  USER_TMP_ROOT <- Sys.getenv("BIOME_USER_TMP", file.path(RTMP_PATH, paste0("biome_", curr_user)))

  get_my_uid <- function() {
    tryCatch({
      if (requireNamespace("unix", quietly=TRUE)) return(unix::getuid())
      td <- tempdir(); if (dir.exists(td)) { uid <- file.info(td)$uid; if (!is.na(uid)) return(uid) }
      uid <- suppressWarnings(as.integer(system2("id", args="-u", stdout=TRUE, stderr=FALSE)))
      if (!is.na(uid)) return(uid)
      -1L
    }, error = function(e) -1L)
  }
  MY_UID <- get_my_uid()

  # ── Global Options ──
  options(
    parallelly.fork.enable             = TRUE,
    stringsAsFactors                   = FALSE,
    timeout                            = 300,
    editor                             = "vi",
    menu.graphics                      = FALSE,
    reticulate.python.usage.suggestion = FALSE,
    repos                              = c(CRAN = "https://cloud.r-project.org"),
    save.defaults                      = list(ascii = FALSE, version = NULL, compress = TRUE),
    # v11.2 [H9]: brms.file_refit is a REAL option (brms/R/brm.R:469)
    brms.file_refit                    = "on_change"
  )
  Sys.setenv(
    CUDA_VISIBLE_DEVICES = "-1",
    TF_CPP_MIN_LOG_LEVEL = "2"
    # v11.2 [H7]: CMDSTANR_OUTPUT_DIR env var is phantom — cmdstanr reads
    # options("cmdstanr_output_dir"), not this env var. Option is set below
    # inside the ENABLE_STAN_OPT block where USER_TMP_ROOT is validated.
  )

  # ── Secure Environment ──
  .biome_env <- new.env(parent = emptyenv())
  .biome_env$shared_env <- new.env(parent = emptyenv())

  se <- .biome_env$shared_env
  se$last_quota    <- 0L; se$last_cores   <- 0L;  se$last_threads <- 0L
  se$has_gpu       <- FALSE; se$gpu_count  <- 0L
  se$terra_threads <- 0L;  se$arrow_threads <- 0L; se$future_workers <- 0L
  se$cgroup_ram_gb <- Inf; se$cgroup_cpus   <- Inf
  se$ai_active     <- FALSE
  se$timeout_hours <- 24
  se$last_update   <- 0;   se$diag_logs     <- list()
  se$deferred_done <- FALSE
  se$last_cgroup_check <- 0
  se$user_tmp_root <- USER_TMP_ROOT   # v11.0: stored early
  .biome_env$VERSION <- VERSION
  .biome_env$API_VERSION <- 10L       # v11.4: bumped 9→10 (lexical scope fix)
  .biome_env$TMP_WARN_PCT <- TMP_WARN_PCT
  .biome_env$TMP_DISK_GB <- TMP_DISK_GB
  .biome_env$USER_TMP_ROOT <- USER_TMP_ROOT

  .biome_env$blas_is_serial <- tryCatch({
    blas_path <- sessionInfo()$BLAS
    lapack_path <- sessionInfo()$LAPACK
    grepl("openblas-serial", blas_path, fixed = TRUE) &&
    grepl("openblas-serial", lapack_path, fixed = TRUE)
  }, error = function(e) FALSE)
  rm(se)

  assign(".biome_env", .biome_env, envir = .GlobalEnv)

  # ── Logging Utility ──
  sys_log <- function(section, status, msg = "") {
    tryCatch({
      logs <- .biome_env$shared_env$diag_logs
      if (length(logs) > 500L) {
        keep_from <- max(1L, length(logs) - 399L)
        .biome_env$shared_env$diag_logs <- logs[seq(keep_from, length(logs))]
      }
      .biome_env$shared_env$diag_logs[[section]] <- list(status = status, msg = msg, ts = Sys.time())
    }, error = function(e) NULL)
    if (ENABLE_SYS_LOGGING) tryCatch({
      cat(sprintf("[%s] [USER: %-12s] [SEC: %-14s] [STAT: %-4s] %s\n",
          format(Sys.time(), "%Y-%m-%d %H:%M:%S"), curr_user, section, status, msg),
          file = LOG_PATH, append = TRUE)
    }, error = function(e) NULL)
  }

  get_session_timeout <- function() {
    conf_file <- "%%RSESSION_CONF_PATH%%"
    timeout_h <- 24
    if (file.exists(conf_file)) {
      tryCatch({
        lines <- readLines(conf_file, warn = FALSE)
        m <- grep("^session-timeout-minutes", lines, value = TRUE)
        if (length(m) > 0) {
          mins <- as.numeric(sub(".*=(\\d+).*", "\\1", m[1]))
          if (!is.na(mins) && mins > 0) timeout_h <- ceiling(mins / 60) + 1
          else if (grepl("=0", m[1])) timeout_h <- 168
        }
      }, error = function(e) NULL)
    }
    return(timeout_h)
  }
  .biome_env$shared_env$timeout_hours <- get_session_timeout()

  # ── Library Path & Smart Cleanup ──
  tryCatch({
    if (!dir.exists(personal_lib)) dir.create(personal_lib, recursive=TRUE, showWarnings=FALSE)
    if (!personal_lib %in% .libPaths()) .libPaths(c(personal_lib, .libPaths()))
    sys_log("LibPaths", "OK", paste("Primary:", personal_lib))
  }, error = function(e) NULL)

  if (ENABLE_TMP_CLEANUP && MY_UID >= 0) {
    tryCatch({
      all_tmp <- list.files(RTMP_PATH,
        pattern=paste0("^Rtmp|^terra_|^sf_|^arrow_|^rgee_|^gdalwarp_|^biome_", curr_user),
        full.names=TRUE)
      if (length(all_tmp) > 0) {
        info <- file.info(all_tmp)
        age_h <- as.numeric(difftime(Sys.time(), info$mtime, units="hours"))
        limit_h <- .biome_env$shared_env$timeout_hours
        to_del <- all_tmp[!is.na(info$uid) & info$uid == MY_UID & age_h > limit_h]
        current_td <- basename(tempdir())
        to_del <- to_del[basename(to_del) != current_td]
        # v11.0: NEVER delete user_tmp_root itself (contains active worker compile dirs)
        to_del <- to_del[to_del != USER_TMP_ROOT]
        if (length(to_del) > 0) {
           unlink(to_del, recursive=TRUE, force=FALSE)
           sys_log("Cleanup", "OK", sprintf("Removed %d /Rtmp items older than %dh", length(to_del), limit_h))
        }
      }
      # v11.0 [N10]: Clean old cluster_logs (keep last 7 days)
      cl_dir <- file.path(USER_TMP_ROOT, "cluster_logs")
      if (dir.exists(cl_dir)) {
        logs <- list.files(cl_dir, full.names = TRUE)
        if (length(logs) > 0) {
          li <- file.info(logs)
          old <- logs[as.numeric(difftime(Sys.time(), li$mtime, units = "days")) > 7]
          if (length(old) > 0) unlink(old, force = FALSE)
        }
      }
      # v11.3 [W8]: cleanup only real compile dirs (stan_compile).
      # nimble_compile/tmb_compile were phantom — v11.0-v11.2 created them
      # but nothing wrote to them. Keeping the loop single-entry for forward
      # compatibility (easy to re-add dirs if another routing becomes real).
      for (sub in c("stan_compile")) {
        d <- file.path(USER_TMP_ROOT, sub)
        if (dir.exists(d)) {
          sessions <- list.files(d, pattern = "^session_|^worker_", full.names = TRUE)
          if (length(sessions) > 0) {
            si <- file.info(sessions)
            limit_h <- .biome_env$shared_env$timeout_hours
            old_sess <- sessions[!is.na(si$mtime) &
                                 as.numeric(difftime(Sys.time(), si$mtime, units = "hours")) > limit_h]
            # Don't delete anything matching this session's PID
            my_pid_patterns <- c(paste0("session_", Sys.getpid()),
                                  paste0("worker_", Sys.getpid()))
            old_sess <- old_sess[!basename(old_sess) %in% my_pid_patterns]
            if (length(old_sess) > 0) {
              unlink(old_sess, recursive = TRUE, force = FALSE)
              sys_log("CompileCleanup", "OK",
                      sprintf("%s: removed %d orphan dirs", sub, length(old_sess)))
            }
          }
        }
      }
    }, error = function(e) NULL)
  }

  # ── Hardware Topology & Cgroups ──
  total_vcores <- tryCatch(parallel::detectCores(logical=TRUE), error=function(e) VM_VCORES)

  if (ENABLE_CGROUP_AWARE) tryCatch({
    cg2_mem <- "/sys/fs/cgroup/memory.max"; cg1_mem <- "/sys/fs/cgroup/memory/memory.limit_in_bytes"
    cg2_cpu <- "/sys/fs/cgroup/cpu.max";    cg1_cq  <- "/sys/fs/cgroup/cpu/cpu.cfs_quota_us"
    if (file.exists(cg2_mem)) {
      v <- trimws(readLines(cg2_mem, n=1, warn=FALSE))
      if (v != "max") .biome_env$shared_env$cgroup_ram_gb <- as.numeric(v)/(1024^3)
    } else if (file.exists(cg1_mem)) {
      v <- as.numeric(readLines(cg1_mem, n=1, warn=FALSE))
      if (!is.na(v) && v < 1e18) .biome_env$shared_env$cgroup_ram_gb <- v/(1024^3)
    }
    if (file.exists(cg2_cpu)) {
      p <- strsplit(trimws(readLines(cg2_cpu, n=1, warn=FALSE)), " ")[[1]]
      if (p[1] != "max" && length(p)==2) {
        q <- as.numeric(p[1]); d <- as.numeric(p[2])
        if (!is.na(q) && !is.na(d) && d>0) .biome_env$shared_env$cgroup_cpus <- q/d
      }
    } else if (file.exists(cg1_cq)) {
       q <- as.numeric(readLines(cg1_cq, n=1, warn=FALSE))
       d <- as.numeric(readLines("/sys/fs/cgroup/cpu/cpu.cfs_period_us", n=1, warn=FALSE))
       if (!is.na(q) && q>0 && !is.na(d) && d>0) .biome_env$shared_env$cgroup_cpus <- q/d
    }
  }, error = function(e) sys_log("Cgroup", "WARN", e$message))

  # ── Resource Engine ──
  .biome_raw_ram_gb <- function() {
    tryCatch({
      mi <- readLines("/proc/meminfo", warn = FALSE)
      al <- grep("^MemAvailable:", mi, value = TRUE)
      if (length(al) > 0) {
        as.numeric(sub(".*:\\s+(\\d+).*", "\\1", al[1])) / 1024 / 1024
      } else {
        f <- as.numeric(sub(".*:\\s+(\\d+).*","\\1",grep("^MemFree:",mi,value=TRUE)[1]))
        b <- as.numeric(sub(".*:\\s+(\\d+).*","\\1",grep("^Buffers:",mi,value=TRUE)[1]))
        c <- as.numeric(sub(".*:\\s+(\\d+).*","\\1",grep("^Cached:", mi,value=TRUE)[1]))
        sum(c(f,b,c), na.rm=TRUE) / 1024 / 1024
      }
    }, error = function(e) Inf)
  }
  .biome_env$.get_ram_gb <- .biome_raw_ram_gb

  get_system_ram_gb <- function() {
    tryCatch({
      ra <- floor(.biome_raw_ram_gb())
      if (is.finite(.biome_env$shared_env$cgroup_ram_gb)) ra <- min(ra, floor(.biome_env$shared_env$cgroup_ram_gb))
      max(2L, as.integer(ra))
    }, error=function(e) 16L)
  }

  get_active_users <- function() {
    # v11.3 [W11]: count rsession + Rscript + bare R processes for fair-share.
    # Future::multisession and callr spawn Rscript, not rsession — previous
    # version undercounted them, causing quota over-allocation.
    # We read /proc/<pid>/cmdline via readBin (NUL-separated argv) and
    # inspect basename(argv[0]). Can't use strsplit on "\0" literal because
    # R source disallows NUL in strings — we replace NULs -> spaces first.
    tryCatch({
      pids <- list.dirs("/proc", full.names = FALSE, recursive = FALSE)
      pids <- pids[grepl("^[0-9]+$", pids)]
      count <- 0L; scanned <- 0L
      for (p in pids) {
        scanned <- scanned + 1L
        if (scanned > 2000L) break
        cmdline_file <- file.path("/proc", p, "cmdline")
        if (file.exists(cmdline_file)) {
          raw_cmd <- tryCatch(readBin(cmdline_file, what = "raw", n = 512L),
                              error = function(e) raw(0L))
          if (length(raw_cmd) > 0L) {
            # Replace NUL argv separators with space so strsplit works
            raw_cmd[raw_cmd == as.raw(0L)] <- charToRaw(" ")
            cmd <- tryCatch(rawToChar(raw_cmd), error = function(e) "")
            if (nzchar(cmd)) {
              first_tok <- basename(trimws(strsplit(cmd, " ", fixed = TRUE)[[1]][1]))
              if (first_tok %in% c("rsession", "Rscript", "R") ||
                  grepl("^rsession", first_tok, fixed = FALSE)) {
                count <- count + 1L
              }
            }
          }
        }
      }
      if (count < 1L) 1L else count
    }, error = function(e) 1L)
  }

  update_resources <- function(quiet = TRUE) {
    tryCatch({
      now <- as.numeric(Sys.time())
      if (quiet && (now - .biome_env$shared_env$last_update) < 30) return(invisible(NULL))
      .biome_env$shared_env$last_update <- now

      ram_gb  <- get_system_ram_gb()
      n_procs <- get_active_users()
      quota   <- max(2L, as.integer(floor((ram_gb / n_procs) * 0.9)))
      eff_vc <- total_vcores
      if (is.finite(.biome_env$shared_env$cgroup_cpus)) eff_vc <- min(eff_vc, as.integer(ceiling(.biome_env$shared_env$cgroup_cpus)))
      fair_cores <- max(1L, as.integer(floor(eff_vc / n_procs)))
      bt <- min(fair_cores, MAX_THREADS)

      Sys.setenv(OMP_NUM_THREADS=as.character(bt),
                 OPENBLAS_NUM_THREADS=as.character(bt),
                 MKL_NUM_THREADS=as.character(bt),
                 VECLIB_MAXIMUM_THREADS=as.character(bt),
                 NUMEXPR_NUM_THREADS=as.character(bt),
                 GOTO_NUM_THREADS=as.character(bt),
                 BLIS_NUM_THREADS=as.character(bt))
      options(mc.cores = fair_cores)

      if (isNamespaceLoaded("data.table")) try(data.table::setDTthreads(bt), silent=TRUE)
      if (isNamespaceLoaded("RhpcBLASctl")) try({RhpcBLASctl::blas_set_num_threads(bt); RhpcBLASctl::omp_set_num_threads(bt)}, silent=TRUE)

      if (ENABLE_RGEE_OPT) {
        rgee_mem <- floor(quota * 0.3 * 1024)
        options(rgee.max_memory = rgee_mem, rgee.n_cores = min(4, fair_cores))
      }
      if (ENABLE_TF_MGMT) {
         inter_op <- max(1L, floor(bt / 2))
         Sys.setenv(TF_NUM_INTRAOP_THREADS = as.character(bt))
         Sys.setenv(TF_NUM_INTEROP_THREADS = as.character(inter_op))
         Sys.setenv(TF_ENABLE_ONEDNN_OPTS = "1")
      }
      if (ENABLE_AI_ASSISTANT) Sys.setenv(OLLAMA_NUM_THREADS = as.character(bt))

      if (!.biome_env$shared_env$ai_active && ENABLE_AI_ASSISTANT) {
          tryCatch({
              con <- suppressWarnings(socketConnection("127.0.0.1", port=11434, open="r", timeout=1.5))
              close(con)
              .biome_env$shared_env$ai_active <- TRUE
          }, error = function(e) NULL)
      }

      prev <- .biome_env$shared_env$last_quota
      if (!quiet && interactive() && prev > 0 && abs(quota - prev) > 1) {
        .bx_h <- intToUtf8(0x2550); .bx_v <- intToUtf8(0x2551)
        message(paste0("\n", .C_YELLOW, intToUtf8(0x2554), strrep(.bx_h, 50), intToUtf8(0x2557)))
        message(sprintf("%s \u26a1 BIOME-RESCALE: Activity Detected (Users: %-2d)  %s", .bx_v, n_procs, .bx_v))
        message(sprintf("%s    RAM Quota: %-3d GB | Threads: %-2d              %s", .bx_v, quota, bt, .bx_v))
        message(paste0(intToUtf8(0x255A), strrep(.bx_h, 50), intToUtf8(0x255D), .C_RESET))
      }
      .biome_env$shared_env$last_quota <- quota
      .biome_env$shared_env$last_cores <- fair_cores
      .biome_env$shared_env$last_threads <- bt

      if (ENABLE_CGROUP_AWARE && (now - .biome_env$shared_env$last_cgroup_check) > 300) {
        .biome_env$shared_env$last_cgroup_check <- now
        tryCatch({
          cg2_mem <- "/sys/fs/cgroup/memory.max"
          if (file.exists(cg2_mem)) {
            v <- trimws(readLines(cg2_mem, n=1, warn=FALSE))
            if (v != "max") .biome_env$shared_env$cgroup_ram_gb <- as.numeric(v)/(1024^3)
          }
        }, error = function(e) NULL)
      }

      if (ENABLE_SMART_ROUTING) tryCatch({
        tmp_pct <- get_tmp_disk_use_pct()
        if (tmp_pct >= TMP_WARN_PCT && !isTRUE(getOption("biome_tmp_warn_shown"))) {
          options(biome_tmp_warn_shown = TRUE)
          if (interactive()) {
            warning(sprintf(paste0(
              "BIOME-CALC: /Rtmp local disk is at %d%% capacity.\n",
              "  Clean up stale temp files or contact admin if persistent."),
              as.integer(tmp_pct)), call. = FALSE, immediate. = TRUE)
          }
          sys_log("TmpDisk", "WARN", sprintf("/Rtmp at %d%%", as.integer(tmp_pct)))
        }
      }, error = function(e) NULL)

    }, error=function(e) sys_log("ResMgmt", "FAIL", e$message))
  }

  # ══════════════════════════════════════════════════════════════════════════
  # PSOCK CLUSTER FACTORY (v11.0 — full routing env + outfile default)
  # v11.3 [W7]: explicit requireNamespace guard on parallelly.
  # ══════════════════════════════════════════════════════════════════════════
  .biome_make_cluster_impl <- function(workers = NULL, worker_threads = 1L,
                                        outfile = NULL, ...) {
    # Fail fast with actionable message if parallelly is missing.
    # Installing parallelly via apt (r-cran-parallelly) or install.packages.
    if (!requireNamespace("parallelly", quietly = TRUE)) {
      stop("BIOME-CALC: package 'parallelly' is required for biome_make_cluster().\n",
           "  Install: apt install r-cran-parallelly  OR  install.packages('parallelly')\n",
           "  This is a hard dependency — no silent fallback to parallel::makeCluster.",
           call. = FALSE)
    }
    if (is.null(workers)) {
      fc <- .biome_env$shared_env$last_cores
      workers <- max(1L, if (fc > 0) fc - 1L else 3L)
    }
    workers <- as.integer(workers)
    worker_threads <- as.integer(min(worker_threads, MAX_THREADS))
    coretype <- Sys.getenv("OPENBLAS_CORETYPE", "")

    # v11.0 [N3]: Default outfile routes to cluster_logs/ for post-mortem.
    if (is.null(outfile)) {
      cl_dir <- file.path(USER_TMP_ROOT, "cluster_logs")
      if (!dir.exists(cl_dir)) tryCatch(dir.create(cl_dir, recursive = TRUE, showWarnings = FALSE),
                                        error = function(e) NULL)
      outfile <- file.path(cl_dir,
                           sprintf("psock_%s_pid%d.log",
                                   format(Sys.time(), "%Y%m%d_%H%M%S"),
                                   Sys.getpid()))
    }

    # v11.0 [N3] + v11.3 [W8]: Propagate only REAL routing env vars to workers.
    # Removed BIOME_NIMBLE_DIR / BIOME_TMB_DIR — neither NIMBLE nor TMB read them.
    env_vec <- c(
      BIOME_WORKER_MODE       = "1",
      BIOME_WORKER_THREADS    = as.character(worker_threads),
      OMP_NUM_THREADS         = as.character(worker_threads),
      OPENBLAS_NUM_THREADS    = as.character(worker_threads),
      MKL_NUM_THREADS         = as.character(worker_threads),
      VECLIB_MAXIMUM_THREADS  = as.character(worker_threads),
      NUMEXPR_NUM_THREADS     = as.character(worker_threads),
      GOTO_NUM_THREADS        = as.character(worker_threads),
      BLIS_NUM_THREADS        = as.character(worker_threads),
      TMP                     = RTMP_PATH,
      TEMP                    = RTMP_PATH,
      TMPDIR                  = RTMP_PATH,
      R_TEMPDIR               = RTMP_PATH,
      BIOME_USER_TMP          = USER_TMP_ROOT,
      BIOME_STAN_DIR          = file.path(USER_TMP_ROOT, "stan_compile"),
      BIOME_RCPP_CACHE        = file.path(USER_TMP_ROOT, "rcpp_cache"),
      # GDAL routing for terra/sf/raster/stars in workers
      GDAL_NUM_THREADS        = as.character(worker_threads),
      CPL_TMPDIR              = file.path(USER_TMP_ROOT, "sf_gdal"),
      GDAL_PAM_PROXY_DIR      = file.path(USER_TMP_ROOT, "stars"),
      CUDA_VISIBLE_DEVICES    = "-1",
      TF_CPP_MIN_LOG_LEVEL    = "2",
      # Fontconfig for ragg/systemfonts (workers doing ggsave in parallel)
      FONTCONFIG_PATH         = "/etc/fonts"
    )
    if (nchar(coretype) > 0) env_vec <- c(env_vec, OPENBLAS_CORETYPE = coretype)

    parallelly::makeClusterPSOCK(
      workers,
      revtunnel = FALSE,
      homogeneous = TRUE,
      outfile = outfile,
      rscript_envs = env_vec,
      ...
    )
  }

  # ── Deferred helpers ──
  get_tmp_disk_use_pct <- function() {
    tryCatch({
      df_out <- system2("df", args = c("-P", RTMP_PATH), stdout = TRUE, stderr = FALSE)
      if (length(df_out) >= 2) {
        parts <- strsplit(trimws(df_out[2]), "[[:space:]]+")[[1]]
        pct_str <- gsub("[^0-9]", "", parts[5])
        if (nchar(pct_str) > 0) return(as.numeric(pct_str))
      }
      0
    }, error = function(e) 0)
  }


  # ══════════════════════════════════════════════════════════════════════════
  # v11.3 [W1]: WRAPPER INSTALLER — single source of truth for safe_* binds
  # ──────────────────────────────────────────────────────────────────────────
  # FIX class-of-bug observed in v11.2 safe_makeCluster:
  #   assign(fn, envir = asNamespace("parallel"))
  # does NOT change environment(fn). The closure keeps its original enclosure
  # (the local frame where it was defined). So default args that reference
  # non-exported symbols of the target namespace (e.g. getClusterOption) fail
  # at call-time symbol lookup with
  #   Error: could not find function "getClusterOption"
  #
  # This helper does FOUR things correctly on every install:
  #   1. environment(fn) <- ns_env  — fixes default-arg symbol resolution
  #   2. Verify target symbol exists — SKIP cleanly if package layout changed
  #   3. Save the original function (for pass-through) BEFORE mutation
  #   4. Preserve original binding-lock state (was_locked save/restore) so we
  #      don't silently change R's binding semantics under other packages
  # Every install/skip/fail is logged via sys_log for post-mortem.
  # ══════════════════════════════════════════════════════════════════════════
  .biome_install_wrapper <- function(fn, name, ns_env, save_original_to = NULL) {
    stopifnot(is.function(fn), is.character(name), length(name) == 1L,
              is.environment(ns_env))

    # (2) verify target exists in the namespace (not inherited)
    if (!exists(name, envir = ns_env, inherits = FALSE)) {
      sys_log("WrapperInstall", "SKIP",
              sprintf("%s not found in target namespace", name))
      return(invisible(FALSE))
    }

    # (3) save the original BEFORE any mutation, so we can always delegate
    original <- tryCatch(get(name, envir = ns_env, inherits = FALSE),
                         error = function(e) NULL)
    if (is.null(original) || !is.function(original)) {
      sys_log("WrapperInstall", "SKIP",
              sprintf("%s is not a function in namespace", name))
      return(invisible(FALSE))
    }
    if (!is.null(save_original_to)) {
      assign(save_original_to, original, envir = .biome_env)
    }

    # (1) REMOVED: environment(fn) <- ns_env
    # Changing the closure's environment breaks lexical scope resolution,
    # preventing the wrapper from accessing .biome_env, sys_log, etc.

    # (4) remember + restore lock state (don't silently lock unlocked bindings)
    was_locked <- tryCatch(bindingIsLocked(name, ns_env),
                           error = function(e) FALSE)
    tryCatch({
      if (was_locked) unlockBinding(name, ns_env)
      assign(name, fn, envir = ns_env)
      if (was_locked) lockBinding(name, ns_env)
      sys_log("WrapperInstall", "OK",
              sprintf("%s -> safe wrapper (was_locked=%s)", name, was_locked))
      invisible(TRUE)
    }, error = function(e) {
      sys_log("WrapperInstall", "FAIL", sprintf("%s: %s", name, e$message))
      # Attempt best-effort rollback if possible
      tryCatch({
        if (was_locked && !bindingIsLocked(name, ns_env)) lockBinding(name, ns_env)
      }, error = function(e2) NULL)
      invisible(FALSE)
    })
  }

  # ══════════════════════════════════════════════════════════════════════════
  # DEFERRED PACKAGE INIT — installs base memory guards (one-shot)
  # ══════════════════════════════════════════════════════════════════════════
  deferred_pkg_init <- function() {
    if (.biome_env$shared_env$deferred_done) return(invisible(NULL))
    fc <- .biome_env$shared_env$last_cores
    qr <- .biome_env$shared_env$last_quota
    msg_parts <- c()

    .biome_get_ram_gb <- .biome_env$.get_ram_gb
    .blas_serial <- isTRUE(.biome_env$blas_is_serial)

    # ── solve() guard (v11.3 [W5]: migrated to .biome_install_wrapper) ──
    # NOTE [W12]: This guard protects DENSE base::solve() dispatch only.
    # S4 methods (e.g., Matrix::solve for dgCMatrix) are dispatched via
    # setMethod and bypass this wrapper completely. Users working with
    # Matrix sparse types will NOT see these warnings — document in tutorial.
    if (ENABLE_SMART_ROUTING && !isTRUE(attr(base::solve, "biome_guard"))) tryCatch({
      safe_solve <- function(a, b, ...) {
        if (is.matrix(a) && nrow(a) > 5000 && ncol(a) == nrow(a)) {
          n <- nrow(a)
          matrix_gb <- (n * n * 8) / 1024^3
          ram_avail_gb <- .biome_get_ram_gb()
          blas_serial <- isTRUE(.biome_env$blas_is_serial)

          if (blas_serial) {
            if (is.finite(ram_avail_gb) && matrix_gb * 2.06 > ram_avail_gb * 0.8) {
              warning(sprintf(paste0(
                "BIOME-CALC: solve() on %d x %d matrix (~%.0f GB) needs ~%.0f GB.\n",
                "  Available RAM: ~%.0f GB. OOM risk is HIGH.\n",
                "  BLAS: serial (no thread reduction available).\n",
                "  Alternatives: Matrix::Cholesky() for SPD, or sparse methods."),
                n, n, matrix_gb, matrix_gb * 2.06, ram_avail_gb),
                call. = FALSE, immediate. = TRUE)
            } else if (matrix_gb > 5 && interactive()) {
              message(sprintf(paste0(.C_YELLOW,
                "\U0001F4A1 BIOME-CALC: solve() on %d\u00d7%d matrix (~%.1f GB). ",
                "BLAS: serial (safe, no thread conflict).", .C_RESET),
                n, n, matrix_gb))
            }
          } else {
            curr_threads <- as.integer(Sys.getenv("OPENBLAS_NUM_THREADS", "1"))
            total_need_gb <- matrix_gb * (2 + 0.06 * curr_threads)
            if (is.finite(ram_avail_gb) && total_need_gb > ram_avail_gb * 0.8) {
              warning(sprintf(paste0(
                "BIOME-CALC: solve() on %d x %d matrix (~%.0f GB) with %d BLAS threads needs ~%.0f GB.\n",
                "  Available RAM: ~%.0f GB. OOM risk is HIGH."),
                n, n, matrix_gb, curr_threads, total_need_gb, ram_avail_gb),
                call. = FALSE, immediate. = TRUE)
              if (interactive()) Sys.sleep(2)
            }
            reduced_threads <- if (n > 10000) 2L
                               else if (n > 5000) max(4L, as.integer(curr_threads / 2))
                               else curr_threads
            if (reduced_threads < curr_threads) {
              Sys.setenv(OPENBLAS_NUM_THREADS = as.character(reduced_threads),
                         OMP_NUM_THREADS = as.character(reduced_threads))
              if (isNamespaceLoaded("RhpcBLASctl")) tryCatch({
                RhpcBLASctl::blas_set_num_threads(reduced_threads)
                RhpcBLASctl::omp_set_num_threads(reduced_threads)
              }, error = function(e) NULL)
              on.exit({
                Sys.setenv(OPENBLAS_NUM_THREADS = as.character(curr_threads),
                           OMP_NUM_THREADS = as.character(curr_threads))
                if (isNamespaceLoaded("RhpcBLASctl")) tryCatch({
                  RhpcBLASctl::blas_set_num_threads(curr_threads)
                  RhpcBLASctl::omp_set_num_threads(curr_threads)
                }, error = function(e) NULL)
              }, add = TRUE)
            }
          }
        }
        .biome_env$original_solve(a, b, ...)
      }
      attr(safe_solve, "biome_guard") <- TRUE
      .biome_install_wrapper(safe_solve, "solve", baseenv(),
                             save_original_to = "original_solve")
    }, error = function(e) sys_log("SolveGuard", "FAIL", e$message))

    # ── dist() guard (v11.3 [W3+W5]: restored formals, migrated to helper) ──
    # NOTE [W12]: stats::dist is S3 but simple; no hidden S4 dispatch path.
    # Restoring formal args allows tab completion, positional calls,
    # lintr/styler introspection, and formals(dist) to behave correctly.
    if (ENABLE_SMART_ROUTING && !isTRUE(attr(stats::dist, "biome_guard"))) tryCatch({
      safe_dist <- function(x, method = "euclidean", diag = FALSE,
                            upper = FALSE, p = 2) {
        if (is.matrix(x) || is.data.frame(x)) {
          n <- nrow(x)
          result_gb <- (n * (n - 1) / 2 * 8) / 1024^3
          if (result_gb > 5 && interactive()) {
            ram_gb <- .biome_get_ram_gb()
            full_matrix_gb <- (n * n * 8) / 1024^3
            if (is.finite(ram_gb) && full_matrix_gb > ram_gb * 0.5) {
              warning(sprintf(paste0(
                "BIOME-CALC: dist() on %d observations will create a %.1f GB dist object.\n",
                "  as.matrix() on this would need %.1f GB. Available RAM: ~%.0f GB.\n",
                "  For N > 20,000: consider sparse distance methods or spatial indexing."),
                n, result_gb, full_matrix_gb, ram_gb),
                call. = FALSE, immediate. = TRUE)
            }
          }
        }
        # Delegate with EXPLICIT named args — no ... splat that could drop values
        .biome_env$original_dist(x, method = method, diag = diag,
                                 upper = upper, p = p)
      }
      attr(safe_dist, "biome_guard") <- TRUE
      .biome_install_wrapper(safe_dist, "dist", asNamespace("stats"),
                             save_original_to = "original_dist")
    }, error = function(e) sys_log("DistGuard", "FAIL", e$message))

    # ── outer() guard (v11.3 [W5]: migrated to .biome_install_wrapper) ──
    if (ENABLE_SMART_ROUTING && !isTRUE(attr(base::outer, "biome_guard"))) tryCatch({
      safe_outer <- function(X, Y = X, FUN = "*", ...) {
        n1 <- length(X); n2 <- length(Y)
        result_gb <- (n1 * n2 * 8) / 1024^3
        if (result_gb > 5 && interactive()) {
          ram_gb <- .biome_get_ram_gb()
          if (is.finite(ram_gb) && result_gb > ram_gb * 0.5) {
            warning(sprintf(paste0(
              "BIOME-CALC: outer() will create a %d x %d matrix (%.1f GB). Available RAM: ~%.0f GB."),
              n1, n2, result_gb, ram_gb), call. = FALSE, immediate. = TRUE)
          }
        }
        .biome_env$original_outer(X, Y, FUN, ...)
      }
      attr(safe_outer, "biome_guard") <- TRUE
      .biome_install_wrapper(safe_outer, "outer", baseenv(),
                             save_original_to = "original_outer")
    }, error = function(e) sys_log("OuterGuard", "FAIL", e$message))

    # ── expand.grid() guard (v11.3 [W5]: migrated to .biome_install_wrapper) ──
    if (ENABLE_SMART_ROUTING && !isTRUE(attr(base::expand.grid, "biome_guard"))) tryCatch({
      safe_expand_grid <- function(...) {
        args <- list(...)
        if (length(args) > 0) {
          total_rows <- prod(vapply(args, length, 1L))
          ncols <- length(args)
          result_gb <- (total_rows * ncols * 8) / 1024^3
          if (result_gb > 2 && interactive()) {
            ram_gb <- .biome_get_ram_gb()
            msg <- sprintf("expand.grid() will create %.0f rows x %d cols (~%.1f GB)",
                           total_rows, ncols, result_gb)
            if (is.finite(ram_gb) && result_gb > ram_gb * 0.5) {
              warning(sprintf(paste0(
                "BIOME-CALC: %s. Available RAM: ~%.0f GB.\n",
                "  Consider: data.table::CJ() for cross-joins, or iterators."), msg, ram_gb),
                call. = FALSE, immediate. = TRUE)
            }
          }
        }
        .biome_env$original_expand_grid(...)
      }
      attr(safe_expand_grid, "biome_guard") <- TRUE
      .biome_install_wrapper(safe_expand_grid, "expand.grid", baseenv(),
                             save_original_to = "original_expand_grid")
    }, error = function(e) sys_log("ExpandGridGuard", "FAIL", e$message))

    # ══════════════════════════════════════════════════════════════════════
    # v11.0 [N4] + v11.3 [W2]: parallel::makeCluster SAFEGUARD
    # ══════════════════════════════════════════════════════════════════════
    # FIXED in v11.4: explicitly qualify parallel:::getClusterOption("type").
    # The previous v11.3 fix (changing the closure's environment) broke
    # lexical scope resolution for .biome_env across all wrappers.
    # ══════════════════════════════════════════════════════════════════════
    if (ENABLE_PARALLEL_GUARD && !exists("original_makeCluster", envir = .biome_env)) tryCatch({
      safe_makeCluster <- function(spec, type = parallel:::getClusterOption("type"), ...) {
        # Only warn for PSOCK (default) — FORK/MPI have their own issues
        if ((missing(type) || type == "PSOCK") && interactive()) {
          message(sprintf(paste0(.C_YELLOW,
            "\U0001F6E1\ufe0f  BIOME-CALC: parallel::makeCluster(%s) detected.\n",
            "   For NIMBLE/TMB/Stan MCMC use: biome_make_cluster(workers=%s, worker_threads=1L)\n",
            "   It sets BLAS/OMP caps, routes compile to /Rtmp, captures worker logs,\n",
            "   and prevents NFS directory-cache races that cause unserialize() failures.",
            .C_RESET),
            if (is.numeric(spec)) as.character(spec) else "N",
            if (is.numeric(spec)) as.character(spec) else "N"))
        }
        .biome_env$original_makeCluster(spec, type = type, ...)
      }
      ok <- .biome_install_wrapper(safe_makeCluster, "makeCluster",
                                    asNamespace("parallel"),
                                    save_original_to = "original_makeCluster")
      if (isTRUE(ok)) msg_parts <- c(msg_parts, "parallel::makeCluster [Guard]")
    }, error = function(e) sys_log("MakeClusterGuard", "FAIL", e$message))

    # v11.0-fix: Set deferred_done AFTER all guards are installed
    .biome_env$shared_env$deferred_done <- TRUE

    # ══ Per-user /Rtmp setup (defensive — already done in Section -1.8) ══
    tryCatch({
      user_tmp_root <- file.path(RTMP_PATH, paste0("biome_", curr_user))
      if (!dir.exists(user_tmp_root)) dir.create(user_tmp_root, recursive = TRUE, showWarnings = FALSE)
      .biome_env$shared_env$user_tmp_root <- user_tmp_root
    }, error = function(e) sys_log("DeferredInit", "FAIL", e$message))
  }

  # ══════════════════════════════════════════════════════════════════════════
  # DEFERRED PACKAGE HOOKS — runs on EVERY callback (fires as packages load)
  # ══════════════════════════════════════════════════════════════════════════
  deferred_pkg_hooks <- function() {
    if (!.biome_env$shared_env$deferred_done) return(invisible(NULL))
    fc <- .biome_env$shared_env$last_cores
    qr <- .biome_env$shared_env$last_quota
    msg_parts <- c()

    user_tmp_root <- .biome_env$shared_env$user_tmp_root
    if (is.null(user_tmp_root)) {
      user_tmp_root <- file.path(RTMP_PATH, paste0("biome_", curr_user))
      if (!dir.exists(user_tmp_root)) dir.create(user_tmp_root, recursive = TRUE, showWarnings = FALSE)
    }

    # ── terra ──
    if (ENABLE_TERRA_OPT && isNamespaceLoaded("terra") &&
        .biome_env$shared_env$terra_threads == 0L) tryCatch({
      tt <- min(fc, 8L); gc_mb <- as.integer(floor(qr * 0.2 * 1024))
      Sys.setenv(GDAL_NUM_THREADS = as.character(tt), GDAL_CACHEMAX = as.character(gc_mb))
      td <- file.path(user_tmp_root, "terra")
      if (!dir.exists(td)) dir.create(td, recursive = TRUE, showWarnings = FALSE)
      terra::terraOptions(memfrac = 0.6, tempdir = td, verbose = FALSE)
      .biome_env$shared_env$terra_threads <- tt
      msg_parts <- c(msg_parts, "Terra [LocalDisk]")
    }, error = function(e) NULL)

    # ── raster ──
    if (ENABLE_SMART_ROUTING && isNamespaceLoaded("raster") &&
        !isTRUE(.biome_env$shared_env$.raster_hook_done)) tryCatch({
      rt <- file.path(user_tmp_root, "raster")
      if (!dir.exists(rt)) dir.create(rt, recursive=TRUE, showWarnings=FALSE)
      raster::rasterOptions(tmpdir = rt)
      .biome_env$shared_env$.raster_hook_done <- TRUE
      msg_parts <- c(msg_parts, "Raster [LocalDisk]")
    }, error = function(e) NULL)

    # ── stars ──
    if (ENABLE_SMART_ROUTING && isNamespaceLoaded("stars") &&
        !isTRUE(.biome_env$shared_env$.stars_hook_done)) tryCatch({
      st <- file.path(user_tmp_root, "stars")
      if (!dir.exists(st)) dir.create(st, recursive=TRUE, showWarnings=FALSE)
      Sys.setenv(GDAL_PAM_PROXY_DIR = st)
      .biome_env$shared_env$.stars_hook_done <- TRUE
      msg_parts <- c(msg_parts, "Stars [LocalDisk]")
    }, error = function(e) NULL)

    # ── sf (GDAL routing) ──
    if (ENABLE_SMART_ROUTING && isNamespaceLoaded("sf") &&
        !isTRUE(.biome_env$shared_env$.sf_hook_done)) tryCatch({
      sf_tmp <- file.path(user_tmp_root, "sf_gdal")
      if (!dir.exists(sf_tmp)) dir.create(sf_tmp, recursive = TRUE, showWarnings = FALSE)
      Sys.setenv(CPL_TMPDIR = sf_tmp)   # GDAL temp
      .biome_env$shared_env$.sf_hook_done <- TRUE
      msg_parts <- c(msg_parts, "sf/GDAL [LocalDisk]")
    }, error = function(e) NULL)

    # ── ncdf4 ──
    if (ENABLE_SMART_ROUTING && isNamespaceLoaded("ncdf4") &&
        !isTRUE(.biome_env$shared_env$.ncdf4_hook_done)) tryCatch({
      nc_tmp <- file.path(user_tmp_root, "ncdf4")
      if (!dir.exists(nc_tmp)) dir.create(nc_tmp, recursive=TRUE, showWarnings=FALSE)
      .biome_env$shared_env$.ncdf4_hook_done <- TRUE
      msg_parts <- c(msg_parts, "NetCDF [LocalDisk]")
    }, error = function(e) NULL)

    # ── gstat / fields / spatstat ──
    if (ENABLE_SMART_ROUTING && (isNamespaceLoaded("gstat") || isNamespaceLoaded("fields") ||
                                  isNamespaceLoaded("spatstat")) &&
        !isTRUE(.biome_env$shared_env$.spatial_stats_hook_done)) tryCatch({
      sp_tmp <- file.path(user_tmp_root, "spatial_stats")
      if (!dir.exists(sp_tmp)) dir.create(sp_tmp, recursive=TRUE, showWarnings=FALSE)
      loaded <- c(if (isNamespaceLoaded("gstat")) "Gstat",
                  if (isNamespaceLoaded("fields")) "Fields",
                  if (isNamespaceLoaded("spatstat")) "Spatstat")
      .biome_env$shared_env$.spatial_stats_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("%s [LocalDisk]", paste(loaded, collapse="+")))
    }, error = function(e) NULL)

    # ── keras / tensorflow ──
    if (ENABLE_SMART_ROUTING && (isNamespaceLoaded("keras") || isNamespaceLoaded("tensorflow")) &&
        !isTRUE(.biome_env$shared_env$.keras_hook_done)) tryCatch({
      kt <- file.path(user_tmp_root, "keras_cache")
      if (!dir.exists(kt)) dir.create(kt, recursive=TRUE, showWarnings=FALSE)
      Sys.setenv(KERAS_CACHE_DIR = kt)
      Sys.setenv(TF_XLA_FLAGS = paste0("--tf_xla_enable_xla_devices --tf_xla_cpu_global_jit --tf_xla_auto_jit=2 --tf_xla_fallback_tmpdir=", kt))
      .biome_env$shared_env$.keras_hook_done <- TRUE
      msg_parts <- c(msg_parts, "Keras [LocalDisk]")
    }, error = function(e) NULL)

    # ── ggplot / plotly / tmap / mapview ──
    if (ENABLE_GGPLOT_OPT && (isNamespaceLoaded("ggplot2") || isNamespaceLoaded("plotly") ||
                               isNamespaceLoaded("tmap") || isNamespaceLoaded("mapview")) &&
        !isTRUE(.biome_env$shared_env$.ggplot_hook_done)) tryCatch({
      gt <- file.path(user_tmp_root, "plot_cache")
      if (!dir.exists(gt)) dir.create(gt, recursive = TRUE, showWarnings = FALSE)
      # Note: we do NOT overwrite TMP/TEMP globally here because that breaks other stuff.
      # Per-plot temp is handled by ragg/cairo via tempfile() → inherits TMPDIR = /Rtmp ✓
      has_ragg <- requireNamespace("ragg", quietly = TRUE)
      if (has_ragg) options(device = ragg::agg_png)
      options(bitmapType = "cairo")
      options(ggplot2.continuous.colour = "viridis", ggplot2.continuous.fill = "viridis")
      Sys.setenv(FONTCONFIG_PATH = "/etc/fonts")
      if (requireNamespace("systemfonts", quietly = TRUE)) {
        tryCatch(systemfonts::system_fonts(), error = function(e) NULL)
      }
      backend_label <- if (has_ragg) "ragg" else "cairo"
      vis_pkgs <- c("Ggplot", if (isNamespaceLoaded("tmap")) "Tmap",
                    if (isNamespaceLoaded("mapview")) "Mapview")
      .biome_env$shared_env$.ggplot_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("%s [%s/LocalDisk]", paste(vis_pkgs, collapse="+"),
                                         backend_label))
    }, error = function(e) NULL)

    # ── arrow ──
    if (ENABLE_ARROW_OPT && isNamespaceLoaded("arrow") &&
        .biome_env$shared_env$arrow_threads == 0L) tryCatch({
      at <- min(fc, 16L); arrow::set_cpu_count(at); arrow::set_io_thread_count(min(at,8L))
      .biome_env$shared_env$arrow_threads <- at
      msg_parts <- c(msg_parts, "Arrow")
    }, error = function(e) NULL)

    # ── geosphere safeguard (v11.3 [W4+W5]: ... passthrough + helper) ──
    if (ENABLE_SMART_ROUTING && isNamespaceLoaded("geosphere") &&
        !exists("original_distm", envir = .biome_env)) tryCatch({
      safe_distm <- function(x, y = x, fun = geosphere::distHaversine, ...) {
        n1 <- if (is.matrix(x) || is.data.frame(x)) nrow(x) else length(x) / 2
        n2 <- if (is.matrix(y) || is.data.frame(y)) nrow(y) else length(y) / 2
        matrix_gb <- (n1 * n2 * 8) / 1024^3
        ram_avail_gb <- .biome_env$.get_ram_gb()
        if (matrix_gb > 5 && interactive()) {
          message(sprintf(paste0(.C_YELLOW,
            "\n\u26a0\ufe0f  BIOME-CALC: geosphere::distm() will create a %.0f x %.0f matrix (%.1f GB).",
            "\n   Available RAM: ~%.0f GB. solve() on this matrix needs ~%.0f GB.",
            "\n   For N > 20,000: consider sparse matrices or NNGP (see biome_tutorial()).", .C_RESET),
            n1, n2, matrix_gb, ram_avail_gb, matrix_gb * 4))
        }
        if (is.finite(ram_avail_gb) && matrix_gb > ram_avail_gb * 0.5) {
          warning(sprintf(paste0(
            "BIOME-CALC: distm() output (%.1f GB) would exceed 50%% of available RAM (%.0f GB).\n",
            "  Solutions: (1) sparse matrices, (2) BRISC/spNNGP, (3) bigmemory chunking."),
            matrix_gb, ram_avail_gb), call. = FALSE, immediate. = TRUE)
        }
        .biome_env$original_distm(x, y, fun, ...)
      }
      ok <- .biome_install_wrapper(safe_distm, "distm",
                                    asNamespace("geosphere"),
                                    save_original_to = "original_distm")
      if (isTRUE(ok)) msg_parts <- c(msg_parts, "Geosphere [SafeGuard]")
    }, error = function(e) sys_log("DistmGuard", "FAIL", e$message))

    # ── future ──
    if (ENABLE_FUTURE_OPT && isNamespaceLoaded("future") &&
        .biome_env$shared_env$future_workers == 0L) tryCatch({
      fw <- max(1L, fc - 1L)
      cl <- .biome_make_cluster_impl(workers = fw, worker_threads = 1L)
      future::plan(future::cluster, workers = cl)
      .biome_env$shared_env$future_workers <- fw
      msg_parts <- c(msg_parts, "Future")
    }, error = function(e) NULL)

    # ── doParallel safeguard (v11.3 [W5]: migrated to helper) ──
    if (isNamespaceLoaded("doParallel") &&
        !exists("original_registerDoParallel", envir = .biome_env)) tryCatch({
      safe_registerDoParallel <- function(cl = NULL, cores = NULL, ...) {
        if (is.null(cl) && !is.null(cores)) {
          cl <- .biome_make_cluster_impl(workers = as.integer(cores), worker_threads = 1L)
          if (interactive()) {
            message(sprintf(paste0(.C_GREEN,
              "\U0001F6E1\ufe0f BIOME-CALC: doParallel registered with %d workers (BLAS threads capped at 1/worker).",
              .C_RESET), as.integer(cores)))
          }
        } else if (is.null(cl)) {
          fw <- max(1L, .biome_env$shared_env$last_cores - 1L)
          cl <- .biome_make_cluster_impl(workers = fw, worker_threads = 1L)
        }
        .biome_env$original_registerDoParallel(cl, ...)
      }
      ok <- .biome_install_wrapper(safe_registerDoParallel, "registerDoParallel",
                                    asNamespace("doParallel"),
                                    save_original_to = "original_registerDoParallel")
      if (isTRUE(ok)) msg_parts <- c(msg_parts, "DoParallel [SafeGuard]")
    }, error = function(e) sys_log("DoParallelGuard", "FAIL", e$message))

    # ── v11.0 [N5] + v11.3 [W5]: doSNOW safeguard (migrated to helper) ──
    if (isNamespaceLoaded("doSNOW") &&
        !exists("original_registerDoSNOW", envir = .biome_env)) tryCatch({
      safe_registerDoSNOW <- function(cl) {
        if (!inherits(cl, "cluster") && interactive()) {
          message(paste0(.C_YELLOW,
            "\U0001F4A1 BIOME-CALC: doSNOW::registerDoSNOW() called without a cluster.\n",
            "   Recommended: cl <- biome_make_cluster(workers=N); registerDoSNOW(cl)",
            .C_RESET))
        }
        .biome_env$original_registerDoSNOW(cl)
      }
      ok <- .biome_install_wrapper(safe_registerDoSNOW, "registerDoSNOW",
                                    asNamespace("doSNOW"),
                                    save_original_to = "original_registerDoSNOW")
      if (isTRUE(ok)) msg_parts <- c(msg_parts, "DoSNOW [SafeGuard]")
    }, error = function(e) sys_log("DoSNOWGuard", "FAIL", e$message))


    # ══════════════════════════════════════════════════════════════════════
    # v11.0 [N1]: NIMBLE/nimbleHMC — LOCAL-DISK compile (was NFS in v10.0)
    # ──────────────────────────────────────────────────────────────────────
    # ROOT CAUSE of unserialize() crashes in multi-chain parLapply MCMC:
    #   1. v10.0 routed nimble.dirName to $HOME/.nimble_compile/session_<pid>
    #   2. $HOME is NFS mount with acregmin=60,acdirmin=60 (dir attr cache = 60s)
    #   3. compileNimble() spawns R CMD SHLIB → g++ → writes .cpp/.o/.so
    #   4. When 4 parLapply workers compile concurrently on the same parent dir,
    #      NFS directory-listing cache isn't consistent → make sees stale state →
    #      either build fails OR produces a corrupt .so → dyn.load() SIGSEGV →
    #      worker socket closes mid-serialize → master's unserialize() fails.
    #
    # v11.0 FIX: route everything to /Rtmp (local ext4, no NFS cache weirdness):
    #   Master session:  /Rtmp/biome_<user>/nimble_compile/session_<pid>/
    #   PSOCK workers:   /Rtmp/biome_<user>/nimble_compile/worker_<pid>/
    # Each process has ITS OWN subdir → zero parent-dir contention.
    # Compile artifacts are ephemeral (regenerated every session) — local-only OK.
    # ══════════════════════════════════════════════════════════════════════
    # ══════════════════════════════════════════════════════════════════════
    # v11.2 [H1-H2]: NIMBLE — OMP thread cap only (no compile-dir routing)
    # ══════════════════════════════════════════════════════════════════════
    # NIMBLE compile directory is handled automatically via tempdir(), which
    # is /Rtmp/RtmpXXXXXX per R session (driven by TMPDIR=/Rtmp in Renviron).
    # Previous v11.0/v11.1 set options(nimble.dirName) which NIMBLE never
    # reads — confirmed by grep on nimble-dev/nimble source. Removed in v11.2.
    # We still cap OMP threads here for multi-chain safety.
    # ══════════════════════════════════════════════════════════════════════
    if ((isNamespaceLoaded("nimble") || isNamespaceLoaded("nimbleHMC")) &&
        !isTRUE(.biome_env$shared_env$.nimble_hook_done)) tryCatch({
      # Cap threads for multi-chain safety (4 chains x 4 threads = 16 = VM cap)
      bt <- .biome_env$shared_env$last_threads
      nimble_threads <- max(2L, min(4L, as.integer(bt)))

      # NIMBLE uses Eigen via OMP for dense linear algebra in derived models.
      # Cap OMP threads conservatively when NIMBLE is loaded.
      Sys.setenv(OMP_NUM_THREADS = as.character(nimble_threads))

      .biome_env$shared_env$.nimble_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("NIMBLE [tempdir/%d threads]", nimble_threads))
      if (interactive()) {
        message(sprintf(paste0(.C_GREEN,
          "\U0001F9EA BIOME-CALC: NIMBLE compile dir -> %s (per-process tempdir).\n",
          "   Thread cap: %d. Use biome_make_cluster() for multi-chain MCMC.",
          .C_RESET), file.path(tempdir(), "nimble_generatedCode"), nimble_threads))
      }
    }, error = function(e) NULL)

    # ══════════════════════════════════════════════════════════════════════
    # v11.2 [H4-H5]: TMB/glmmTMB — OMP thread cap only
    # ══════════════════════════════════════════════════════════════════════
    # Sys.setenv(TMB_COMPILE_DIR) was phantom (TMB never reads it) — removed.
    # TMB::compile() compiles in the current working directory by default;
    # users should setwd() to a scratch dir if needed, or pass `dir=` to
    # TMB::compile(). options(TMB.threads) IS real — kept.
    # ══════════════════════════════════════════════════════════════════════
    if ((isNamespaceLoaded("TMB") || isNamespaceLoaded("glmmTMB")) &&
        !isTRUE(.biome_env$shared_env$.tmb_hook_done)) tryCatch({
      bt <- .biome_env$shared_env$last_threads
      tmb_threads <- max(1L, min(4L, as.integer(bt)))
      options(TMB.threads = tmb_threads)
      tmb_label <- if (isNamespaceLoaded("glmmTMB")) "TMB+glmmTMB" else "TMB"
      .biome_env$shared_env$.tmb_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("%s [%d threads]", tmb_label, tmb_threads))
    }, error = function(e) NULL)

    # ══════════════════════════════════════════════════════════════════════
    # v11.2 [H9-H10] + v11.3 [W9]: rstan / cmdstanr / brms — REAL options only
    # ══════════════════════════════════════════════════════════════════════
    # Kept:   options(cmdstanr_output_dir)  — REAL (cmdstanr/R/options.R:27)
    #         options(brms.file_refit)      — REAL (brms/R/brm.R:469)
    #         options(mc.cores)             — REAL (base R)
    # Removed: options(rstan.auto_write)    — PHANTOM; rstan uses its own
    #         rstan_options() storage, not base::options(). Users who want
    #         auto_write should call rstan::rstan_options(auto_write = TRUE)
    #         after loading rstan — we can't do it here because the option
    #         doesn't exist until rstan is attached (not just namespaced).
    # Removed: Sys.setenv(STAN_TMPDIR)      — PHANTOM; Stan doesn't read this.
    #
    # v11.3 [W9]: separate hook-done flags per package so late-loaded
    # packages still get their routing applied. Previous unified flag
    # .stan_hook_done caused e.g. brms to miss options() if loaded after
    # cmdstanr had already triggered the block.
    # ══════════════════════════════════════════════════════════════════════
    if (ENABLE_STAN_OPT) {
      # Pre-compute shared resources used by all three blocks
      stan_tmp <- file.path(user_tmp_root, "stan_compile",
                            paste0("session_", Sys.getpid()))
      if (!dir.exists(stan_tmp)) tryCatch(dir.create(stan_tmp, recursive = TRUE,
                                             showWarnings = FALSE, mode = "0700"),
                                           error = function(e) NULL)
      bt <- .biome_env$shared_env$last_threads
      stan_cores <- max(1L, min(4L, as.integer(bt / 2)))

      # cmdstanr block (independent flag)
      if (isNamespaceLoaded("cmdstanr") &&
          !isTRUE(.biome_env$shared_env$.cmdstanr_hook_done)) tryCatch({
        options(cmdstanr_output_dir = stan_tmp)
        options(mc.cores = stan_cores)
        .biome_env$shared_env$.cmdstanr_hook_done <- TRUE
        msg_parts <- c(msg_parts, sprintf("cmdstanr [LocalDisk/cores=%d]", stan_cores))
      }, error = function(e) sys_log("CmdstanrHook", "FAIL", e$message))

      # brms block (independent flag)
      if (isNamespaceLoaded("brms") &&
          !isTRUE(.biome_env$shared_env$.brms_hook_done)) tryCatch({
        options(brms.file_refit = "on_change")
        options(mc.cores = stan_cores)
        .biome_env$shared_env$.brms_hook_done <- TRUE
        msg_parts <- c(msg_parts, sprintf("brms [cores=%d]", stan_cores))
      }, error = function(e) sys_log("BrmsHook", "FAIL", e$message))

      # rstan block (independent flag) — auto_write is deferred to attach event
      if (isNamespaceLoaded("rstan") &&
          !isTRUE(.biome_env$shared_env$.rstan_hook_done)) tryCatch({
        options(mc.cores = stan_cores)
        # auto_write via rstan_options() can only fire after ATTACH, not ns-load.
        # Register a package-attach hook exactly once.
        if (!isTRUE(.biome_env$shared_env$.rstan_auto_write_hook)) {
          setHook(packageEvent("rstan", "attach"), function(...) {
            tryCatch(rstan::rstan_options(auto_write = TRUE),
                     error = function(e) NULL)
          }, action = "append")
          .biome_env$shared_env$.rstan_auto_write_hook <- TRUE
        }
        .biome_env$shared_env$.rstan_hook_done <- TRUE
        msg_parts <- c(msg_parts, sprintf("rstan [cores=%d]", stan_cores))
      }, error = function(e) sys_log("RstanHook", "FAIL", e$message))
    }

    # ══════════════════════════════════════════════════════════════════════
    # v11.0 [N8]: BRISC / spNNGP / ranger — OMP thread cap
    # These packages use OpenMP DIRECTLY (not via BLAS), so OPENBLAS_NUM_THREADS
    # doesn't affect them. They check their own n.omp.threads argument.
    # We can't intercept per-call, but we can set option defaults they pick up.
    # ══════════════════════════════════════════════════════════════════════
    if ((isNamespaceLoaded("BRISC") || isNamespaceLoaded("spNNGP") ||
         isNamespaceLoaded("ranger")) &&
        !isTRUE(.biome_env$shared_env$.omp_pkg_hook_done)) tryCatch({
      bt <- .biome_env$shared_env$last_threads
      omp_cap <- max(1L, min(8L, as.integer(bt)))
      # These are READ by the packages if set via Sys.setenv before the call
      Sys.setenv(OMP_NUM_THREADS = as.character(omp_cap))
      # ranger: use default num.threads = all cores unless user sets -1
      options(ranger.num.threads = omp_cap)
      pkgs <- c(if (isNamespaceLoaded("BRISC")) "BRISC",
                if (isNamespaceLoaded("spNNGP")) "spNNGP",
                if (isNamespaceLoaded("ranger")) "ranger")
      .biome_env$shared_env$.omp_pkg_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("%s [OMP=%d]", paste(pkgs, collapse="+"), omp_cap))
    }, error = function(e) NULL)

    # ══════════════════════════════════════════════════════════════════════
    # v11.0 [N11]: rJava — DYNAMIC heap (replaces hardcoded -Xmx4g)
    # ══════════════════════════════════════════════════════════════════════
    if (isNamespaceLoaded("rJava") &&
        !isTRUE(.biome_env$shared_env$.rjava_hook_done)) tryCatch({
      # Scale heap with user's RAM quota: 25% of quota, min 2GB, max 16GB.
      # Java large-heap causes long GC pauses, so cap at 16GB.
      java_heap_gb <- max(2L, min(16L, as.integer(floor(qr * 0.25))))
      options(java.parameters = sprintf("-Xmx%dg", java_heap_gb))
      # If rJava is not yet initialized, options() will take effect on first .jinit()
      # If already initialized, new heap size won't apply — warn the user.
      if (exists(".jinit", envir = asNamespace("rJava"), inherits = FALSE)) {
        is_init <- tryCatch(rJava::.jinit(silent = TRUE), error = function(e) -1)
        if (isTRUE(is_init) && interactive()) {
          message(paste0(.C_GRAY,
            "   \u2139 rJava already initialized — heap change takes effect next session.",
            .C_RESET))
        }
      }
      .biome_env$shared_env$.rjava_hook_done <- TRUE
      msg_parts <- c(msg_parts, sprintf("rJava [Xmx%dg]", java_heap_gb))
    }, error = function(e) NULL)

    # ── chattr ──
    if (ENABLE_AI_ASSISTANT && isNamespaceLoaded("chattr") &&
        !isTRUE(.biome_env$shared_env$.chattr_hook_done)) tryCatch({
      options(chattr.model = AI_MODEL, chattr.provider = "ollama")
      .biome_env$shared_env$.chattr_hook_done <- TRUE
      msg_parts <- c(msg_parts, "Chattr")
    }, error = function(e) NULL)

    # ── Rcpp / devtools compile cache routing ──
    # v11.0 [N6]: Rcpp::sourceCpp uses tempdir() which inherits TMPDIR=/Rtmp ✓
    # No specific option needed, but we log the routing on first load.
    if (isNamespaceLoaded("Rcpp") &&
        !isTRUE(.biome_env$shared_env$.rcpp_hook_done)) tryCatch({
      rcpp_dir <- file.path(user_tmp_root, "rcpp_cache")
      if (!dir.exists(rcpp_dir)) dir.create(rcpp_dir, recursive = TRUE, showWarnings = FALSE)
      Sys.setenv(RCPP_CACHE_DIR = rcpp_dir)
      .biome_env$shared_env$.rcpp_hook_done <- TRUE
      msg_parts <- c(msg_parts, "Rcpp [LocalDisk]")
    }, error = function(e) NULL)

    if (length(msg_parts) > 0 && interactive()) {
      message(paste0(.C_GREEN, "   \U0001F680 BIOME-CALC: Engines Initialized: ",
                     paste(msg_parts, collapse=", "), .C_RESET))
    }
  }

  # ══════════════════════════════════════════════════════════════════════════
  # Smart I/O — v11.3 [W6]: split into two dedicated wrappers
  # ──────────────────────────────────────────────────────────────────────────
  # Previous unified .biome_smart_io dispatched on sys.call()[1] string match.
  # Problems:
  #   (a) Infinite-recursion risk: fallback `utils::read.csv(file, ...)` re-
  #       resolves to the wrapper binding, causing stack overflow if
  #       .biome_env$original_read_csv got cleared.
  #   (b) sys.call() dispatch fragile: do.call(fread, ...) defeats detection.
  #   (c) fread signature mismatch: fread() takes (input, file, text, cmd, ...)
  #       not (file, ...). Users calling fread(cmd="zcat ...") got misrouted.
  #
  # v11.3 fix:
  #   - Two wrappers, each tied to ONE function, matching its real signature.
  #   - Original function captured via CLOSURE (not namespace lookup) — cannot
  #     recurse even if .biome_env is destroyed.
  #   - Explicit stop() on unexpected loss of original ref (fail fast).
  # ══════════════════════════════════════════════════════════════════════════
  if (ENABLE_SMART_IO) {

    # -------- read.csv wrapper --------
    if (requireNamespace("utils", quietly = TRUE)) tryCatch({
      ue <- as.environment("package:utils")
      if (exists("read.csv", envir = ue, inherits = FALSE)) {
        # Capture the CURRENT read.csv into the wrapper's closure env — this
        # is the ONLY reference the wrapper uses for delegation. No recursion,
        # ever, even if .biome_env is wiped mid-session.
        .biome_original_read_csv <- get("read.csv", envir = ue, inherits = FALSE)
        assign("original_read_csv", .biome_original_read_csv, envir = .biome_env)

        .biome_smart_read_csv <- local({
          .ref <- .biome_original_read_csv
          function(file, ...) {
            if (is.character(file) && length(file) == 1L) {
              pq <- paste0(file, ".parquet")
              if (file.exists(pq) && interactive() &&
                  requireNamespace("arrow", quietly = TRUE)) {
                message("BIOME-IO: Using .parquet accelerator (read.csv -> arrow)")
                return(arrow::read_parquet(pq))
              }
            }
            # Defensive: .ref is captured in our closure env — always present
            # unless someone actively destroys it (rm on closure env). We fail
            # fast with a clear error rather than recursing or returning bad
            # data. NO infinite-recursion path exists by design.
            if (!exists(".ref", inherits = FALSE) ||
                is.null(.ref) || !is.function(.ref)) {
              stop("BIOME-CALC: read.csv wrapper lost its original reference; ",
                   "cannot delegate. Reinstall the profile.", call. = FALSE)
            }
            .ref(file, ...)
          }
        })
        was_locked <- tryCatch(bindingIsLocked("read.csv", ue),
                               error = function(e) FALSE)
        if (was_locked) unlockBinding("read.csv", ue)
        assign("read.csv", .biome_smart_read_csv, envir = ue)
        if (was_locked) lockBinding("read.csv", ue)
        sys_log("SmartIO", "OK", "read.csv wrapped (utils)")
      }
    }, error = function(e) sys_log("SmartIO", "FAIL", paste("read.csv:", e$message)))

    # -------- fread wrapper (deferred to data.table load) --------
    # Hook fires when package:data.table is attached; captures fread and wraps
    # with its REAL signature (input, file, text, cmd, ...).
    setHook(packageEvent("data.table", "onLoad"), function(...) {
      tryCatch({
        de <- as.environment("package:data.table")
        if (!exists("fread", envir = de, inherits = FALSE)) return(invisible())
        .biome_original_fread <- get("fread", envir = de, inherits = FALSE)
        assign("original_fread", .biome_original_fread, envir = .biome_env)

        .biome_smart_fread <- local({
          .ref <- .biome_original_fread
          function(input = "", file = NULL, text = NULL, cmd = NULL, ...) {
            # Parquet sidecar detection: try input if it's a path, then file=
            target <- NULL
            if (is.character(input) && length(input) == 1L && nzchar(input) &&
                file.exists(input)) target <- input
            if (is.null(target) && !is.null(file) && is.character(file) &&
                length(file) == 1L && file.exists(file)) target <- file
            if (!is.null(target)) {
              pq <- paste0(target, ".parquet")
              if (file.exists(pq) && interactive() &&
                  requireNamespace("arrow", quietly = TRUE)) {
                message("BIOME-IO: Using .parquet accelerator (fread -> arrow)")
                return(arrow::read_parquet(pq))
              }
            }
            if (!exists(".ref", inherits = FALSE) ||
                is.null(.ref) || !is.function(.ref)) {
              stop("BIOME-CALC: fread wrapper lost its original reference; ",
                   "cannot delegate.", call. = FALSE)
            }
            .ref(input = input, file = file, text = text, cmd = cmd, ...)
          }
        })
        was_locked <- tryCatch(bindingIsLocked("fread", de),
                               error = function(e) FALSE)
        if (was_locked) unlockBinding("fread", de)
        assign("fread", .biome_smart_fread, envir = de)
        if (was_locked) lockBinding("fread", de)
        sys_log("SmartIO", "OK", "fread wrapped (data.table)")
      }, error = function(e) sys_log("SmartIO", "FAIL", paste("fread:", e$message)))
    })
  }

  # ── CALLBACKS ──
  .biome_env$shared_env$last_update <- 0
  .biome_env$deferred_pkg_init <- deferred_pkg_init
  .biome_env$deferred_pkg_hooks <- deferred_pkg_hooks
  update_resources(quiet = TRUE)
  tryCatch({
    addTaskCallback(function(...) {
      try({
        deferred_pkg_init()
        deferred_pkg_hooks()
        update_resources(quiet = TRUE)
      }, silent = TRUE)
      TRUE
    }, name = "biome_resource_monitor")
    if (!"biome_resource_monitor" %in% getTaskCallbackNames()) {
      sys_log("Callback", "FAIL", "addTaskCallback returned but name not found")
    }
  }, error = function(e) {
    sys_log("Callback", "FAIL", paste("addTaskCallback failed:", e$message))
    # v11.3 [W10]: two fallback paths.
    # (a) RStudio-specific sessionInit hook — runs once when rsession fully loaded.
    setHook("rstudio.sessionInit", function(newSession) {
      if (!.biome_env$shared_env$deferred_done) {
        tryCatch(deferred_pkg_init(), error = function(e)
          sys_log("DeferredFallback", "FAIL", e$message))
      }
      tryCatch(deferred_pkg_hooks(), error = function(e) NULL)
      tryCatch(update_resources(quiet = TRUE), error = function(e) NULL)
    }, action = "append")
    # (b) Non-RStudio fallback (plain R / Rscript) — run init/hooks NOW so
    # base guards are at least installed. Without this path, Rscript users
    # (e.g. Martina's batch MCMC runs) would get zero guards if
    # addTaskCallback ever failed.
    is_rstudio <- nzchar(Sys.getenv("RSTUDIO", "")) ||
                  identical(Sys.getenv("RSTUDIO_USER_IDENTITY"), "")
    if (!is_rstudio) {
      tryCatch({
        deferred_pkg_init()
        deferred_pkg_hooks()
        sys_log("Callback", "OK", "Non-RStudio immediate fallback executed")
      }, error = function(e2) sys_log("ImmediateFallback", "FAIL", e2$message))
    }
  })


  # ══════════════════════════════════════════════════════════════════════════
  # PERSISTENT TOOLS — attached to tools:biome_calc
  # ══════════════════════════════════════════════════════════════════════════
  tool_env_name <- "tools:biome_calc"
  tool_env <- tryCatch({
    pos <- match(tool_env_name, search())
    if (!is.na(pos)) as.environment(pos) else attach(NULL, name = tool_env_name)
  }, error = function(e) attach(NULL, name = tool_env_name))

  .fmt_eng <- function(name, enabled, loaded) {
      if (!enabled) return(paste0(.C_GRAY, "[\u2717] ", name, .C_RESET))
      if (loaded)   return(paste0(.C_GREEN, "[\u2713] ", name, .C_RESET))
      return(paste0(.C_CYAN, "[\u25CB] ", name, .C_RESET))
  }

  assign("status", function() {
    update_resources(quiet = FALSE)
    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC v", .biome_env$VERSION, " | System Dashboard ===", .C_RESET, "\n"))
    cat(sprintf("  RAM Quota:    %d GB (fair-share)\n", .biome_env$shared_env$last_quota))
    cat(sprintf("  vCPU Cores:   %d (Allocated)\n", .biome_env$shared_env$last_cores))
    cat(sprintf("  Active Users: %d\n", get_active_users()))
    tmp_str <- tryCatch({
      df <- system2("df", args = c("-P", "-BG", RTMP_PATH), stdout = TRUE, stderr = FALSE)
      if (length(df) >= 2) {
         p <- strsplit(df[2], "\\s+")[[1]]
         sprintf("%s free of %s (%s used | Local Disk | Warn @%d%%)",
                 p[4], p[2], p[5], TMP_WARN_PCT)
      } else "Unknown"
    }, error = function(e) "Unknown")
    cat(sprintf("  /Rtmp Disk:   %s\n", tmp_str))
    cat(sprintf("  Tmp Cleanup:  Files >%d hours\n", .biome_env$shared_env$timeout_hours))
    ct <- Sys.getenv("OPENBLAS_CORETYPE", "auto")
    cat(sprintf("  BLAS Type:    %s\n", ct))
    cat(sprintf("  User TMP:     %s\n", .biome_env$USER_TMP_ROOT))
    cat(paste0("\n  ", .C_BOLD, "Engines & Services:", .C_RESET, "\n"))
    r_sys <- .fmt_eng("Resource Mgmt", ENABLE_RESOURCE_MGMT, TRUE)
    r_sio <- .fmt_eng("Smart I/O", ENABLE_SMART_IO, TRUE)
    r_tmp <- .fmt_eng("Tmp Cleanup", ENABLE_TMP_CLEANUP, TRUE)
    r_ai  <- .fmt_eng(paste0("AI (", AI_MODEL, ")"), ENABLE_AI_ASSISTANT, .biome_env$shared_env$ai_active)
    r_ter <- .fmt_eng("Terra (Geospatial)", ENABLE_TERRA_OPT, isNamespaceLoaded("terra"))
    r_arr <- .fmt_eng("Arrow (Parquet)", ENABLE_ARROW_OPT, isNamespaceLoaded("arrow"))
    r_fut <- .fmt_eng("Future (Parallel)", ENABLE_FUTURE_OPT, isNamespaceLoaded("future"))
    r_gee <- .fmt_eng("RGEE (Earth Engine)", ENABLE_RGEE_OPT, isNamespaceLoaded("rgee"))
    r_tf  <- .fmt_eng("Keras/TF (CPU)", ENABLE_TF_MGMT, isNamespaceLoaded("tensorflow"))
    r_nim <- .fmt_eng("NIMBLE [LocalDisk]", TRUE,
                       isNamespaceLoaded("nimble") || isNamespaceLoaded("nimbleHMC"))
    r_tmb <- .fmt_eng("TMB/glmmTMB",  TRUE,
                       isNamespaceLoaded("TMB") || isNamespaceLoaded("glmmTMB"))
    r_stn <- .fmt_eng("Stan/brms", ENABLE_STAN_OPT,
                       isNamespaceLoaded("rstan") || isNamespaceLoaded("cmdstanr") ||
                       isNamespaceLoaded("brms"))
    cat(sprintf("  %s  %s  %s\n", r_sys, r_sio, r_tmp))
    cat(sprintf("  %s  %s  %s\n", r_ter, r_arr, r_gee))
    cat(sprintf("  %s  %s  %s\n", r_ai, r_fut, r_tf))
    cat(sprintf("  %s  %s  %s\n", r_nim, r_tmb, r_stn))
    cat(paste0("\n  ", .C_GRAY, "[\u2713]=Active  [\u25CB]=Lazy(Standby)  [\u2717]=Disabled", .C_RESET, "\n"))
    invisible(NULL)
  }, envir = tool_env)

  assign("ask_ai", function(prompt, model=AI_MODEL) {
    if (!.biome_env$shared_env$ai_active) stop("Ollama service is not responding on port 11434.")
    message(paste0(.C_CYAN, "Thinking (", model, ")...", .C_RESET))
    tf <- tempfile(pattern = "ollama_req_", fileext = ".json")
    on.exit(unlink(tf), add = TRUE)
    if (requireNamespace("jsonlite", quietly=TRUE)) {
      body <- jsonlite::toJSON(list(model=model, prompt=prompt, stream=FALSE), auto_unbox=TRUE)
      writeLines(as.character(body), tf)
    } else {
      clean_prompt <- gsub('"', '\\\\"', prompt)
      clean_prompt <- gsub('\n', '\\\\n', clean_prompt)
      json_body <- sprintf('{"model": "%s", "prompt": "%s", "stream": false}', model, clean_prompt)
      writeLines(json_body, tf)
    }
    res <- suppressWarnings(system2("curl", args = c(
      "-s", "-m", as.character(AI_CURL_TIMEOUT), "--connect-timeout", "5",
      "-X", "POST", OLLAMA_API, "-d", paste0("@", tf)
    ), stdout = TRUE, stderr = FALSE))
    if (length(res) > 0) {
      if (requireNamespace("jsonlite", quietly=TRUE)) {
        out <- tryCatch(jsonlite::fromJSON(paste(res, collapse="")), error=function(e) NULL)
        if (!is.null(out$response)) cat(paste0("\n", .C_GREEN, "\U0001F916 ", model, ":", .C_RESET, "\n", out$response, "\n"))
        else cat("Error: Invalid JSON response from AI.\n")
      }
    } else cat("No response from AI service (timeout or connection refused).\n")
  }, envir = tool_env)

  # v11.0 [N3]: biome_make_cluster with outfile support
  assign("biome_make_cluster", function(workers = NULL, worker_threads = 1L,
                                         outfile = NULL, ...) {
    .biome_make_cluster_impl(workers = workers, worker_threads = worker_threads,
                              outfile = outfile, ...)
  }, envir = tool_env)

  # v11.0 [N9]: biome_future_plan — picks best backend for workload
  assign("biome_future_plan", function(workers = NULL, strategy = c("auto", "cluster", "callr", "sequential")) {
    strategy <- match.arg(strategy)
    if (!requireNamespace("future", quietly = TRUE)) {
      stop("Package 'future' is required. install.packages('future')")
    }
    if (is.null(workers)) {
      workers <- max(1L, .biome_env$shared_env$last_cores - 1L)
    }
    workers <- as.integer(workers)

    if (strategy == "auto") {
      # Auto-pick: if NIMBLE or Stan is loaded, callr is safer (fresh R process
      # per task, no socket to corrupt during long compilations).
      # Otherwise cluster (faster startup, shared state).
      if (isNamespaceLoaded("nimble") || isNamespaceLoaded("rstan") ||
          isNamespaceLoaded("cmdstanr") || isNamespaceLoaded("brms")) {
        strategy <- "callr"
      } else {
        strategy <- "cluster"
      }
    }

    if (strategy == "sequential") {
      future::plan(future::sequential)
      message(paste0(.C_CYAN, "BIOME-CALC: future::plan = sequential (no parallelism)", .C_RESET))
      return(invisible("sequential"))
    } else if (strategy == "callr") {
      if (!requireNamespace("future.callr", quietly = TRUE)) {
        message(paste0(.C_YELLOW,
          "BIOME-CALC: future.callr not installed. Falling back to cluster.\n",
          "  Install: install.packages('future.callr')", .C_RESET))
        strategy <- "cluster"
      } else {
        future::plan(future.callr::callr, workers = workers)
        message(sprintf(paste0(.C_GREEN,
          "\U0001F680 BIOME-CALC: future::plan = callr, %d workers (fresh R per task, MCMC-safe)",
          .C_RESET), workers))
        return(invisible("callr"))
      }
    }

    if (strategy == "cluster") {
      cl <- .biome_make_cluster_impl(workers = workers, worker_threads = 1L)
      future::plan(future::cluster, workers = cl)
      message(sprintf(paste0(.C_GREEN,
        "\U0001F680 BIOME-CALC: future::plan = cluster, %d PSOCK workers (BIOME_WORKER_MODE=1)",
        .C_RESET), workers))
      return(invisible("cluster"))
    }
  }, envir = tool_env)

  # v11.0 [N10]: Worker log diagnostics
  assign("biome_worker_diagnostics", function(n = 5, since_hours = 24) {
    cl_dir <- file.path(.biome_env$USER_TMP_ROOT, "cluster_logs")
    if (!dir.exists(cl_dir)) {
      message("No cluster_logs/ directory yet. biome_make_cluster() creates one on first call.")
      return(invisible(NULL))
    }
    logs <- list.files(cl_dir, pattern = "^psock_.*\\.log$", full.names = TRUE)
    if (length(logs) == 0) {
      message("No PSOCK worker logs in ", cl_dir)
      return(invisible(NULL))
    }
    li <- file.info(logs)
    recent_idx <- which(as.numeric(difftime(Sys.time(), li$mtime, units = "hours")) <= since_hours)
    if (length(recent_idx) == 0) {
      message(sprintf("No worker logs in last %d hours.", since_hours))
      return(invisible(NULL))
    }
    logs <- logs[recent_idx]
    li <- li[recent_idx, , drop = FALSE]
    # Sort by mtime desc, take last n
    ord <- order(li$mtime, decreasing = TRUE)
    logs <- logs[ord][seq_len(min(n, length(logs)))]

    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC Worker Log Diagnostics ===", .C_RESET, "\n"))
    cat(sprintf("  Directory: %s\n", cl_dir))
    cat(sprintf("  Showing %d most recent logs (last %d hours)\n\n", length(logs), since_hours))
    for (lg in logs) {
      sz <- file.info(lg)$size
      cat(paste0(.C_BOLD, basename(lg), .C_RESET,
                 sprintf(" (%.1f KB, mtime: %s)\n", sz / 1024,
                         format(file.info(lg)$mtime, "%Y-%m-%d %H:%M:%S"))))
      # Show last 30 lines
      txt <- tryCatch(tail(readLines(lg, warn = FALSE), 30), error = function(e) "")
      if (length(txt) > 0) {
        # Highlight errors/crashes
        for (line in txt) {
          if (grepl("Error|error|SIGSEGV|SIGKILL|fatal|unserialize|crash", line,
                    ignore.case = FALSE)) {
            cat(paste0("  ", .C_RED, line, .C_RESET, "\n"))
          } else {
            cat(paste0("  ", .C_GRAY, line, .C_RESET, "\n"))
          }
        }
      }
      cat("\n")
    }
    invisible(logs)
  }, envir = tool_env)

  assign("biome_tutorial", function() {
    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC v", VERSION, ": User Guide ===", .C_RESET, "\n"))
    cat("This system automatically optimizes resources. Services are 'Lazy' [\u25CB] by default\n")
    cat("and become 'Active' [\u2713] the moment you use them.\n\n")
    cat(paste0(.C_BOLD, "1. Resource Management (Auto)", .C_RESET, "\n"))
    cat("   - RAM & CPU are dynamically allocated based on active users.\n")
    cat("   - Check your current quota anytime: status()\n\n")
    cat(paste0(.C_BOLD, "2. Smart I/O (Auto-Parquet)", .C_RESET, "\n"))
    cat("   - If 'data.csv.parquet' exists, it replaces 'data.csv' automatically.\n\n")
    cat(paste0(.C_BOLD, "3. AI Assistant", .C_RESET, "\n"))
    cat(sprintf("   - ask_ai(\"How do I run a PERMANOVA?\")  [Model: %s]\n\n", AI_MODEL))
    cat(paste0(.C_BOLD, "4. Geospatial (Terra/RGEE/sf)", .C_RESET, "\n"))
    cat("   - library(terra); library(rgee) \u2014 auto-threads & cache.\n")
    cat("   - All GDAL/raster temp on local /Rtmp (fast, no RAM cost).\n\n")
    cat(paste0(.C_BOLD, "5. Parallel MCMC (NIMBLE/Stan/TMB) \u2014 v11.0 ROUTE", .C_RESET, "\n"))
    cat("   - ALWAYS use biome_make_cluster(), NEVER bare parallel::makeCluster():\n")
    cat(paste0("       ", .C_GREEN, "cl <- biome_make_cluster(workers = 4, worker_threads = 1L)", .C_RESET, "\n"))
    cat(paste0("       ", .C_GREEN, "on.exit(parallel::stopCluster(cl), add = TRUE)", .C_RESET, "\n"))
    cat("       result <- parLapply(cl, 1:4, run_MCMC_fun, ...)\n")
    cat("   - biome_make_cluster() does:\n")
    cat("       * Caps BLAS/OMP threads per worker (no oversubscription)\n")
    cat("       * Routes NIMBLE/TMB/Stan compile to LOCAL /Rtmp (not NFS)\n")
    cat("       * Captures worker stderr to cluster_logs/ (post-mortem)\n")
    cat("   - For alternative backends:\n")
    cat(paste0("       ", .C_GREEN, "biome_future_plan(workers=4, strategy='callr')", .C_RESET,
               "  # safer for 16h+ MCMC\n\n"))
    cat(paste0(.C_BOLD, "6. /Rtmp Local Disk (v11.0)", .C_RESET, "\n"))
    cat(sprintf("   - /Rtmp is a dedicated %dGB local disk (NOT RAM, NOT OS /tmp, NOT NFS).\n", TMP_DISK_GB))
    cat(sprintf("   - Advisory warning at %d%% usage. No auto-redirect needed.\n", TMP_WARN_PCT))
    cat("   - v11.0 routes ALL scratch to /Rtmp:\n")
    cat("       * NIMBLE/TMB/Stan compile, Rcpp, terra/raster/stars, keras, ggplot cache\n")
    cat("   - NFS $HOME keeps ONLY: packages (~/R), RData backups, your scripts & results.\n")
    cat("   - Diagnostic: biome_plot_budget()\n\n")
    cat(paste0(.C_BOLD, "7. Post-mortem for worker crashes", .C_RESET, "\n"))
    cat("   - biome_worker_diagnostics()                 \u2014 last 5 crashes, 24h\n")
    cat("   - biome_worker_diagnostics(n=10, since_hours=72)\n\n")
    cat(paste0(.C_BOLD, "8. Ggplot Optimization", .C_RESET, "\n"))
    cat("   - ragg backend auto-enabled (2-4x faster than cairo).\n")
    cat("   - Viridis colorblind-safe palette as default.\n\n")
    cat(paste0(.C_BOLD, "9. Safely Saving & Loading Work", .C_RESET, "\n"))
    cat("   - Save: biome_save_session()       (NFS $HOME, persistent)\n")
    cat("   - Load: biome_load_session()\n")
    cat("   - NOTE: /Rtmp is LOCAL to this VM \u2014 DO NOT save final results there.\n")
    cat("   - RStudio will NOT auto-save your data on logout!\n\n")
    cat(paste0(.C_GRAY, "   Tip: sessioninfo::session_info() for full R/BLAS/LAPACK details.", .C_RESET, "\n"))
    cat(sprintf("  Support: %s\n", "%%BIOME_CONTACT%%"))
  }, envir = tool_env)

  assign("biome_save_session", function(file_name = "biome_session_backup.RData") {
    target <- file.path(Sys.getenv("HOME"), file_name)
    EXCLUDE_CLASSES <- c("SpatRaster", "SpatVector", "stars", "RasterStack",
                          "RasterBrick", "ff", "bigmemory")
    ws_objects <- ls(envir = .GlobalEnv)
    ws_size <- 0; excluded_count <- 0L
    for (obj_name in ws_objects) {
      obj <- tryCatch(get(obj_name, envir = .GlobalEnv, inherits = FALSE), error = function(e) NULL)
      if (!is.null(obj)) {
        if (inherits(obj, EXCLUDE_CLASSES)) { excluded_count <- excluded_count + 1L }
        else { ws_size <- ws_size + tryCatch(as.numeric(object.size(obj)), error = function(e) 0) }
      }
    }
    ws_gb <- ws_size / 1024^3
    if (ws_gb > 1.5) {
      message(sprintf(paste0(.C_YELLOW,
        "\n\u26a0\ufe0f  CRITICAL WARNING: Workspace is %.1f GB. Loading this in the future may crash the RStudio Web Interface!",
        "\n   Please use saveRDS() for large dataframes instead of biome_save_session().",
        "\n   %d spatial objects excluded (file-backed).",
        .C_RESET), ws_gb, excluded_count))
    }
    tryCatch({
      df_home <- system2("df", args = c("-P", "-BG", Sys.getenv("HOME")),
                          stdout = TRUE, stderr = FALSE)
      if (length(df_home) >= 2) {
        free_gb <- as.numeric(gsub("[^0-9]", "", strsplit(trimws(df_home[2]), "\\s+")[[1]][4]))
        if (!is.na(free_gb) && free_gb < max(ws_gb * 2, 5)) {
          warning(sprintf(paste0(.C_RED,
            "\n\u26a0\ufe0f  LOW DISK: Only ~%d GB free on HOME. Save may fail!", .C_RESET),
            as.integer(free_gb)), call. = FALSE, immediate. = TRUE)
        }
      }
    }, error = function(e) NULL)
    message(paste0("\n\U0001f4be Saving to: ", target, " ..."))
    tryCatch({
      save.image(file = target)
      final_size <- tryCatch(file.info(target)$size / 1024^2, error = function(e) NA)
      if (!is.na(final_size)) {
        message(sprintf(paste0(.C_GREEN, "\U00002705 Done (%.1f MB). You may now safely log out.", .C_RESET), final_size))
      }
    }, error = function(e) {
      message(sprintf(paste0(.C_RED, "\n\u274c SAVE FAILED: %s", .C_RESET), e$message))
    })
  }, envir = tool_env)

  assign("biome_load_session", function(file_name = "biome_session_backup.RData") {
    target <- file.path(Sys.getenv("HOME"), file_name)
    if (!file.exists(target)) {
      warning(paste0(.C_RED, "\u26a0\ufe0f No backup found at ", target, .C_RESET, "\n"),
              call. = FALSE, immediate. = TRUE)
      return(invisible(NULL))
    }
    file_mb <- tryCatch(file.info(target)$size / 1024^2, error = function(e) NA)
    if (!is.na(file_mb)) {
      ram_avail_mb <- tryCatch({
        mi <- readLines("/proc/meminfo", warn = FALSE)
        al <- grep("^MemAvailable:", mi, value = TRUE)
        if (length(al) > 0) as.numeric(sub(".*:\\s+(\\d+).*", "\\1", al[1])) / 1024
        else Inf
      }, error = function(e) Inf)
      if (is.finite(ram_avail_mb) && file_mb > ram_avail_mb * 0.5) {
        warning(sprintf(paste0(.C_RED,
          "\n\u26a0\ufe0f  DANGER: File is %.1f GB but only %.1f GB RAM available.",
          "\n   Consider: env <- new.env(); load('%s', envir=env); ls(env)", .C_RESET),
          file_mb / 1024, ram_avail_mb / 1024, target),
          call. = FALSE, immediate. = TRUE)
      }
    }
    message(paste0("\n\U0001f504 Loading workspace from: ", target, " ..."))
    tryCatch({
      before_objs <- ls(envir = .GlobalEnv)
      load(file = target, envir = .GlobalEnv)
      after_objs <- ls(envir = .GlobalEnv)
      message(sprintf(paste0(.C_GREEN, "\U00002705 Workspace restored! %d objects loaded.", .C_RESET),
                       length(after_objs)))
    }, error = function(e) {
      message(sprintf(paste0(.C_RED, "\n\u274c LOAD FAILED: %s", .C_RESET), e$message))
    })
  }, envir = tool_env)

  assign("biome_plot_budget", function() {
    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC Plot Budget ===", .C_RESET, "\n"))
    tmp_info <- tryCatch(
      system2("df", args = c("-P", "-BG", RTMP_PATH), stdout = TRUE, stderr = FALSE),
      error = function(e) NULL
    )
    if (!is.null(tmp_info) && length(tmp_info) >= 2) {
      p <- strsplit(trimws(tmp_info[2]), "\\s+")[[1]]
      cat(sprintf("  /Rtmp Disk:   Total: %s | Used: %s | Free: %s (%s)\n", p[2], p[3], p[4], p[5]))
    }
    backend <- if (requireNamespace("ragg", quietly = TRUE)) "ragg (fast)" else "cairo (default)"
    cat(sprintf("  Render backend: %s\n", backend))
    cat(sprintf("  Tmp storage:    Local Disk /Rtmp (no RAM cost)\n"))
    cat(sprintf("  R tempdir:      %s\n", tempdir()))
    user_root <- .biome_env$USER_TMP_ROOT
    if (dir.exists(user_root)) {
      sz <- sum(file.info(list.files(user_root, full.names = TRUE, recursive = TRUE, all.files = TRUE))$size, na.rm = TRUE)
      cat(sprintf("  Your tmp usage: ~%.1f MB\n", sz / 1024^2))
      # Per-subdir breakdown
      for (sub in c("nimble_compile", "tmb_compile", "stan_compile", "rcpp_cache",
                    "terra", "raster", "stars", "cluster_logs", "keras_cache", "plot_cache")) {
        d <- file.path(user_root, sub)
        if (dir.exists(d)) {
          fl <- list.files(d, full.names = TRUE, recursive = TRUE, all.files = TRUE)
          sz <- sum(file.info(fl)$size, na.rm = TRUE)
          if (sz > 0) cat(sprintf("    - %-20s ~%.1f MB (%d items)\n",
                                   sub, sz / 1024^2, length(fl)))
        }
      }
    }
    tmp_pct <- get_tmp_disk_use_pct()
    if (tmp_pct < TMP_WARN_PCT) {
      cat(paste0("  Status:         ", .C_GREEN, "OK", .C_RESET, "\n"))
    } else {
      cat(paste0("  Status:         ", .C_YELLOW,
                 sprintf("ADVISORY \u2014 /Rtmp at %d%% capacity", as.integer(tmp_pct)),
                 .C_RESET, "\n"))
    }
    invisible(NULL)
  }, envir = tool_env)

  assign("biome_help", function() {
    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC Helper ===", .C_RESET, "\n"))
    cat("  Commands:\n")
    cat(paste0("  ", .C_BOLD, "status()", .C_RESET, "                     - System Dashboard.\n"))
    cat(paste0("  ", .C_BOLD, "biome_tutorial()", .C_RESET, "             - Code examples.\n"))
    cat(paste0("  ", .C_BOLD, "biome_save_session()", .C_RESET, "         - Save data to $HOME (NFS).\n"))
    cat(paste0("  ", .C_BOLD, "biome_load_session()", .C_RESET, "         - Restore saved data.\n"))
    cat(paste0("  ", .C_BOLD, "biome_plot_budget()", .C_RESET, "          - /Rtmp disk breakdown per engine.\n"))
    cat(paste0("  ", .C_BOLD, "biome_make_cluster()", .C_RESET, "         - PSOCK cluster for MCMC.\n"))
    cat(paste0("  ", .C_BOLD, "biome_future_plan()", .C_RESET, "          - Set future::plan (auto/callr/cluster).\n"))
    cat(paste0("  ", .C_BOLD, "biome_worker_diagnostics()", .C_RESET, "   - Post-mortem of worker crashes.\n"))
    cat(paste0("  ", .C_BOLD, "ask_ai(txt)", .C_RESET, "                  - Ask AI.\n"))
    cat(paste0("  ", .C_BOLD, "biome_help()", .C_RESET, "                 - This message.\n"))
    cat(sprintf("\n  Support: %s\n", "%%BIOME_CONTACT%%"))
  }, envir = tool_env)

  assign("get_tmp_disk_use_pct", get_tmp_disk_use_pct, envir = tool_env)
  assign("biome_restore", function() { get("status", envir=as.environment("tools:biome_calc"))() }, envir = tool_env)
  assign("show_quota", function() { get("status", envir=as.environment("tools:biome_calc"))() }, envir = tool_env)

  # ── FINALIZATION ──
  setHook("rstudio.sessionInit", function(newSession) {
    if (newSession && interactive()) {
      tryCatch({
        cf <- file.path(Sys.getenv("HOME"), "ULTIMO_CRASH_RAM.txt")
        if (file.exists(cf)) {
           message(paste0("\n", .C_RED, " WARNING: Previous session killed by OOM ", .C_RESET))
           try(file.remove(cf), silent=TRUE)
        }
      }, error = function(e) NULL)

      bn <- "**********************************************************"
      message(paste0("\n", .C_CYAN, bn))
      message(sprintf("*** BIOME-CALC v%s (%s)%s***", VERSION, R_HOST,
                       paste(rep(" ", max(1, 37 - nchar(VERSION) - nchar(R_HOST))), collapse="")))
      message("*** Local-disk architecture: NIMBLE/TMB/Stan -> /Rtmp   ***")
      message("*** If you have any problem please write an e-mail to: ***")
      message(sprintf("*** %-52s ***", "%%BIOME_CONTACT%%"))
      message("*** Don't share your password with anyone...           ***")
      message(paste0(bn, .C_RESET))

      message(sprintf("\n   RAM Quota:  %-3d GB  (VM ~%dGB, full RAM available)",
                       .biome_env$shared_env$last_quota, VM_RAM_GB))
      message(sprintf("   vCPU:       %-3d / %d  (Adapts to active users)",
                       .biome_env$shared_env$last_cores, total_vcores))

      ct <- Sys.getenv("OPENBLAS_CORETYPE", "auto")
      cpuv <- tryCatch({
        ci <- readLines("/proc/cpuinfo", n = 5, warn = FALSE)
        vl <- grep("^vendor_id", ci, value = TRUE)[1]
        if (!is.na(vl)) trimws(sub(".*:\\s*", "", vl)) else "unknown"
      }, error = function(e) "unknown")
      message(sprintf("   BLAS:       CORETYPE=%s (vendor=%s, serial=%s)",
                       ct, cpuv, isTRUE(.biome_env$blas_is_serial)))

      tryCatch({
        ei <- extSoftVersion()
        blas_lib <- basename(La_library())
        lapack_ver <- ei[["LAPACK"]]
        if (is.null(lapack_ver) || !nzchar(lapack_ver)) lapack_ver <- "system"
        message(sprintf("   LAPACK:     %s (%s)", blas_lib, lapack_ver))
      }, error = function(e) NULL)

      tryCatch({
        df_out <- system2("df", args = c("-h", RTMP_PATH), stdout = TRUE, stderr = FALSE)
        if (length(df_out) >= 2) {
          p <- strsplit(trimws(df_out[2]), "\\s+")[[1]]
          message(sprintf("   /Rtmp:      %s free of %s (%s)", p[4], p[2], p[5]))
        }
      }, error = function(e) NULL)

      message(sprintf("   UserTmp:    %s", .biome_env$USER_TMP_ROOT))

      message(paste0("\n   ", .C_BOLD, "\U0001F680 Engines:", .C_RESET))
      r_sio <- .fmt_eng("SmartIO", ENABLE_SMART_IO, TRUE)
      r_ai  <- .fmt_eng("AI", ENABLE_AI_ASSISTANT, .biome_env$shared_env$ai_active)
      r_ter <- .fmt_eng("Terra", ENABLE_TERRA_OPT, isNamespaceLoaded("terra"))
      r_arr <- .fmt_eng("Arrow", ENABLE_ARROW_OPT, isNamespaceLoaded("arrow"))
      r_tf  <- .fmt_eng("Keras/TF", ENABLE_TF_MGMT, isNamespaceLoaded("tensorflow"))
      message(sprintf("   %s  %s  %s  %s  %s", r_sio, r_ai, r_ter, r_arr, r_tf))

      message("----------------------------------------------------------")
      message(paste0("   \U0001F4A1 Type ", .C_BOLD, "biome_help()", .C_RESET, " for commands."))
      message(paste0("   \U0001F4DA Type ", .C_BOLD, "biome_tutorial()", .C_RESET, " for MCMC examples."))
      message(paste0("   \U0001F4CA Type ", .C_BOLD, "status()", .C_RESET, " for resource quotas."))
      message(paste0("   \U0001F50D Type ", .C_BOLD, "biome_worker_diagnostics()", .C_RESET, " after worker crashes."))
      if (.biome_env$shared_env$ai_active) message(paste0("   \U0001F916 Try  ", .C_BOLD, 'ask_ai("Help me with R")', .C_RESET, "."))
      message(sprintf("   Startup: %.2fs", as.numeric(difftime(Sys.time(), .start_time, units="secs"))))
      message(paste0(.C_CYAN, bn, .C_RESET, "\n"))
    }
  }, action = "append")

  reg.finalizer(.biome_env, function(env) {
    tryCatch({ sys_log("Session", "END", sprintf("User: %s", curr_user)) }, error = function(e) NULL)
    # v11.3 [W8]: cleanup only real compile dirs (stan_compile is the only one
    # that writes per-session subdirs; nimble/tmb were phantom in v11.0-v11.2)
    tryCatch({
      for (sub in c("stan_compile")) {
        d <- file.path(.biome_env$USER_TMP_ROOT, sub, paste0("session_", Sys.getpid()))
        if (dir.exists(d)) unlink(d, recursive = TRUE, force = FALSE)
      }
    }, error = function(e) NULL)
  }, onexit = TRUE)

  sys_log("Profile", "OK", "Loaded successfully (v11.3)")
})
  }  # end of: if (!.biome_skip_main) { ...main block... }

  # Clean up the guard variable so it doesn't pollute the global namespace
  if (exists(".biome_skip_main", inherits = FALSE)) rm(.biome_skip_main)

}  # end of: else branch (full profile mode) — pairs with `if (worker_mode)` above

# === END ===
