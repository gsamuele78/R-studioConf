  message(sprintf(paste0(
    "\n=== BIOME-CALC v12 Compile Router (TEST) Loaded ===\n",
    "  Run ID: %s\n",
    "  Use biome_run_diagnostics() to inspect compile dirs.\n",
    "  Use .biome_get_compile_dir('nimble') for explicit routing.\n"
  ), Sys.getenv("BIOME_RUN_ID")))
}

