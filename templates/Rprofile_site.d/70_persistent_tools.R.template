  # v11.0 [N9]: biome_future_plan — picks best backend for workload
  assign("biome_future_plan", function(workers = NULL, strategy = c("auto", "cluster", "callr", "sequential")) {
    strategy <- match.arg(strategy)
    if (!requireNamespace("future", quietly = TRUE)) {
      stop("Package 'future' is required. install.packages('future')")
    }
    if (is.null(workers)) {
      workers <- max(1L, .biome_env$shared_env$last_cores - 1L)
    }
    workers <- as.integer(workers)

    if (strategy == "auto") {
      # Auto-pick: if NIMBLE or Stan is loaded, callr is safer (fresh R process
      # per task, no socket to corrupt during long compilations).
      # Otherwise cluster (faster startup, shared state).
      if (isNamespaceLoaded("nimble") || isNamespaceLoaded("rstan") ||
          isNamespaceLoaded("cmdstanr") || isNamespaceLoaded("brms")) {
        strategy <- "callr"
      } else {
        strategy <- "cluster"
      }
    }

    if (strategy == "sequential") {
      future::plan(future::sequential)
      message(paste0(.C_CYAN, "BIOME-CALC: future::plan = sequential (no parallelism)", .C_RESET))
      return(invisible("sequential"))
    } else if (strategy == "callr") {
      if (!requireNamespace("future.callr", quietly = TRUE)) {
        message(paste0(.C_YELLOW,
          "BIOME-CALC: future.callr not installed. Falling back to cluster.\n",
          "  Install: install.packages('future.callr')", .C_RESET))
        strategy <- "cluster"
      } else {
        future::plan(future.callr::callr, workers = workers)
        message(sprintf(paste0(.C_GREEN,
          "\U0001F680 BIOME-CALC: future::plan = callr, %d workers (fresh R per task, MCMC-safe)",
          .C_RESET), workers))
        return(invisible("callr"))
      }
    }

    if (strategy == "cluster") {
      cl <- .biome_make_cluster_impl(workers = workers, worker_threads = 1L)
      future::plan(future::cluster, workers = cl)
      message(sprintf(paste0(.C_GREEN,
        "\U0001F680 BIOME-CALC: future::plan = cluster, %d PSOCK workers (BIOME_WORKER_MODE=1)",
        .C_RESET), workers))
      return(invisible("cluster"))
    }
  }, envir = tool_env)

  # v11.4 [W14]: cluster self-test — verifies fast-path, /Rtmp, thread caps.
  # Use to diagnose unserialize/connection errors before running real MCMC.
  # Sys.setenv(BIOME_WORKER_DEBUG="1") before calling to get per-worker logs.
  assign("biome_cluster_test", function(workers = 2L) {
    workers <- max(1L, as.integer(workers))
    cat(sprintf("  Testing biome_make_cluster(%d)...\n", workers))
    cl <- tryCatch(
      biome_make_cluster(workers = workers, worker_threads = 1L),
      error = function(e) {
        cat(sprintf("  [FAIL] Could not create cluster: %s\n", e$message))
        return(NULL)
      }
    )
    if (is.null(cl)) return(invisible(FALSE))
    on.exit(tryCatch(parallel::stopCluster(cl), error = .biome_swerr("Line_2078")), add = TRUE)

    results <- tryCatch(
      parallel::clusterCall(cl, function() {
        # R 4.5+: explicit attach suppresses serialize() 'utils may not be
        # available' warnings — utils is always present but not always attached
        # at the exact moment clusterCall's closure is deserialized.
        requireNamespace("utils", quietly = TRUE)
        list(
          pid          = Sys.getpid(),
          tempdir      = tempdir(),
          worker_mode  = Sys.getenv("BIOME_WORKER_MODE", "NOT_SET"),
          omp_threads  = Sys.getenv("OMP_NUM_THREADS",   "NOT_SET"),
          blas_threads = Sys.getenv("OPENBLAS_NUM_THREADS", "NOT_SET"),
          rtmp_ok      = dir.exists("/Rtmp"),
          profile_fast = isTRUE(getOption("biome.profile.loaded")),
          # XDR check: parallelly uses FALSE (little-endian), base uses TRUE
          r_version    = paste0(R.version$major, ".", R.version$minor),
          detected_by  = {
            args <- commandArgs(trailingOnly = TRUE)
            if (any(grepl("^MASTER=", args))) "commandArgs" else
            if (nzchar(Sys.getenv("BIOME_WORKER_MODE", ""))) "env_var" else
            "NEITHER — full profile loaded (BUG)"
          }
        )
      }),
      error = function(e) {
        cat(sprintf("  [FAIL] clusterCall failed: %s\n", e$message))
        NULL
      }
    )

    if (is.null(results)) return(invisible(FALSE))

    all_ok <- TRUE
    for (i in seq_along(results)) {
      r <- results[[i]]
      ok <- r$profile_fast && r$rtmp_ok &&
            r$worker_mode == "1" &&
            r$omp_threads == "1" &&
            !grepl("BUG", r$detected_by)
      status <- if (ok) "[OK]  " else "[WARN]"
      if (!ok) all_ok <- FALSE
      cat(sprintf("  %s Worker %d | pid=%d | detected_by=%s | fast_path=%s | /Rtmp=%s | omp=%s\n",
          status, i, r$pid, r$detected_by,
          r$profile_fast, r$rtmp_ok, r$omp_threads))
    }

    if (all_ok) {
      cat("  All workers passed. biome_make_cluster() is functioning correctly.\n")
    } else {
      cat("  WARNING: one or more workers did not take the fast path.\n")
      cat("  Re-run with Sys.setenv(BIOME_WORKER_DEBUG='1') for per-worker logs in /tmp/.\n")
    }
    invisible(all_ok)
  }, envir = tool_env)

  # v11.4 [W15]: Global debug dump — shows debug log + live session state.
  # Only useful when BIOME_DEBUG=1 was set before starting R.
  assign("biome_debug_dump", function(tail_n = 60L) {
    dbg_log <- .biome_env$BIOME_DEBUG_LOG
    if (!nzchar(dbg_log)) {
      cat("BIOME_DEBUG not active. Restart R with:\n")
      cat("  BIOME_DEBUG=1 R\n")
      cat("  BIOME_DEBUG=1 Rscript your_script.R\n\n")
      cat("--- In-memory diag_logs (last 20 entries) ---\n")
      logs <- .biome_env$shared_env$diag_logs
      if (length(logs) == 0) { cat("  (empty)\n"); return(invisible(NULL)) }
      for (nm in tail(names(logs), 20L)) {
        e <- logs[[nm]]
        cat(sprintf("  [%s] [%-20s] [%-4s] %s\n",
            format(e$ts, "%H:%M:%S"), nm, e$status, e$msg))
      }
      return(invisible(NULL))
    }
    if (!file.exists(dbg_log)) {
      cat(sprintf("Debug log not found: %s\n", dbg_log))
      return(invisible(NULL))
    }
    lines <- readLines(dbg_log, warn = FALSE)
    cat(sprintf("--- %s (%d lines, showing last %d) ---\n",
        dbg_log, length(lines), min(tail_n, length(lines))))
    cat(paste(tail(lines, tail_n), collapse = "\n"), "\n")
    cat(sprintf("\n--- Live state | pid=%d | cores=%d | threads=%d | quota=%d GB ---\n",
        Sys.getpid(),
        .biome_env$shared_env$last_cores,
        .biome_env$shared_env$last_threads,
        .biome_env$shared_env$last_quota))
  }, envir = tool_env)

  # Store debug log path in .biome_env so biome_debug_dump() can find it
