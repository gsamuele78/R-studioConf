  # ── biome_cgroup_verify: R-side 3-layer cgroup verification tool (v11.4) ──
  # Checks: systemd dropin file, kernel memory.max, current session state.
  # Guides users when cgroup limits are "Inf (not detected)" — typically means
  # the user logged in BEFORE the cgroup deployment was applied.
  assign("biome_cgroup_verify", function() {
    cat(paste0("\n", .C_CYAN, "=== BIOME-CALC Cgroup Verification ===", .C_RESET, "\n"))
    uid <- tryCatch(MY_UID, error = function(e) -1L)

    # Layer 1: systemd drop-in file
    dropin <- "/etc/systemd/system/user-.slice.d/50-biome-limits.conf"
    dropin_status <- if (file.exists(dropin)) {
      paste0(.C_GREEN, "[PRESENT]", .C_RESET)
    } else {
      paste0(.C_RED, "[MISSING]", .C_RESET,
             " — run: sudo 50_setup_nodes.sh, option 8")
    }
    cat(sprintf("  Systemd dropin:   %s\n", dropin_status))

    # Layer 2: kernel-reported cgroup limits
    cg <- tryCatch(
      .biome_cgroup_read_limits(uid),
      error = function(e) list(ram_gb = Inf, cpus = Inf, source = "error")
    )
    cg_ram_str <- if (is.finite(cg$ram_gb)) sprintf("%.0f GB", cg$ram_gb) else "max (no limit set)"
    cg_cpu_str <- if (is.finite(cg$cpus)) sprintf("%.1f vCPUs", cg$cpus) else "unlimited"
    cg_src_str <- if (!is.null(cg$source) && nzchar(cg$source)) cg$source else "none"
    cat(sprintf("  Kernel reports:   RAM=%s | CPU=%s | source=%s\n",
                cg_ram_str, cg_cpu_str, cg_src_str))

    # Layer 3: current Rprofile session state (read during profile load)
    sess_ram <- .biome_env$shared_env$cgroup_ram_gb
    sess_cpu <- .biome_env$shared_env$cgroup_cpus
    cat(sprintf("  Session state:    cgroup_ram_gb=%s | cgroup_cpus=%s\n",
                format(sess_ram), format(sess_cpu)))

    # Diagnosis
    if (!is.finite(sess_ram)) {
      cat(paste0("\n  ", .C_YELLOW, "[ACTION NEEDED]", .C_RESET,
                 " Kernel shows 'max' (unlimited) for your session.\n"))
      cat("  Your login session predates the cgroup deployment. Solutions:\n")
      cat("    1. Log out of RStudio and log back in.\n")
      cat("    2. Ask admin to run: loginctl terminate-user <your-username>\n")
      cat("    3. Admin can verify server-side: sudo 50_setup_nodes.sh --verify\n")
    } else {
      cat(paste0("\n  ", .C_GREEN, "[OK]", .C_RESET,
                 " Cgroup memory limits are active for this session.\n"))
    }

    invisible(cg)
  }, envir = tool_env)

  .biome_mark_time("finalization")
  # ── FINALIZATION ──
  setHook("rstudio.sessionInit", function(newSession) {
    if (newSession && interactive()) {
      tryCatch({
        cf <- file.path(Sys.getenv("HOME"), "ULTIMO_CRASH_RAM.txt")
        if (file.exists(cf)) {
           message(paste0("\n", .C_RED, " WARNING: Previous session killed by OOM ", .C_RESET))
           try(file.remove(cf), silent=TRUE)
        }
      }, error = .biome_swerr("Line_2420"))

      bn <- "**********************************************************"
      message(paste0("\n", .C_CYAN, bn))
      message(sprintf("*** BIOME-CALC v%s (%s)%s***", VERSION, R_HOST,
                       paste(rep(" ", max(1, 37 - nchar(VERSION) - nchar(R_HOST))), collapse="")))
      message("*** Local-disk architecture: NIMBLE/TMB/Stan -> /Rtmp   ***")
      message("*** If you have any problem please write an e-mail to: ***")
      message(sprintf("*** %-52s ***", "%%BIOME_CONTACT%%"))
      message("*** Don't share your password with anyone...           ***")
      message(paste0(bn, .C_RESET))

      # v12.0 [C7]: Banner reflects cgroup enforcement reality.
      .cg_ram <- .biome_env$shared_env$cgroup_ram_gb
      .cg_cpu <- .biome_env$shared_env$cgroup_cpus
      message(sprintf("\n   RAM:        %-3d GB available  (VM %dGB | slice limit: %s)",
                       .biome_env$shared_env$last_quota, VM_RAM_GB,
                       if (is.finite(.cg_ram)) sprintf("%.0f GB", .cg_ram) else "none"))
      message(sprintf("   BLAS/OMP:   %d threads capped  (cores: %d | slice CPU: %s)",
                       .biome_env$shared_env$last_threads,
                       .biome_env$shared_env$last_cores,
                       if (is.finite(.cg_cpu)) sprintf("%.1f", .cg_cpu) else "CPUWeight fair-share"))

      ct <- Sys.getenv("OPENBLAS_CORETYPE", "auto")
      cpuv <- tryCatch({
        ci <- readLines("/proc/cpuinfo", n = 5, warn = FALSE)
        vl <- grep("^vendor_id", ci, value = TRUE)[1]
        if (!is.na(vl)) trimws(sub(".*:\\s*", "", vl)) else "unknown"
      }, error = function(e) "unknown")
      message(sprintf("   BLAS:       CORETYPE=%s (vendor=%s, serial=%s)",
                       ct, cpuv, isTRUE(.biome_env$blas_is_serial)))

      tryCatch({
        ei <- extSoftVersion()
        blas_lib <- basename(La_library())
        lapack_ver <- ei[["LAPACK"]]
        if (is.null(lapack_ver) || !nzchar(lapack_ver)) lapack_ver <- "system"
        message(sprintf("   LAPACK:     %s (%s)", blas_lib, lapack_ver))
      }, error = .biome_swerr("Line_2452"))

      tryCatch({
        df_out <- system2("df", args = c("-h", RTMP_PATH), stdout = TRUE, stderr = FALSE)
        if (length(df_out) >= 2) {
          p <- strsplit(trimws(df_out[2]), "\\s+")[[1]]
          message(sprintf("   /Rtmp:      %s free of %s (%s)", p[4], p[2], p[5]))
        }
      }, error = .biome_swerr("Line_2460"))

      message(sprintf("   UserTmp:    %s", .biome_env$USER_TMP_ROOT))

      message(paste0("\n   ", .C_BOLD, "\U0001F680 Engines:", .C_RESET))
      r_sio <- .fmt_eng("SmartIO", ENABLE_SMART_IO, TRUE)
      r_ai  <- .fmt_eng("AI", ENABLE_AI_ASSISTANT, .biome_env$shared_env$ai_active)
      r_ter <- .fmt_eng("Terra", ENABLE_TERRA_OPT, isNamespaceLoaded("terra"))
      r_arr <- .fmt_eng("Arrow", ENABLE_ARROW_OPT, isNamespaceLoaded("arrow"))
      r_tf  <- .fmt_eng("Keras/TF", ENABLE_TF_MGMT, isNamespaceLoaded("tensorflow"))
      message(sprintf("   %s  %s  %s  %s  %s", r_sio, r_ai, r_ter, r_arr, r_tf))

      message("----------------------------------------------------------")
      message(paste0("   \U0001F4A1 Type ", .C_BOLD, "biome_help()", .C_RESET, " for commands."))
      message(paste0("   \U0001F4DA Type ", .C_BOLD, "biome_tutorial()", .C_RESET, " for MCMC examples."))
      message(paste0("   \U0001F4CA Type ", .C_BOLD, "status()", .C_RESET, " for resource quotas."))
      message(paste0("   \U0001F50D Type ", .C_BOLD, "biome_worker_diagnostics()", .C_RESET, " after worker crashes."))
      if (.biome_env$shared_env$ai_active) message(paste0("   \U0001F916 Try  ", .C_BOLD, 'ask_ai("Help me with R")', .C_RESET, "."))
      message(sprintf("   Startup: %.2fs", as.numeric(difftime(Sys.time(), .start_time, units="secs"))))
      message(paste0(.C_CYAN, bn, .C_RESET, "\n"))
    }
  }, action = "append")

  reg.finalizer(.biome_env, function(env) {
    tryCatch({ sys_log("Session", "END", sprintf("User: %s", curr_user)) }, error = .biome_swerr("Line_2484"))
    # v11.3 [W8]: cleanup only real compile dirs (stan_compile is the only one
    # that writes per-session subdirs; nimble/tmb were phantom in v11.0-v11.2)
    tryCatch({
      for (sub in c("stan_compile")) {
        d <- file.path(.biome_env$USER_TMP_ROOT, sub, paste0("session_", Sys.getpid()))
        if (dir.exists(d)) unlink(d, recursive = TRUE, force = FALSE)
      }
    }, error = .biome_swerr("Line_2492"))
  }, onexit = TRUE)

  .biome_mark_time("profile_end")
  sys_log("Profile", "OK", "Loaded successfully (v12.0)")
  
  # ── Final Load Report ──
  if (BIOME_GLOBAL_DEBUG) {
    cat("\n=== BIOME DEBUG LOAD REPORT ===\n")
    for (nm in names(.biome_env$shared_env$timers)) {
      cat(sprintf("  [%-20s] %7.3fs\n", nm, .biome_env$shared_env$timers[[nm]]))
    }
    swallowed <- Filter(function(x) identical(x$status, "SWALLOW"), .biome_env$shared_env$diag_logs)
    if (length(swallowed) > 0) {
      cat(sprintf("\n  Caught %d swallowed errors:\n", length(swallowed)))
      for (nm in names(swallowed)) {
        cat(sprintf("  - [%s] %s\n", nm, swallowed[[nm]]$msg))
      }
    } else {
      cat("\n  No swallowed errors detected.\n")
    }
    cat("===============================\n")
  }
