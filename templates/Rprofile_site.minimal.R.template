# Deployed by:    scripts/50_setup_nodes.sh
# Activated via:  /usr/local/bin/r_minimal  (sets R_PROFILE_USER=this file)
#
# PURPOSE (HC-13 — Adapt System, Not User Script):
#   Bare-bones Rprofile for sysadmin triage. ZERO wrappers, ZERO package hooks,
#   ZERO dispatcher, ZERO bspm. Sets only the irreducible safety env-vars and
#   exposes 7 forensic helpers for diagnosing why a user script hangs/crashes.
#
# WHEN TO USE:
#   * L0 / L1 layer of the HC-13 troubleshooting ladder
#     (see docs/operations/USER_SCRIPT_TROUBLESHOOTING.md).
#   * To prove that a hang reproduces under PURE R (no profile fragments) —
#     in which case the bug is in the user script or in the OS/NFS/terra
#     stack, NOT in our profile dispatcher.
#
# WHAT IT INTENTIONALLY DOES NOT DO:
#   * No fragment loader. No /etc/R/Rprofile_site.d/ sourcing.
#   * No detectCores wrapper, no options() guard, no setwd guard.
#   * No bspm, no Ollama, no telemetry, no callbacks.
#   * No package hooks (terra/sf/raster/nimble/stan/...).
#   * No /Rtmp pre-creation beyond BIOME_USER_TMP.
#
# CONTACT: %%BIOME_CONTACT%%
# ==============================================================================

# ── Banner (always on — point of this profile is troubleshooting) ──────────
local({
  cat(
    "\n",
    "\033[1;33m========================================================\033[0m\n",
    "\033[1;33m  BIOME-CALC MINIMAL FORENSIC PROFILE v1.0  (HC-13 L0/L1)\033[0m\n",
    "\033[1;33m========================================================\033[0m\n",
    "  Pure R + safe env vars + forensic helpers ONLY.\n",
    "  No fragments, no wrappers, no package hooks.\n",
    "  Type \033[1mbiome_help()\033[0m for the command list.\n",
    "  Type \033[1mbiome_diag()\033[0m for a one-page system summary.\n",
    "\n", sep = ""
  )
})

# ── Section 1: irreducible safety env vars (mirrors Renviron.site) ─────────
# Single-thread everything — defensive default. User code is free to raise
# these AFTER load if they know what they are doing.
local({
  for (v in c("OMP_NUM_THREADS", "OPENBLAS_NUM_THREADS", "MKL_NUM_THREADS",
              "VECLIB_MAXIMUM_THREADS", "NUMEXPR_NUM_THREADS",
              "GOTO_NUM_THREADS", "BLIS_NUM_THREADS", "GDAL_NUM_THREADS")) {
    if (!nzchar(Sys.getenv(v, ""))) Sys.setenv(setNames(list("1"), v))
  }
})

# ── Section 2: OPENBLAS_CORETYPE auto-detect (QEMU SIGILL guard) ───────────
if (!nzchar(Sys.getenv("OPENBLAS_CORETYPE", ""))) {
  tryCatch({
    ci <- readLines("/proc/cpuinfo", n = 25, warn = FALSE)
    vendor <- trimws(sub(".*:\\s*", "", grep("^vendor_id", ci, value = TRUE)[1]))
    flags  <- trimws(sub(".*:\\s*", "", grep("^flags",     ci, value = TRUE)[1]))
    coretype <- if (grepl("AMD",   vendor, ignore.case = TRUE))
                  if (grepl("\\bavx2\\b",    flags)) "ZEN"      else "BARCELONA"
                else if (grepl("Intel", vendor, ignore.case = TRUE))
                  if (grepl("\\bavx512f\\b", flags)) "SKYLAKEX" else "HASWELL"
                else NULL
    if (!is.null(coretype)) Sys.setenv(OPENBLAS_CORETYPE = coretype)
  }, error = function(e) NULL)
}

# ── Section 3: TMPDIR / BIOME_USER_TMP (only if /Rtmp exists) ──────────────
local({
  curr_user <- tryCatch(Sys.info()[["user"]], error = function(e) "unknown")
  if (dir.exists("/Rtmp")) {
    user_tmp <- file.path("/Rtmp", paste0("biome_", curr_user))
    tryCatch({
      if (!dir.exists(user_tmp))
        dir.create(user_tmp, recursive = TRUE, showWarnings = FALSE, mode = "0700")
      Sys.setenv(BIOME_USER_TMP = user_tmp, TMPDIR = user_tmp)
    }, error = function(e) NULL)
  }
})

