# docker-deploy/.env.sandbox
# Local testing environment for R-studioConf Vagrant Sandbox.
# Uses test tokens and disabled external calls.

# RStudio General Configuration
RSTUDIO_SSSD_IMAGE=rstudio-botanical-sssd:sandbox
RSTUDIO_SAMBA_IMAGE=rstudio-botanical-samba:sandbox
RSTUDIO_MEMORY_LIMIT=2G
RSTUDIO_CPU_LIMIT=1.0
RAMDISK_SIZE=512M
DOCKER_USERID=1000
DOCKER_GROUPID=1000

# Proxy & SSL Configuration
# No Let's Encrypt in sandbox
LETSENCRYPT_MODE=disabled
NGINX_HOST=192.168.56.40

# Keycloak / SSO Configuration (assuming iam-host handles this, or disabled)
OAUTH2_PROXY_CLIENT_ID=sandbox-rstudio
OAUTH2_PROXY_CLIENT_SECRET=sandbox123
OAUTH2_PROXY_COOKIE_SECRET=00000000000000000000000000000000

# Fake PKI Fingerprint from upstream test
FINGERPRINT=sandbox-dummy-fingerprint
STEP_CA_ROOT_PATH=../docker-deploy/shared-certs/step-ca-root.crt

# Host mount paths (sandbox overrides)
RSTUDIO_DATA_DIR=./data
RSTUDIO_CONFIG_DIR=./config
