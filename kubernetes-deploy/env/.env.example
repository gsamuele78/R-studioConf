# kubernetes-deploy/env/.env.example
# ──────────────────────────────────────────────────────────────
# Template for env/.env.prd consumed by scripts/deploy_k8s.sh.
# DO NOT COMMIT env/.env.prd (HC-08).
#
# Tier T3 status: SKELETON_NOT_READY (.ai/project.yml).
# These keys mirror what deploy_k8s.sh injects into Secrets.
# ──────────────────────────────────────────────────────────────

# Domain / Ingress
HOST_DOMAIN=rstudio.example.example.org
NEXTCLOUD_URL=https://nextcloud.example.example.org

# Active Directory bind (for SSSD/Samba sidecar — T3 design pending)
AD_BIND_USER=svc-rstudio
AD_BIND_PASSWORD=__REPLACE_ME__
AD_DOMAIN=ad.example.com

# step-ca PKI (ACME / cert rotation — T3 design pending)
STEP_TOKEN=__REPLACE_ME__
STEP_CA_FINGERPRINT=__REPLACE_ME__
STEP_CA_URL=https://step-ca.example.example.org

# OIDC (oauth2-proxy → Keycloak; aligns with Infra-Iam-PKI sibling project)
OIDC_ISSUER_URL=https://keycloak.example.example.org/realms/unibo
OIDC_CLIENT_ID=rstudio
OIDC_CLIENT_SECRET=__REPLACE_ME__
OIDC_COOKIE_SECRET=__REPLACE_ME__   # 32 bytes base64

# Image tags (kustomization.yaml → images: block does the actual pinning)
IMAGE_TAG=1.0.0
RSTUDIO_IMAGE=rstudio-botanical-sssd
PORTAL_IMAGE=botanical-portal-nginx
OLLAMA_IMAGE=botanical-ai-ollama
TELEMETRY_IMAGE=botanical-telemetry-api
