#!/bin/bash
# ----------------------------------------------------------------
# SETUP NODES VARS (v1.0)
# ----------------------------------------------------------------
# Configuration for 50_setup_nodes.sh
# This script deploys OpenBLAS/CORETYPE detection, Rprofile.site v9.3.x,
# the R audit script, kernel tuning, and optional Ollama AI service.

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# The hostname shown in the Rprofile welcome banner and log files.
# Auto-detected at runtime if left empty.
BIOME_HOST=""

# IP used for info display (auto-detected from hostname -I if empty).
BIOME_IP=""

# NFS home directory root (where AD users' homes live)
NFS_HOME="/nfs/home"

# CIFS/SMB archive mount point
CIFS_ARCHIVE="/mnt/ProjectStorage"

# Python geospatial virtualenv path (created/updated by setup)
PYTHON_ENV="/opt/r-geospatial"

# Local /Rtmp disk (dedicated virtio disk per VM — NOT tmpfs, NOT NFS, NOT OS /tmp)
# Each VM has its own 400GB disk mounted at /Rtmp. This is NOT shared.
# Set to 0 to indicate /Rtmp does NOT consume RAM (disk-backed).
RAMDISK_SIZE="0"
RAMDISK_GB=0
TMP_DISK_GB=400

# /Rtmp usage advisory threshold (% of local disk — warning only, no redirect)
# At 80%, users get a warning to clean up. No auto-redirect — local disk is safe.
TMP_WARN_THRESHOLD_PCT=80

# Name of the biome-calc config directory (stores audit.conf, ai_model, etc.)
BIOME_CONF="/etc/biome-calc"

# System log file (world-writable so AD rsession users can write to it)
LOG_FILE="/var/log/biome-log/r_biome_system.log"

# ==============================================================================
# 5. ORPHAN CLEANUP SETTINGS
# ==============================================================================
# Email threshold and tracking settings
SMTP_HOST="smtp.unibo.it"
SMTP_PORT="25"
SENDER_EMAIL="noreply-biome@unibo.it"
MAIL_DOMAIN="studio.unibo.it"
SMTP_DNS_SERVERS="137.204.25.10 137.204.25.11"
KILL_TIMEOUT="30"

# Cron scheduling
ORPHAN_CRON_CLEANUP="15 * * * *"
ORPHAN_CRON_NOTIFY="00 18 * * *"
ORPHAN_CRON_REPORT="00 08 * * 1"

# ==============================================================================
# 6. ARCHIVE PROJECT SETTINGS
# ==============================================================================
# Directories and deployment files for BIOME Precision Archiver
ARCHIVE_STORAGE_ROOT="/mnt/ProjectStorage"
ARCHIVE_LOG_DIR="/var/log/biome-log/biome_archive"
ARCHIVE_CONF_DIR="${BIOME_CONF}/conf"
ARCHIVE_CSV_FILE="${ARCHIVE_CONF_DIR}/biome_supervisor_map.csv"

# Cron scheduling (daily at 03:00)
ARCHIVE_CRON_SCHEDULE="00 03 * * *"

# =============================================================================
# SWAP
# =============================================================================

# Path to the swap file (created/managed by setup_nodes_swap)
SWAP_FILE="/swap.img"

# Desired swap size in GB (32 GB = 32768 MiB)
SWAP_SIZE_GB=32

# =============================================================================
# RPROFILE & R CONFIGURATION
# =============================================================================

# Number of vCores visible to the VM (shown in Rprofile's welcome banner)
VM_VCORES=32

# Total RAM available to the VM in GB (net of OS overhead — shown in welcome)
VM_RAM_GB=400

# RStudio session configuration (read by Rprofile to determine cleanup timeout)
RSESSION_CONF_PATH="/etc/rstudio/rsession.conf"

# =============================================================================
# OPENBLAS / BLAS TUNING
# =============================================================================

# Maximum OpenBLAS/OMP thread cap to prevent QEMU livelock
# This is also enforced in Rprofile.site dynamically.
MAX_BLAS_THREADS=16
# Alias used by the audit template (%%MAX_THREADS%%)
MAX_THREADS=16

# Path to OpenBLAS serial BLAS/LAPACK alternative
# CRITICAL: Must use openblas-serial, NOT openblas-pthread.
# OpenBLAS-pthread's internal thread pool conflicts with RStudio rsession's
# own pthreads (event loop, HTTP, watchdog), causing SIGSEGV in blas_thread_server
# during solve()/crossprod() on dense matrices. See: rstudio/rstudio#7031
OPENBLAS_BLAS_PATH="/usr/lib/x86_64-linux-gnu/openblas-serial/libblas.so.3"
OPENBLAS_LAPACK_PATH="/usr/lib/x86_64-linux-gnu/openblas-serial/liblapack.so.3"

# =============================================================================
# OLLAMA AI SERVICE
# =============================================================================

# Set to "true" to skip Ollama installation/setup
SKIP_OLLAMA=false

# Base model for AI assistant (8-bit quant: best quality; 4-bit: less RAM)
OLLAMA_BASE_MODEL="qwen2.5-coder:14b-instruct-q4_K_M"

# Fallback model if the base model cannot be pulled
OLLAMA_FALLBACK_MODEL="codellama:7b"

# Name of the custom R-focused model created from the Modelfile
OLLAMA_CUSTOM_MODEL="r-coder"

# Maximum RAM for the Ollama systemd service (cgroup MemoryMax)
OLLAMA_RAM_LIMIT="24G"

# Number of inference threads (roughly half of vCores, leaves rest for R)
OLLAMA_THREADS=24

# =============================================================================
# PYTHON PACKAGES (for geospatial venv)
# =============================================================================

# Python packages installed into PYTHON_ENV
PYTHON_PACKAGES=(
    "earthengine-api"
    "numpy<2"
    "pandas"
    "tensorflow>=2.16"
    "tf-keras"
)

# =============================================================================
# R PACKAGES
# =============================================================================

# R packages installed via bspm/CRAN during setup
R_PACKAGES=(
    # ── Core Data ──
    "data.table"
    "arrow"
    "dplyr"
    "tidyr"
    "tidyverse"     # Meta-package (loads ggplot2, dplyr, tidyr, etc.)
    "jsonlite"
    "httr"          # HTTP client (GBIF/API downloads)
    "devtools"      # Package development & GitHub installs
    "progress"      # Progress bars for long operations
    "tictoc"        # Timing utility
    # ── Visualization ──
    "ggplot2"       # Required for audit v27 render test
    "ragg"          # Anti-Grain Geometry renderer (2-4x faster than cairo)
    "svglite"       # SVG output for publication figures
    "systemfonts"   # Font cache for ragg/svglite
    "tmap"          # Thematic maps (heavy polygon rendering, tests ragg)
    "mapview"       # Interactive maps
    # ── Geospatial ──
    "terra"
    "sf"
    "stars"         # Modern raster alternative (uses local /Rtmp disk)
    "sp"            # Legacy spatial (dependency for geosphere/gstat/raster)
    "raster"        # Legacy raster (still needed by many older packages)
    "geosphere"     # Geodistance matrices (required for audit ecology tests)
    "geodata"       # WorldClim/GBIF raster data downloads
    "osmdata"       # OpenStreetMap data
    "rnaturalearth" # Country/boundary shapefiles
    "nngeo"         # Nearest-neighbor geospatial
    "rgee"
    # ── Spatial Statistics ──
    "fields"        # Kriging/Tps — uses outer() + solve() (double guard test)
    "gstat"         # Geostatistics/variograms
    "spatstat"      # Spatial point patterns
    "ncdf4"         # NetCDF I/O (climate data, 1-50 GB files, local /Rtmp stress)
    # ── Species Distribution Modeling ──
    "dismo"         # SDM (expand.grid on parameter grids → OOM guard test)
    "enmSdmX"       # ENM/SDM wrapper (calls dismo+terra+sf)
    "spThin"        # Spatial thinning of occurrence records
    "CoordinateCleaner"  # GBIF data coordinate validation
    # ── Ecology / Biodiversity ──
    "vegan"         # Community ecology (vegdist→dist(), validates OOM guards)
    "iNEXT"         # Rarefaction/extrapolation for diversity
    "igraph"        # Network/graph analysis (large RAM consumer)
    # ── Statistical Modeling ──
    "lme4"          # Mixed models (solve on sparse Cholesky, most-cited ecology pkg)
    "glmmTMB"       # Generalized LMMs via TMB (Hessian → solve() OOM risk)
    "TMB"           # Template Model Builder (C++ AD, uses BLAS threads)
    "DHARMa"        # GLMM residual diagnostics
    # ── NIMBLE Ecosystem (deps must precede nimble → nimbleHMC) ──
    "R6"            # OOP classes (NIMBLE dependency)
    "coda"          # MCMC output analysis (NIMBLE dependency)
    "pracma"        # Numerical math (NIMBLE dependency)
    "numDeriv"      # Numerical derivatives (NIMBLE dependency)
    "nimble"        # NIMBLE DSL + C++ compiler framework (needs build-essential)
    "nimbleHMC"     # Bayesian MCMC Hamiltonian Monte Carlo (extends nimble)
    "caret"         # ML with hyperparameter grids (expand.grid OOM risk)
    "Matrix"        # Sparse algebra (escape route recommended by solve() guard)
    "covr"
    "mcmcse"
    "nimbleQuad"
    # ── Conservation Planning ──
    "prioritizr"    # Conservation optimization (LP solver, heavy memory)
    "highs"         # HiGHS LP solver backend for prioritizr
    # ── Parallel / Compute ──
    "future"
    "future.apply"
    "furrr"         # Future-based purrr (parallel map)
    "parallelly"
    "doParallel"    # Parallel foreach backend (needs thread capping on workers)
    "RhpcBLASctl"
    # ── AI / ML / Python ──
    "tensorflow"
    "keras"
    "reticulate"
    "chattr"
    # ── Java / Climate4R support ──
    "rJava"         # Java bridge (required by climate4R/loadeR GitHub packages)
    # ── System ──
    "unix"
    "sessioninfo"
    # NOTE: mgcv, nlme, MASS, parallel are bundled with base R
    # NOTE: climate4R suite (loadeR, downscaleR, etc.) install via r_env_manager.sh
)

# =============================================================================
# CONTACT / BRANDING
# =============================================================================

# Contact email shown in Rprofile welcome and audit reports
BIOME_CONTACT="Lifewatch_Biome_internal@live.unibo.it"

# Rprofile version label (shown in welcome banner and status())
RPROFILE_VERSION="10.0"
