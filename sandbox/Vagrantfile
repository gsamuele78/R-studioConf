# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Multi-VM Vagrant Sandbox for R-studioConf
#
# Simulates real production topology:
#   192.168.56.40  =>  rstudio-host
#

LOG_DIR = File.join(File.dirname(__FILE__), "logs")

def log_path(hostname, phase)
  host_dir = File.join(LOG_DIR, hostname)
  FileUtils.mkdir_p(host_dir) unless Dir.exist?(host_dir)
  "/workspace/R-studioConf/sandbox/logs/#{hostname}/#{phase}.log"
end

def logged_shell(hostname, phase, script)
  log = log_path(hostname, phase)
  <<~SHELL
    mkdir -p "$(dirname '#{log}')"
    > '#{log}'
    _TS_CMD="awk '{ print strftime(\\"%Y-%m-%dT%H:%M:%S\\"), $0; fflush() }'"
    if command -v ts >/dev/null 2>&1; then _TS_CMD="ts '%Y-%m-%dT%H:%M:%S'"; fi
    exec > >(eval "$_TS_CMD" | tee -a '#{log}') 2>&1
    echo "=========================================="
    echo " HOST    : #{hostname}"
    echo " PHASE   : #{phase}"
    echo "=========================================="
    #{script}
    _EXIT=$?
    echo "=========================================="
    echo " STATUS  : $( [ $_EXIT -eq 0 ] && echo 'SUCCESS' || echo 'FAILED' )"
    echo "=========================================="
    SUMMARY_LOG="/workspace/R-studioConf/sandbox/logs/summary.log"
    printf "%-12s %-20s %-8s %s\\n" "#{hostname}" "#{phase}" \
      "$( [ $_EXIT -eq 0 ] && echo 'OK' || echo 'FAILED' )" \
      "$(date '+%Y-%m-%dT%H:%M:%S')" | tee -a "$SUMMARY_LOG"
    exit $_EXIT
  SHELL
end

FileUtils.mkdir_p(LOG_DIR) unless Dir.exist?(LOG_DIR)
summary_log = File.join(LOG_DIR, "summary.log")
File.open(summary_log, "a") do |f|
  f.puts ""
  f.puts "# vagrant up  #{Time.now.strftime('%Y-%m-%d %H:%M:%S')}"
  f.puts "#{'%-12s %-20s %-8s %s' % %w[HOST PHASE STATUS TIMESTAMP]}"
  f.puts "#{'─' * 60}"
end

Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"

  config.vm.synced_folder ".", "/vagrant", disabled: true
  config.vm.synced_folder "../", "/workspace/R-studioConf", type: "rsync",
    rsync__exclude: [
      ".git/",
      "sandbox/.vagrant/",
      "sandbox/logs/"
    ]

  config.vm.provision "shell", name: "install-docker", inline: logged_shell("all-hosts", "install-docker", <<~'INNER')
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq && apt-get install -y ca-certificates curl gnupg moreutils
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list
    apt-get update -qq && apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    usermod -aG docker vagrant
  INNER

  # RStudio Host on 192.168.56.40
  config.vm.define "rstudio-host" do |rst|
    rst.vm.hostname = "rstudio-host"
    rst.vm.network "private_network", ip: "192.168.56.40"

    rst.vm.provider :libvirt do |libvirt|
      libvirt.driver = "kvm"
      libvirt.memory = 4096
      libvirt.cpus   = 4
    end

    rst.vm.provision "shell", name: "start-rstudio", inline: logged_shell("rstudio-host", "start-rstudio", <<~'INNER')
      set -euo pipefail
      
      echo "[1/2] Prepping sandbox environment..."
      cd /workspace/R-studioConf/docker-deploy
      # Using our sandbox overrides
      cp .env.sandbox .env

      echo "[2/2] Starting RStudio Deploy (sssd)..."
      docker compose up -d --build

      echo "Waiting for services to become healthy..."
      sleep 10
      docker compose ps
      
      echo "====================================================="
      echo " RStudio Host Ready (192.168.56.40)"
      echo "====================================================="
    INNER
    
    rst.trigger.after :provision do |t|
      t.name = "pull-logs-rstudio"
      t.info = "Pulling provisioning logs from rstudio-host"
      t.run = { inline: "chmod +x ./pull-logs.sh && ./pull-logs.sh rstudio-host" }
    end
  end

end
