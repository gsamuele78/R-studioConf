#!/bin/bash
set -euo pipefail

# .ai/hooks/pre-commit
# ══════════════════════════════════════════════════════════════
# Git pre-commit hook for R-studioConf.
# Validates hard constraints BEFORE allowing a commit.
#
# Installation:
#   .ai/install-hooks.sh
#   (or manually: cp .ai/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)
#
# Bypass (emergency only):
#   git commit --no-verify -m "..."
# ══════════════════════════════════════════════════════════════

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# When running as git hook, we're in .git/hooks/ — project root is ../../
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
VALIDATOR="$PROJECT_ROOT/.ai/validate.sh"

# Only validate if changed files touch infrastructure code
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

NEEDS_VALIDATION=false
for f in $STAGED_FILES; do
    case "$f" in
        docker-deploy/docker-compose.yml|docker-deploy/Dockerfile*|scripts/*.sh|sandbox/*.yml|.ai/*)
            NEEDS_VALIDATION=true
            break
            ;;
    esac
done

if [ "$NEEDS_VALIDATION" = false ]; then
    # No infrastructure files changed — skip validation
    exit 0
fi

echo "═══ Pre-commit: Running constraint validation ═══"

if [ ! -f "$VALIDATOR" ]; then
    echo "Warning: .ai/validate.sh not found — skipping validation"
    exit 0
fi

chmod +x "$VALIDATOR"

# Run validator — exit 1 blocks the commit, exit 2 (warnings) allows it
if ! "$VALIDATOR" --ci; then
    echo ""
    echo "══════════════════════════════════════════════════"
    echo "  COMMIT BLOCKED: Hard constraint violations found"
    echo "  Run: .ai/validate.sh --fix-hint"
    echo "  Bypass (emergency): git commit --no-verify"
    echo "══════════════════════════════════════════════════"
    exit 1
fi

# Check if generated files need updating
GENERATOR="$PROJECT_ROOT/.ai/generate.sh"
if [ -f "$GENERATOR" ]; then
    chmod +x "$GENERATOR"
    if ! "$GENERATOR" --check 2>/dev/null; then
        echo ""
        echo "══════════════════════════════════════════════════"
        echo "  WARNING: Agent context files are outdated."
        echo "  Run: .ai/generate.sh"
        echo "  Then: git add CLAUDE.md .cursorrules .clinerules .windsurfrules .github/"
        echo "══════════════════════════════════════════════════"
        # Warning only — don't block commit for this
    fi
fi

echo "═══ Pre-commit: All checks passed ═══"
exit 0
